{
  "general": {
    "system_name": "多源异构数据同步系统",
    "version": "1.0.0",
    "debug_mode": false,
    "log_level": "INFO",
    "max_log_files": 10,
    "log_rotation_size": 100
  },
  "sync_engine": {
    "sync_interval": 0.01,
    "max_concurrent_sources": 10,
    "enable_auto_recovery": true,
    "recovery_timeout": 30.0,
    "enable_adaptive_sync": true,
    "adaptive_threshold": 0.8
  },
  "data_sources": [
    {
      "source_id": "imu_source_1",
      "source_type": "mqtt",
      "connection_string": "mqtt://localhost:1883/imu/topic1",
      "enabled": true,
      "priority": 1,
      "timeout": 5.0,
      "retry_count": 3,
      "retry_delay": 1.0,
      "metadata": {
        "description": "IMU传感器数据源",
        "data_format": "json",
        "update_rate": 100
      }
    },
    {
      "source_id": "cnap_source_1",
      "source_type": "serial",
      "connection_string": "COM1:9600",
      "enabled": true,
      "priority": 2,
      "timeout": 3.0,
      "retry_count": 5,
      "retry_delay": 0.5,
      "metadata": {
        "description": "CNAP数据源",
        "data_format": "binary",
        "update_rate": 50
      }
    },
    {
      "source_id": "gps_source_1",
      "source_type": "file",
      "connection_string": "/data/gps/source1.txt",
      "enabled": true,
      "priority": 3,
      "timeout": 2.0,
      "retry_count": 2,
      "retry_delay": 2.0,
      "metadata": {
        "description": "GPS数据源",
        "data_format": "csv",
        "update_rate": 10
      }
    },
    {
      "source_id": "database_source_1",
      "source_type": "database",
      "connection_string": "postgresql://user:pass@localhost:5432/sync_db",
      "enabled": false,
      "priority": 4,
      "timeout": 10.0,
      "retry_count": 3,
      "retry_delay": 5.0,
      "metadata": {
        "description": "数据库数据源",
        "data_format": "sql",
        "update_rate": 1
      }
    }
  ],
  "time_alignment": {
    "sync_strategy": "adaptive",
    "max_time_offset": 0.1,
    "quality_threshold": 0.8,
    "enable_ntp_sync": true,
    "ntp_servers": [
      "pool.ntp.org",
      "time.nist.gov",
      "time.windows.com"
    ],
    "sync_interval": 1.0
  },
  "data_fusion": {
    "fusion_algorithm": "weighted_average",
    "quality_weight": 0.7,
    "time_weight": 0.3,
    "enable_adaptive_fusion": true,
    "fusion_threshold": 0.6,
    "max_fusion_delay": 0.5,
    "algorithm_parameters": {
      "weighted_average": {
        "min_quality": 0.5,
        "max_quality": 1.0
      },
      "kalman_filter": {
        "process_noise": 0.01,
        "measurement_noise": 0.1
      },
      "neural_network": {
        "hidden_layers": [64, 32],
        "learning_rate": 0.001,
        "batch_size": 32
      }
    }
  },
  "performance": {
    "max_memory_usage": 1024,
    "enable_memory_optimization": true,
    "gc_threshold": 0.8,
    "enable_async_processing": true,
    "max_worker_threads": 8,
    "queue_size": 1000,
    "optimization_settings": {
      "enable_adaptive_workers": true,
      "max_workers": 16,
      "min_workers": 2,
      "worker_adjustment_threshold": 0.7
    }
  },
  "monitoring": {
    "enable_performance_monitoring": true,
    "monitoring_interval": 1.0,
    "enable_alerting": true,
    "alert_thresholds": {
      "cpu_usage": {
        "warning": 70.0,
        "critical": 90.0
      },
      "memory_usage": {
        "warning": 80.0,
        "critical": 95.0
      },
      "latency": {
        "warning": 0.05,
        "critical": 0.1
      },
      "error_rate": {
        "warning": 0.01,
        "critical": 0.05
      }
    },
    "enable_metrics_storage": true,
    "metrics_retention_days": 30,
    "metrics_storage": {
      "type": "file",
      "path": "./metrics",
      "format": "json"
    }
  },
  "security": {
    "enable_authentication": false,
    "enable_encryption": false,
    "encryption_algorithm": "AES-256",
    "enable_audit_log": true,
    "max_login_attempts": 5,
    "session_timeout": 3600.0,
    "ssl_settings": {
      "enable_ssl": false,
      "cert_file": "",
      "key_file": "",
      "ca_file": ""
    }
  },
  "metadata": {
    "created_at": "2025-08-16T10:00:00Z",
    "created_by": "system",
    "last_modified": "2025-08-16T10:00:00Z",
    "modified_by": "system",
    "description": "多源异构数据同步系统配置文件",
    "tags": ["data_sync", "multi_source", "real_time"]
  }
}
