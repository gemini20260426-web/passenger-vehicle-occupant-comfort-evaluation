            import os
            config_file = os.path.join(os.path.dirname(__file__), '..', '..', 'config', 'mqtt_config.json')
            
            if os.path.exists(config_file):
                import json
                with open(config_file, 'r', encoding='utf-8') as f:
                    config = json.load(f)
                    return str(config.get('port', '1883'))
            
            # 从环境变量获å?
            return os.environ.get('MQTT_PORT', '1883')
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取MQTT端口配置失败: {e}")
            return '1883'  # 降级到默认å?
    
