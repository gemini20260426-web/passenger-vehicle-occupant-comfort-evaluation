class LeftControlPanel(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setStyleSheet(""""""     
    # 定义logger
    logger = logging.getLogger(__name__)
    
    # 定义信号
    data_source_changed = Signal(str, dict)
    analysis_toggled = Signal(bool, str)
    load_file_requested = Signal(str)
    record_toggled = Signal(bool)
    export_data_requested = Signal()
    source_added = Signal(int, str, dict)
    source_removed = Signal(int)
    active_source_changed = Signal(int)
    data_sources_selected = Signal(list)  # 新增信号:数据源选择变化
    
    # 高级分析控制信号
    advanced_analysis_started = Signal()  # 高级分析开始/
    advanced_analysis_stopped = Signal()  # 高级分析停止
    model_load_requested = Signal()       # 模型加载请求
    model_unload_requested = Signal()     # 模型卸载请求
    
    # 管理模块方法定义
    def open_vehicle_management(self):
        """"""         QMessageBox.information(self, "车辆管理", "🚗 车辆管理功能\n\n该功能暂时不可用,右侧标签页已移除。\n\n左侧控制面板中的按钮已保留,可用于将来重新启用此功能?")
    
    def open_driver_management(self):
        """"""         QMessageBox.information(self, "司机管理", "👨司机管理功能\n\n该功能暂时不可用,右侧标签页已移除。\n\n左侧控制面板中的按钮已保留,可用于将来重新启用此功能?")
    
    def open_fleet_management(self):
        """"""         QMessageBox.information(self, "车队管理", "🚛 车队管理功能\n\n该功能暂时不可用,右侧标签页已移除。\n\n左侧控制面板中的按钮已保留,可用于将来重新启用此功能?")
    
    def open_trip_management(self):
        """"""         QMessageBox.information(self, "行程管理", "")
    
    def update_management_summary(self, vehicle_count=0, driver_count=0, fleet_count=0, trip_count=0):
        """"""         try:
            self.vehicle_count_label.setText(str(vehicle_count))
            self.driver_count_label.setText(str(driver_count))
            self.fleet_count_label.setText(str(fleet_count))
            self.trip_count_label.setText(str(trip_count))
        except Exception as e:
            print(f"更新管理模块状态摘要失败 {e}")
    
    def __init__(self, parent=None):
        super().__init__(parent)
        self.main_layout = QVBoxLayout(self)  # 主布局
        self.init_ui()
        
    def init_ui(self):
        """"""         self.main_layout.setContentsMargins(10, 10, 10, 10)
        self.main_layout.setSpacing(10)
        
        # === 🗂ï¸?数据输入统?===
        self.add_data_input_group()
        
        # === ⚙️ 核心分析统?===
        self.add_core_analysis_group()
        
        # === 🔄 数据同步统?===
        self.add_data_sync_group()
        
        # === 🚀 业务管理统?===
        self.add_business_management_group()
        
        # === ⚙️ 系统配置统?===
        self.add_system_config_group()
        
        # 填充剩余空间
        self.main_layout.addStretch()
    
    def _on_data_source_changed(self, source_type: str, config: dict):
        """"""         try:
            self.logger.info(f"数据源变化 {source_type}")
            # 发送信号到主控制器
            self.data_source_changed.emit(source_type, config)
        except Exception as e:
            self.logger.error(f"处理数据源变化失败 {e}")
    
    def _on_load_file_requested(self, file_path: str):
        """"""         try:
            self.logger.info(f"文件加载请求: {file_path}")
            # 发送信号到主控制器
            self.load_file_requested.emit(file_path)
        except Exception as e:
            self.logger.error(f"处理文件加载请求失败: {e}")
    
    def _on_data_sources_selected(self, sources: list):
        """"""         try:
            self.logger.info(f"数据源选择变化: {len(sources)} 个数据源")
            # 发送信号到主控制器
            self.data_sources_selected.emit(sources)
        except Exception as e:
            self.logger.error(f"处理数据源选择变化失败: {e}")
    
    def _on_source_added(self, source_id: int, source_type: str, config: dict):
        """"""         try:
            self.logger.info(f"数据源添加 ID={source_id}, 类型={source_type}")
            # 发送信号到主控制器
            self.source_added.emit(source_id, source_type, config)
        except Exception as e:
            self.logger.error(f"处理数据源添加失败 {e}")
    
    def _on_source_removed(self, source_id: int):
        """"""         try:
            self.logger.info(f"数据源移除 ID={source_id}")
            # 发送信号到主控制器
            self.source_removed.emit(source_id)
        except Exception as e:
            self.logger.error(f"处理数据源移除失败 {e}")
    
    def _on_active_source_changed(self, source_id: int):
        """"""         try:
            self.logger.info(f"活跃数据源变化 ID={source_id}")
            # 发送信号到主控制器
            self.active_source_changed.emit(source_id)
        except Exception as e:
            self.logger.error(f"处理活跃数据源变化失败 {e}")
    
    def add_multi_source_sync_section(self):
        """"""         
        # === 多源同步配置区域 ===
        sync_config_group = QGroupBox("🔄 多源同步配置")
        sync_config_group.setStyleSheet(get_sync_group_style("warning"))
        sync_config_layout = QFormLayout()
        sync_config_layout.setSpacing(8)
        
        # 时间同步精度设置
        self.sync_precision_combo = QComboBox()
        self.sync_precision_combo.addItems(["0.001ms", "0.01ms", "0.1ms", "1ms"])
        self.sync_precision_combo.setCurrentText("0.001ms")
        self.sync_precision_combo.setStyleSheet(get_sync_component_style("warning"))
        sync_config_layout.addRow("时间同步精度:", self.sync_precision_combo)
        
        # 融合算法选择
        self.fusion_algorithm_combo = QComboBox()
        self.fusion_algorithm_combo.addItems([
            "加权平均融合", "卡尔曼滤波融合", "神经网络融合", "集成融合"
        ])
        self.fusion_algorithm_combo.setCurrentText("卡尔曼滤波融合")
        self.fusion_algorithm_combo.setStyleSheet(get_sync_component_style("warning"))
        sync_config_layout.addRow("融合算法:", self.fusion_algorithm_combo)
        
        # 异常检测阈值
        self.anomaly_threshold_spin = QSpinBox()
        self.anomaly_threshold_spin.setRange(50, 95)
        # 动态设置阈值- 基于系统配置或默认å?
        default_threshold = self._get_dynamic_anomaly_threshold()
        self.anomaly_threshold_spin.setValue(default_threshold)
        self.anomaly_threshold_spin.setSuffix("%")
