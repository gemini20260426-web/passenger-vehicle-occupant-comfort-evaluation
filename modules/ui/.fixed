    def _create_real_time_parsing_panel(self):
        """"""         try:
            # 尝试导入实时解析数据显示组件
            if RealTimeParsingDisplay:
                real_time_panel = RealTimeParsingDisplay()
                self.logger.info("œ?实时解析数据显示面板创建成功")
                return real_time_panel
            else:
                # 如果导入失败,创建替代面?
                return self._create_real_time_parsing_placeholder()
        except Exception as e:
            self.logger.error(f"创建实时解析数据显示面板失败: {e}")
            # 创建替代面板
            return self._create_real_time_parsing_placeholder()

    def _create_real_time_parsing_placeholder(self):
        """"""         group = QGroupBox("📊 实时解析数据显示")
        group.setStyleSheet(get_groupbox_style("info", "default"))
        layout = QVBoxLayout()
        layout.setSpacing(10)
        
        # 标题
        title_label = QLabel("实时解析数据显示")
        title_label.setStyleSheet(get_label_style("info", "medium", "bold"))
        title_label.setAlignment(Qt.AlignCenter)
        layout.addWidget(title_label)
        
        # 状态指示器
        status_layout = QHBoxLayout()
        status_layout.addWidget(QLabel("解析状态"))
        
        self.parsing_status_indicator = QLabel("未启åŠ?)
        self.parsing_status_indicator.setStyleSheet(get_status_label_style("muted", "medium"))
        status_layout.addWidget(self.parsing_status_indicator)
        status_layout.addStretch()
        
        layout.addLayout(status_layout)
        
        # 数据统计
        stats_layout = QGridLayout()
        stats_layout.setSpacing(8)
        
        # 总数据点•?
        self.total_data_points_label = QLabel("0")
        self.total_data_points_label.setStyleSheet(get_count_label_style("success"))
        stats_layout.addWidget(QLabel("总数据点:"), 0, 0)
        stats_layout.addWidget(self.total_data_points_label, 0, 1)
        
        # 成功解析•?
        self.successful_parses_label = QLabel("0")
        self.successful_parses_label.setStyleSheet(get_count_label_style("primary"))
        stats_layout.addWidget(QLabel("成功解析:"), 1, 0)
        stats_layout.addWidget(self.successful_parses_label, 1, 1)
        
        # 失败解析•?
        self.failed_parses_label = QLabel("0")
        self.failed_parses_label.setStyleSheet(get_count_label_style("danger"))
        stats_layout.addWidget(QLabel("失败解析:"), 2, 0)
        stats_layout.addWidget(self.failed_parses_label, 2, 1)
        
        # 平均解析速度
        self.avg_speed_label = QLabel("0 数据点/秒)
        self.avg_speed_label.setStyleSheet(get_count_label_style("secondary"))
        stats_layout.addWidget(QLabel("平均速度:"), 3, 0)
        stats_layout.addWidget(self.avg_speed_label, 3, 1)
        
        layout.addLayout(stats_layout)
        
        # 实时数据显示区域
        data_display_group = QGroupBox("实时数据µ?)
        data_display_group.setStyleSheet(get_sync_component_style())
        data_display_layout = QVBoxLayout()
        
        # 数据表格
        self.parsing_data_table = QTableWidget()
        self.parsing_data_table.setColumnCount(4)
        self.parsing_data_table.setHorizontalHeaderLabels([
            "时间", "数据源, "数据类型", "解析状态
        ])
        self.parsing_data_table.setMaximumHeight(150)
        self.parsing_data_table.setStyleSheet(get_table_style())
        
        data_display_layout.addWidget(self.parsing_data_table)
        data_display_group.setLayout(data_display_layout)
        layout.addWidget(data_display_group)
        
        # 控制按钮
        control_layout = QHBoxLayout()
        
        self.start_parsing_btn = QPushButton("▶️ 开始监控)
        self.start_parsing_btn.setStyleSheet(get_button_style("success", "medium"))
        
        self.stop_parsing_btn = QPushButton("⏹️ 停止监控")
        self.stop_parsing_btn.setStyleSheet(get_button_style("danger", "medium"))
        
        self.clear_parsing_data_btn = QPushButton("🗑ï¸?清空数据")
        self.clear_parsing_data_btn.setStyleSheet(get_button_style("warning", "medium"))
        
        control_layout.addWidget(self.start_parsing_btn)
        control_layout.addWidget(self.stop_parsing_btn)
        control_layout.addWidget(self.clear_parsing_data_btn)
        control_layout.addStretch()
        
        layout.addLayout(control_layout)
        
        group.setLayout(layout)
        return group

    def _add_connection_status_item(self, source_name: str, status: str, color: str):
        """"""         try:
            item = QListWidgetItem(f"{source_name}: {status}")
            if color == "red":
                item.setForeground(QColor("#dc3545"))
            elif color == "green":
                item.setForeground(QColor("#28a745"))
            elif color == "yellow":
                item.setForeground(QColor("#ffc107"))
            else:
                item.setForeground(QColor("#6c757d"))
            self.connection_status_list.addItem(item)
        except Exception as e:
            print(f"添加连接状态项失败: {e}")

    def _refresh_real_connection_status(self):
        """"""         try:
            if not hasattr(self, 'connection_status_list'):
                return
            self.connection_status_list.clear()
            statuses = []
            # 从数据管道管理器获取模块健康/连接推断
            if hasattr(self, 'data_pipeline_manager'):
                try:
                    pipeline_status = self.data_pipeline_manager.get_data_pipeline_status()
                    if isinstance(pipeline_status, dict):
                        module_health = pipeline_status.get('module_health', {})
                        for module_name, health in module_health.items():
                            state = '已连Ž? if (isinstance(health, (int, float)) and health > 0) else '未连Ž?
                            color = 'green' if state == '已连 else 'red'
                            statuses.append((module_name, state, color))
                except Exception:
                    pass
            # 从右侧tab推断(兜底)
            if not statuses and hasattr(self, 'right_tab') and hasattr(self.right_tab, 'connection_status_label'):
                text = str(self.right_tab.connection_status_label.text()).lower()
                inferred_state = '已连Ž? if 'connected' in text else '未连Ž?
                statuses.append(("数据源, inferred_state, 'green' if inferred_state == '已连Ž? else 'red'))
            # 渲染
            for name, state, color in statuses:
                self._add_connection_status_item(name, state, color)
        except Exception:
            pass
class CoreUIMainWindow(QMainWindow):
    # 定义信号,用于与控制器通信
    data_source_connected = Signal(str)    # 数据源连接信å?
    analysis_requested = Signal(dict)      # 分析请求信号
    system_status_changed = Signal(str)    # 系统状态变化信å?
    data_updated = Signal(dict)           # 数据更新信号
    """"""     current_lang = 'en'  # 默认语言
    
    # 添加系统监控信号
    update_system_metrics = Signal(float, float, float)  # CPU, Memory, Disk
    
    def __init__(self):
        super().__init__()
        
        # 设置异常处理
        self.setup_exception_handling()
        
        # 初始化日志记录器
        try:
            from config.logging_setup import get_logger
            self.logger = get_logger(__name__)
        except ImportError:
            # 如果日志配置模块不可用,使用基本配置
            self.logger = logging.getLogger(__name__)
            if not self.logger.handlers:
                handler = logging.StreamHandler()
                formatter = logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - %(message)s')
                handler.setFormatter(formatter)
                self.logger.addHandler(handler)
                self.logger.setLevel(logging.INFO)
            self.logger.warning("日志配置模块不可用,使用基本日志配置")
        
        self.logger.info("开始初始化主窗å?)
        
        # 设置窗口属?
        self.setWindowTitle("Core System Dashboard")
        self.setGeometry(100, 100, 1920, 1200)  # 统一使用高分辨率
        self.setMinimumSize(1600, 900)  # 设置最小尺å¯?
        
        # 设置应用程序图标
        self.setWindowIcon(self.style().standardIcon(QStyle.SP_ComputerIcon))
        
        # 初始化多语言支持
        self.current_lang = 'en'
        self.init_translations()
        
        # 初始化设置管理器
        self.settings = QSettings("CoreSystem", "Dashboard")
        
        # 初始化数据管理器 - 已注释,使用真实核心系统
        # self.data_manager = DataManager()
        
        # 初始化分析器 - 已注释,使用真实核心系统
        # self.analyzer = BaseAnalyzer()
        # self.analyzer.set_data_manager(self.data_manager)
        
        # 初始化配置管理器
        try:
            # 使用正确的导入方å¼?
            from modules.ui.config_manager.configuration_manager import ConfigManager
            self.config_manager = ConfigManager()
            self.logger.info("配置管理器导入成åŠ?)
        except Exception as e:
            self.logger.warning(f"配置管理器导入失败 {e},使用默认配置?)
            self.config_manager = None
        
        # 延迟导入核心系统模块
        self._import_core_modules()
        
        # 初始化安全管理器
        try:
            from .security_manager import SecurityManager
            self.security_manager = SecurityManager()
        except ImportError:
            try:
                from modules.ui.security_manager import SecurityManager
                self.security_manager = SecurityManager()
            except ImportError:
                self.logger.warning("安全管理器导入失败,使用默认安全配置")
                self.security_manager = None
        
        # 初始化用户管理器
        try:
            from .user_manager import UserManager
            self.user_manager = UserManager()
        except ImportError:
            try:
                from modules.ui.user_manager import UserManager
                self.user_manager = UserManager()
            except ImportError:
                self.logger.warning("用户管理器导入失败,使用默认用户配置")
                self.user_manager = None
            
        # 初始化系统集成管理器
        try:
            from .system_integration import ExtensionIntegrationWidget
            self.integration_widget = ExtensionIntegrationWidget()
        except ImportError:
            try:
                from modules.ui.system_integration import ExtensionIntegrationWidget
                self.integration_widget = ExtensionIntegrationWidget()
            except ImportError:
                self.logger.warning("系统集成管理器导入失败,使用默认配置")
                self.integration_widget = None
        
        # 初始化数据源管理
        self.data_sources = {}
        self.active_source_id = None
        self.data_count = 0
        
        # 初始化行为统è®?
        self.behavior_stats = {}
        
        # 初始化UI组件
        self.init_ui()
        
        # 连接信号
        self.connect_signals()
        
        # 启动数据更新定时å™?
        self.data_timer = QTimer()
        self.data_timer.timeout.connect(self.update_data)
        self.data_timer.start(10000)  # ¯?0秒更新一¬?
        
        # 启动时间更新定时å™?
        self.time_timer = QTimer()
        self.time_timer.timeout.connect(self.update_time)
        self.time_timer.start(1000)  # 每秒更新一¬?
        
        # 启动数据更新健康监控定时å™?
        self.health_monitor_timer = QTimer()
        self.health_monitor_timer.timeout.connect(self._check_data_update_health)
        self.health_monitor_timer.start(30000)  # ¯?0秒检查一¬?
        
        # 数据更新健康状态
        self.last_data_update_time = time.time()
        self.data_update_failures = 0
        self.max_failures = 3  # 最大失败次•?
        
        # 停止监控广播 - 以Processing Progress进度为基å‡?
        self.monitoring_broadcast_enabled = False
        
        # 🚨 建立真实数据流管é?
        try:
            from modules.ui.data_pipeline_manager import DataPipelineManager
            self.data_pipeline_manager = DataPipelineManager(self)
            
            # 连接数据流管道信å?
            self.data_pipeline_manager.data_flow_status_changed.connect(self._on_data_flow_status_changed)
            self.data_pipeline_manager.data_pipeline_health_updated.connect(self._on_data_pipeline_health_updated)
            self.data_pipeline_manager.module_data_received.connect(self._on_module_data_received)
            
            self.logger.info("œ?数据流管道管理器已集ˆ?)
        except ImportError as e:
            self.logger.warning(f"⚠️ 无法导入数据流管道管理器: {e}")
            # 降级到简单数据流管道
            self.data_pipeline = {
                'sensor_data': None,      # 传感器数据
                'parsing_status': None,   # 解析状态
                'analysis_result': None,  # 分析结果
                'advanced_analysis_result': None,  # 高级分析结果
                'system_status': None,    # 系统状态
                'data_flow_status': 'initialized'  # 数据流状态
            }
            
            # 数据流健康监控
            self.data_pipeline_health = {
                'last_update': time.time(),
                'update_count': 0,
                'error_count': 0,
                'health_score': 100,
                'data_flow_health': 100,
                'module_health': {}
            }
        
        # 连接系统监控信号
        self.update_system_metrics.connect(self.update_system_metrics_ui)
        
        # 启动系统监控
        self.setup_system_monitoring()
        
        # 🚨 启动数据流管道监控(如果使用简单模式)
        if not hasattr(self, 'data_pipeline_manager'):
            self.setup_data_pipeline_monitoring()
        
        # 缩放功能已移至主控制器,不再需要在此初始化
        
        self.logger.info("主窗口初始化完成")
    
    # 🚨 数据流管道信号处理方³?
    def _on_data_flow_status_changed(self, status_data: dict):
        """"""         try:
            self.logger.debug(f"数据流状态变›? {status_data.get('overall_status', 'unknown')}")
            
            # 更新UI显示
            if hasattr(self, 'data_flow_status_label'):
                status = status_data.get('overall_status', 'unknown')
                if status == 'healthy':
                    self.data_flow_status_label.setText("数据流状态 🟢 健康")
                    self.data_flow_status_label.setStyleSheet("color: #28a745; font-weight: bold;")
                elif status == 'warning':
                    self.data_flow_status_label.setText("数据流状态 🟡 警告")
                    self.data_flow_status_label.setStyleSheet("color: #ffc107; font-weight: bold;")
                elif status == 'critical':
                    self.data_flow_status_label.setText("数据流状态 🔴 严重")
                    self.data_flow_status_label.setStyleSheet("color: #dc3545; font-weight: bold;")
                else:
                    self.data_flow_status_label.setText(f"数据流状态 {status}")
            
        except Exception as e:
            self.logger.error(f"处理数据流状态变更信号失败 {e}")
    
    def _on_data_pipeline_health_updated(self, health_data: dict):
        """"""         try:
            health_score = health_data.get('data_flow_health', 0)
            module_health = health_data.get('module_health', {})
            
            self.logger.debug(f"数据流健康状态更新 {health_score:.1f}%")
            
            # 更新健康状态显置¤?
            if hasattr(self, 'data_flow_health_label'):
                self.data_flow_health_label.setText(f"数据流健康度: {health_score:.1f}%")
                
                # 根据健康度设置颜è‰?
                if health_score > 80:
                    self.data_flow_health_label.setStyleSheet("color: #28a745; font-weight: bold;")
                elif health_score > 50:
                    self.data_flow_health_label.setStyleSheet("color: #ffc107; font-weight: bold;")
                else:
                    self.data_flow_health_label.setStyleSheet("color: #dc3545; font-weight: bold;")
            
            # 更新模块健康状态
            self._update_module_health_display(module_health)
            
        except Exception as e:
            self.logger.error(f"处理数据流管道健康状态更新信号失败 {e}")
    
    def _on_module_data_received(self, data_type: str, data: dict):
        """"""         try:
            self.logger.debug(f"模块数据接收: {data_type} -> {len(data)} 个字®?)
            
            # 根据数据类型更新相应显示
            if data_type == 'sensor_data':
                self._update_sensor_data_display(data)
            elif data_type == 'parsing_status':
                self._update_parsing_status_display(data)
            elif data_type == 'analysis_result':
                self._update_analysis_result_display(data)
            elif data_type == 'advanced_analysis_result':
                self._update_advanced_analysis_display(data)
            
        except Exception as e:
            self.logger.error(f"处理模块数据接收信号失败: {e}")
    
    def _update_module_health_display(self, module_health: dict):
        """"""         try:
            # 这里可以添加模块健康状态的详细显示逻辑
            for module_name, health_score in module_health.items():
                self.logger.debug(f"模块 {module_name} 健康度 {health_score}%")
                
        except Exception as e:
            self.logger.error(f"更新模块健康状态显示失败 {e}")
    
    def _update_sensor_data_display(self, sensor_data: dict):
        """"""         try:
            # 更新传感器数据相关的UI显示
            if hasattr(self, 'sensor_data_label'):
                timestamp = sensor_data.get('timestamp', 0)
                self.sensor_data_label.setText(f"传感器数据 {time.strftime('%H:%M:%S', time.localtime(timestamp))}")
                
        except Exception as e:
            self.logger.error(f"更新传感器数据显示失败 {e}")
    
    def _update_parsing_status_display(self, parsing_data: dict):
        """"""         try:
            # 更新解析状态相关的UI显示
            if hasattr(self, 'parsing_status_label'):
                timestamp = parsing_data.get('timestamp', 0)
                self.parsing_status_label.setText(f"解析状态 {time.strftime('%H:%M:%S', time.localtime(timestamp))}")
                
        except Exception as e:
            self.logger.error(f"更新解析状态显示失败 {e}")
    
    def _update_analysis_result_display(self, analysis_data: dict):
        """"""         try:
            # 更新分析结果相关的UI显示
            if hasattr(self, 'analysis_result_label'):
                timestamp = analysis_data.get('timestamp', 0)
                self.analysis_result_label.setText(f"分析结果: {time.strftime('%H:%M:%S', time.localtime(timestamp))}")
                
        except Exception as e:
            self.logger.error(f"更新分析结果显示失败: {e}")
    
    def _update_advanced_analysis_display(self, advanced_data: dict):
        """"""         try:
            # 更新高级分析相关的UI显示
            if hasattr(self, 'advanced_analysis_label'):
                timestamp = advanced_data.get('timestamp', 0)
                self.advanced_analysis_label.setText(f"高级分析: {time.strftime('%H:%M:%S', time.localtime(timestamp))}")
                
        except Exception as e:
            self.logger.error(f"更新高级分析显示失败: {e}")
    
    def update_data_pipeline(self, data_type: str, data: dict):
        """"""         try:
            if hasattr(self, 'data_pipeline_manager'):
                # 使用数据流管道管理器
                return self.data_pipeline_manager.update_data_pipeline(data_type, data)
            else:
                # 使用简单数据流管道
                return self._update_simple_data_pipeline(data_type, data)
                
        except Exception as e:
            self.logger.error(f"更新数据流管道失败 {e}")
            return False
    
    def _update_simple_data_pipeline(self, data_type: str, data: dict):
        """"""         try:
            if data_type in self.data_pipeline:
                # 添加时间ˆ?
                data_with_timestamp = {
                    **data,
                    'timestamp': time.time()
                }
                
                self.data_pipeline[data_type] = data_with_timestamp
                self.data_pipeline_health['update_count'] += 1
                
                self.logger.debug(f"œ?简单数据流管道已更新 {data_type}")
                return True
            else:
                self.logger.warning(f"⚠️ 未知的数据类å析 {data_type}")
                return False
                
        except Exception as e:
            self.logger.error(f"更新简单数据流管道失败: {e}")
            self.data_pipeline_health['error_count'] += 1
            return False
    
    def get_data_pipeline_status(self):
        """"""         try:
            if hasattr(self, 'data_pipeline_manager'):
                # 使用数据流管道管理器
                return self.data_pipeline_manager.get_data_pipeline_status()
            else:
                # 使用简单数据流管道
                return {
                    'pipeline_status': self.data_pipeline,
                    'health_status': self.data_pipeline_health,
                    'timestamp': time.time()
                }
        except Exception as e:
            self.logger.error(f"获取数据流管道状态失败 {e}")
            return {}
    
    def toggle_monitoring_broadcast(self, enable: bool = None):
        """"""         if enable is None:
            # 如果没有指定,则切换当前状态
            self.monitoring_broadcast_enabled = not self.monitoring_broadcast_enabled
        else:
            self.monitoring_broadcast_enabled = enable
        
        status = "启用" if self.monitoring_broadcast_enabled else "停止"
        self.logger.info(f"📡 监控广播已{status}")
        return self.monitoring_broadcast_enabled
    
    def _import_core_modules(self):
        """"""         try:
            # 使用相对路径导入,避免路径问é¢?
            import sys
            import os
            current_dir = os.path.dirname(os.path.abspath(__file__))
            project_root = os.path.dirname(os.path.dirname(current_dir))
            
            if project_root not in sys.path:
                sys.path.insert(0, str(project_root))
            
            from core.core.data_processing.multi_source_sync_manager import MultiSourceDataSyncManager
            from core.core.data_processing.data_parser import IMUDataParser
            from core.core.analysis.base_analyzer import BasicDrivingAnalyzer
            from core.core.analysis.advanced_analyzer import AdvancedBehaviorAnalyzer
            
            # 更新全局变量
            globals()['MultiSourceDataSyncManager'] = MultiSourceDataSyncManager
            globals()['IMUDataParser'] = IMUDataParser
            globals()['BasicDrivingAnalyzer'] = BasicDrivingAnalyzer
            globals()['AdvancedBehaviorAnalyzer'] = AdvancedBehaviorAnalyzer
            
            self.logger.info("œ?成功导入真实核心系统模块")
        except ImportError as e:
            self.logger.warning(f"⚠️ 导入真实核心系统模块失败: {e}")
            self.logger.info("💡 请确保core目录结构正确")
    
    def init_translations(self):
        """"""         try:
            # 这里可以添加多语言初始化逻辑
            # 目前使用默认的英–?
            pass
        except Exception as e:
            self.logger.warning(f"初始化多语言支持失败: {e}")
    
    def connect_signals(self):
        """"""         try:
            # 左侧面板信号连接
            if hasattr(self, 'left_panel'):
                # 数据源相关信å?
                self.left_panel.data_source_changed.connect(self.on_data_source_changed)
                self.left_panel.load_file_requested.connect(self.on_load_file)
                self.left_panel.data_sources_selected.connect(self.on_data_sources_selected)
                
                # 分析相关信号
                self.left_panel.analysis_toggled.connect(self.on_analysis_toggled)
                self.left_panel.record_toggled.connect(self.on_record_toggled)
                self.left_panel.export_data_requested.connect(self.on_export_data)
                
                # 多源管理信号
                self.left_panel.source_added.connect(self.on_source_added)
                self.left_panel.source_removed.connect(self.on_source_removed)
                self.left_panel.active_source_changed.connect(self.on_active_source_changed)
                
                            # 高级分析信号
            self.left_panel.advanced_analysis_started.connect(self.on_advanced_analysis_started)
            self.left_panel.advanced_analysis_stopped.connect(self.on_advanced_analysis_stopped)
            self.left_panel.advanced_analysis_paused.connect(self.on_advanced_analysis_paused)
            self.left_panel.model_load_requested.connect(self.on_model_load_requested)
            self.left_panel.model_unload_requested.connect(self.on_model_unload_requested)
            

                # 主题和设置信号(暂时注释掉,避免错误ï¼?
                # self.left_panel.theme_combo.currentIndexChanged.connect(
                #     lambda index: self.set_theme(self.left_panel.theme_combo.currentText()))
            
            # 右侧标签页信号连Ž?
            if hasattr(self, 'right_tab'):
                # 分析标签页按钮连Ž?
                if hasattr(self.right_tab, 'start_analysis_btn'):
                    self.right_tab.start_analysis_btn.clicked.connect(
                        lambda: self.left_panel.analysis_toggled.emit(True, "basic"))
                if hasattr(self.right_tab, 'stop_analysis_btn'):
                    self.right_tab.stop_analysis_btn.clicked.connect(
                        lambda: self.left_panel.analysis_toggled.emit(False, ""))
                
                # 添加右侧标签页数据更新连Ž?
                if hasattr(self.right_tab, 'monitoring_tab'):
                    # 连接数据更新信号到右侧标签页
                    self.data_updated.connect(self._update_right_tab_data)
                
                # 连接左侧面板数据广播信号到右侧监控模å?
                if hasattr(self.left_panel, 'parsing_status_broadcast'):
                    self.left_panel.parsing_status_broadcast.connect(self._update_monitoring_from_left_panel)
                if hasattr(self.left_panel, 'parsing_stats_broadcast'):
                    self.left_panel.parsing_stats_broadcast.connect(self._update_monitoring_from_left_panel)
                if hasattr(self.left_panel, 'error_monitor_broadcast'):
                    self.left_panel.error_monitor_broadcast.connect(self._update_monitoring_from_left_panel)
                if hasattr(self.left_panel, 'core_system_broadcast'):
                    self.left_panel.core_system_broadcast.connect(self._update_monitoring_from_left_panel)
            
            # 数据更新定时器信å?
            if hasattr(self, 'data_timer'):
                self.data_timer.timeout.connect(self.update_data)
            
            # 时间更新定时器信å?
            if hasattr(self, 'time_timer'):
                self.time_timer.timeout.connect(self.update_time)
            
            self.logger.info("所有信号连接完ˆ?)
            
        except Exception as e:
            self.logger.error(f"信号连接失败: {e}")
            # 显示错误提示
            QMessageBox.critical(
                self, 
                "系统初始化失败, 
                f"信号连接失败:\n{str(e)}\n\n请重启应用程序?
            )
    
    def init_ui(self):
        """"""         # 设置窗口基本属?
        self.setWindowTitle(translations['en']['app_title'])
        self.setGeometry(100, 100, 1400, 900)
        
        # 创建中心部件和主布局
