    def _export_system_logs(self):
        """"""         try:
            from PySide6.QtWidgets import QFileDialog
            from datetime import datetime
            
            # 获取保存文件路径
            file_path, _ = QFileDialog.getSaveFileName(
                self, 
                "导出系统日志", 
                f"system_logs_{datetime.now().strftime('%Y%m%d_%H%m%S')}.txt",
                "文本文件 (*.txt);;所有文组件(*)"
            )
            
            if file_path:
                # 获取日志内容
                log_content = self.log_viewer.toPlainText()
                
                # 写入文件
                with open(file_path, 'w', encoding='utf-8') as f:
                    f.write(log_content)
                
                # 显示成功消息
                from PySide6.QtWidgets import QMessageBox
                QMessageBox.information(self, "导出成功", f"系统日志已导出到:\n{file_path}")
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"导出系统日志失败: {e}")
            from PySide6.QtWidgets import QMessageBox
            QMessageBox.critical(self, "导出失败", f"导出系统日志失败:\n{str(e)}")
    
    def _update_fixed_display_with_real_data(self, data):
        """"""         try:
            from datetime import datetime
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 1. 更新解析后的数据标准è¡?
            if 'source_type' in data and data['source_type'] != '未选择':
                parsed_data = f"数据源 {data['source_type']} | 状态 {data.get('system_state', 'Unknown')} | 连接: {data.get('connection_status', 'Unknown')} | 时间: {current_time}"
            else:
                parsed_data = f"等待数据源连Ž?.. | 时间: {current_time}"
            self.update_fixed_display_area('parsed_data', parsed_data)
            
            # 2. 更新基础分析行为结果
            if 'data_rate' in data and data['data_rate'] > 0:
                basic_analysis = f"数据成功率 {data['data_rate']} Hz | 进度: {data.get('progress', 0)}% | 分析状态 {data.get('analysis_state', 'ready')} | 时间: {current_time}"
            else:
                basic_analysis = f"等待数据分析... | 时间: {current_time}"
            self.update_fixed_display_area('basic_analysis', basic_analysis)
            
            # 3. 更新高级分析行为结果
            if 'source_status' in data or 'performance_data' in data:
                # 基于真实数据的高级分析
                source_count = len(data.get('source_status', {}))
                perf_data = data.get('performance_data', {})
                cpu_usage = perf_data.get('cpu_percent', 0)
                memory_usage = perf_data.get('memory_percent', 0)
                
                advanced_analysis = f"活跃数据源 {source_count} | CPU: {cpu_usage}% | 内存: {memory_usage}% | 系统健康: 良好 | 时间: {current_time}"
            else:
                advanced_analysis = f"等待高级分析... | 时间: {current_time}"
            self.update_fixed_display_area('advanced_analysis', advanced_analysis)
            
            # 4. 更新状态指示器
            if data.get('connection_status') == 'Connected':
                status_indicator = f"œ?系统运行正常 | 数据质量: 优秀 | 同步状态 已同­?| 更新时间: {current_time}"
            elif data.get('connection_status') == 'Error':
                status_indicator = f"?系统错误 | 数据质量: å·?| 同步状态 失败 | 更新时间: {current_time}"
            else:
                status_indicator = f"?系统就绪 | 数据质量: 待定 | 同步状态 等待连接 | 更新时间: {current_time}"
            self.update_fixed_display_area('status_indicator', status_indicator)
            
            # 5. 更新离线数据集处理状态
            if 'source_status' in data and data['source_status']:
                # 检查是否有活跃的数据源
                active_sources = [s for s in data['source_status'].values() if s.get('is_active', False)]
                if active_sources:
                    # 获取第一个活跃数据源的信?
                    source = active_sources[0]
                    source_id = source.get('source_id', 'Unknown')
                    data_count = source.get('data_count', 0)
                    error_count = source.get('error_count', 0)
                    
                    if data_count > 0:
                        if error_count == 0:
                            offline_dataset_status = f"œ?数据集已加载 | 数据é‡? {data_count} | 状态 解析完成 | 时间: {current_time}"
                        else:
                            offline_dataset_status = f"⚠️ 数据集已加载 | 数据é‡? {data_count} | 错误: {error_count} | 状态 部分完成 | 时间: {current_time}"
                    else:
                        offline_dataset_status = f"?数据集加载中 | 状态 处理中| 时间: {current_time}"
                else:
                    offline_dataset_status = f"?等待数据集加è½?| 状态 就绪 | 时间: {current_time}"
            else:
                offline_dataset_status = f"?等待数据集加è½?| 状态 就绪 | 时间: {current_time}"
            
            self.update_fixed_display_area('offline_dataset', offline_dataset_status)
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"使用真实数据更新固定显示区失败 {e}")
    
    def _format_general_metrics(self, data):
        """"""         try:
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 检查是否是Core系统状态数据
            if isinstance(data, dict) and 'source_status' in data:
                return self._format_core_system_metrics(data)
            
            metrics_text = f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化通用数据失败: {e}")
            return f"通用数据格式化失败 {str(e)}"
    
    def _format_core_system_metrics(self, core_status):
        """"""         try:
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 获取数据源状态
            source_status = core_status.get('source_status', {})
            sync_status = core_status.get('sync_status', {})
            performance_data = core_status.get('performance_data', {})
            system_health = core_status.get('system_health', 50)
            
            # 计算活跃数据源数é‡?
            active_sources = sum(1 for status in source_status.values() if status.get('status') == 'running')
            
            metrics_text = f""""""             
            # 添加数据源状态
            for source_id, status in source_status.items():
                status_icon = "🟢" if status.get('status') == 'running' else "🔴" if status.get('status') == 'error' else "🟡"
                metrics_text += f""""""             
            # 添加同步状态
            if sync_status:
                sync_icon = "🟢" if sync_status.get('sync_status') == 'running' else "🔴" if sync_status.get('sync_status') == 'error' else "🟡"
                metrics_text += f""""""             
            # 添加性能数据
            if performance_data:
                metrics_text += f""""""                 if 'cpu_usage' in performance_data:
                    metrics_text += f""""""                 if 'memory_usage' in performance_data:
                    metrics_text += f""""""                 if 'disk_usage' in performance_data:
                    metrics_text += f""""""             
            metrics_text += f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化Core系统状态数据失败 {e}")
            return f"Core系统状态数据格式化失败: {str(e)}"

    def setup_system_monitoring(self):
        """"""         try:
            import psutil
            import threading
            import time
            
            def monitor_system():
                """"""                 while hasattr(self, 'data_timer') and self.data_timer.isActive():
                    try:
                        # CPU使用成功率
                        cpu_percent = psutil.cpu_percent(interval=1)
                        
                        # 内存使用成功率
                        memory = psutil.virtual_memory()
                        memory_percent = memory.percent
                        
                        # 磁盘使用成功率
                        disk = psutil.disk_usage('/')
                        disk_percent = disk.percent
                        
                        # 更新UI(需要在主线程中执行ï¼?
                        self.update_system_metrics.emit(cpu_percent, memory_percent, disk_percent)
                        
                        time.sleep(5)  # ¯?秒更新一¬?
                        
                    except Exception as e:
                        if hasattr(self, 'logger'):
                            self.logger.warning(f"系统监控更新失败: {e}")
                        time.sleep(10)  # 出错后等待更长时é—?
            
            # 启动监控线程
            monitor_thread = threading.Thread(target=monitor_system, daemon=True)
            monitor_thread.start()
            
            self.logger.info("系统监控已启åŠ?)
            
        except ImportError:
            self.logger.warning("psutil模块未安装,系统监控功能不可置"?)
        except Exception as e:
            self.logger.error(f"启动系统监控失败: {e}")

    def update_system_metrics_ui(self, cpu_percent, memory_percent, disk_percent):
        """"""         try:
            if hasattr(self, 'right_tab') and hasattr(self.right_tab, 'system_monitor_tab'):
                # 更新CPU使用成功率
                if hasattr(self.right_tab.system_monitor_tab, 'cpu_usage_value'):
                    self.right_tab.system_monitor_tab.cpu_usage_value.setText(f"{cpu_percent:.1f}%")
                
                # 更新内存使用成功率
                if hasattr(self.right_tab.system_monitor_tab, 'memory_usage_value'):
                    self.right_tab.system_monitor_tab.memory_usage_value.setText(f"{memory_percent:.1f}%")
                
                # 更新磁盘使用成功率
                if hasattr(self.right_tab.system_monitor_tab, 'disk_usage_value'):
                    self.right_tab.system_monitor_tab.disk_usage_value.setText(f"{disk_percent:.1f}%")
                
                # 更新系统健康度评åˆ?
                health_score = self._calculate_health_score(cpu_percent, memory_percent, disk_percent)
                if hasattr(self.right_tab.system_monitor_tab, 'health_score_value'):
                    self.right_tab.system_monitor_tab.health_score_value.setText(str(health_score))
                    self.right_tab.system_monitor_tab.health_score_progress.setValue(health_score)
                    
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"更新系统指标UI失败: {e}")
    
    def _calculate_health_score(self, cpu_percent, memory_percent, disk_percent):
        """"""         try:
            # 基础系统资源评分
            cpu_score = max(0, 100 - cpu_percent)
            memory_score = max(0, 100 - memory_percent)
            disk_score = max(0, 100 - disk_percent)
            
            # 数据质量评分
            data_quality_score = self._calculate_data_quality_score()
            
            # 连接状态评åˆ?
            connection_score = self._calculate_connection_score()
            
            # 分析性能评分
            analysis_score = self._calculate_analysis_performance_score()
            
            # 加权平均计算最终健康度
            health_score = (
                cpu_score * 0.25 +           # CPU权重25%
                memory_score * 0.25 +        # 内存权重25%
                disk_score * 0.15 +          # 磁盘权重15%
                data_quality_score * 0.20 +  # 数据质量权重20%
                connection_score * 0.10 +    # 连接状态权é‡?0%
                analysis_score * 0.05        # 分析性能权重5%
            )
            
            return int(max(0, min(100, health_score)))
            
        except Exception as e:
            self.logger.error(f"计算系统健康度评分失败 {e}")
            return 50  # 返回默认中等评分
    
    def _calculate_data_quality_score(self):
        """"""         try:
            # if not hasattr(self, 'data_manager') or not self.data_manager:
            #     return 50
            
            # 获取数据统计信息
            data_points = 0
            data_integrity = 0.0
            
            # if hasattr(self.data_manager, 'data'):
            #     imu_points = len(self.data_manager.data.get('imu', {}).get('timestamps', []))
            #     cnap_points = len(self.data_manager.data.get('cnap', {}).get('timestamps', []))
            #     data_points = imu_points + cnap_points
            
            # if hasattr(self.data_manager, 'data_integrity'):
            #     data_integrity = self.data_manager.data_integrity
            
            # 根据数据点数量和质量计算评分
            if data_points > 1000 and data_integrity > 0.9:
                return 100
            elif data_points > 500 and data_integrity > 0.8:
                return 85
            elif data_points > 100 and data_integrity > 0.7:
                return 70
            elif data_points > 50 and data_integrity > 0.6:
                return 55
            else:
                return 40
                
        except Exception as e:
            self.logger.error(f"计算数据质量评分失败: {e}")
            return 50
    
    def _calculate_connection_score(self):
        """"""         try:
            # if not hasattr(self, 'data_manager') or not self.data_manager:
            #     return 50
            
            # 检查主数据源连接状态
            # main_connected = getattr(self.data_manager, 'is_connected', False)
            
            # 检查多源数据连接状态
            multi_source_connected = False
            if hasattr(self, 'data_sources'):
                connected_sources = sum(1 for source_info in self.data_sources.values() 
                                      if source_info.get("is_connected", False))
                multi_source_connected = connected_sources > 0
            
            # 根据连接状态计算评åˆ?
            # if main_connected and multi_source_connected:
            #     return 100
            # elif main_connected or multi_source_connected:
            #     return 75
            # else:
            #     return 25
            
            # 临时返回默认值,因为data_manager已被注释
            return 50
                
        except Exception as e:
            self.logger.error(f"计算连接状态评分失败 {e}")
            return 50
    
    def _calculate_analysis_performance_score(self):
        """"""         try:
            if not hasattr(self, 'analyzer') or not self.analyzer:
                return 50
            
            # 检查分析器状态
            analyzer_running = getattr(self.analyzer, 'is_running', False)
            
            # 检查分析结果质é‡?
            analysis_results_count = 0
            if hasattr(self.analyzer, 'analysis_results_history'):
                analysis_results_count = len(self.analyzer.analysis_results_history)
            
            # 根据分析状态和结果数量计算评分
            if analyzer_running and analysis_results_count > 100:
                return 100
            elif analyzer_running and analysis_results_count > 50:
                return 85
            elif analyzer_running and analysis_results_count > 10:
                return 70
            elif analyzer_running:
                return 60
            else:
                return 40
                
        except Exception as e:
            self.logger.error(f"计算分析性能评分失败: {e}")
            return 50

