        # self.right_tab.imu_vis_tab.set_data_manager(self.data_manager)
        # self.right_tab.cnap_vis_tab.set_data_manager(self.data_manager)
        splitter.addWidget(self.right_tab)
        

        
        # 设置初始大小比例
        splitter.setSizes([300, 900])
        main_layout.addWidget(splitter)
        

        
        # 添加底部状态栏
        self.bottom_status = BottomStatusBar()
        self.setStatusBar(self.bottom_status)
        
        # 应用保存的主题(暂时注释掉,避免错误ï¼?
        # self.apply_theme(self.left_panel.theme_combo.currentText())
        
        # 创建菜单栏(在UI组件创建之后ï¼?
        self.create_menu_bar()
    
    def add_multi_source_sync_to_left_panel(self):
        """"""         try:
            # 检查左侧面板是否有主布局
            if hasattr(self.left_panel, 'main_layout'):
                main_layout = self.left_panel.main_layout
            else:
                # 如果没有主布局,创建一中
                main_layout = QVBoxLayout()
                self.left_panel.setLayout(main_layout)
            
            # === 多源同步配置区域 ===
            sync_config_group = QGroupBox("🔄 多源同步配置")
            sync_config_group.setStyleSheet(get_sync_group_style("warning"))
            sync_config_layout = QFormLayout()
            sync_config_layout.setSpacing(10)
            
            # 时间同步精度设置
            self.sync_precision_combo = QComboBox()
            self.sync_precision_combo.addItems(["0.001ms", "0.01ms", "0.1ms", "1ms"])
            self.sync_precision_combo.setCurrentText("0.001ms")
            self.sync_precision_combo.setStyleSheet(get_sync_component_style("warning"))
            sync_config_layout.addRow("时间同步精度:", self.sync_precision_combo)
            
            # 融合算法选择
            self.fusion_algorithm_combo = QComboBox()
            self.fusion_algorithm_combo.addItems([
                "加权平均融合", "卡尔曼滤波融合", "神经网络融合", "集成融合"
            ])
            self.fusion_algorithm_combo.setCurrentText("卡尔曼滤波融合")
            self.fusion_algorithm_combo.setStyleSheet(get_sync_component_style("warning"))
            sync_config_layout.addRow("融合算法:", self.fusion_algorithm_combo)
            
            # 异常检测阈值
            self.anomaly_threshold_spin = QSpinBox()
            self.anomaly_threshold_spin.setRange(50, 95)
            self.anomaly_threshold_spin.setValue(80)
            self.anomaly_threshold_spin.setSuffix("%")
            self.anomaly_threshold_spin.setStyleSheet(get_sync_component_style("warning"))
            sync_config_layout.addRow("异常检测阈值", self.anomaly_threshold_spin)
            
            # 设置同步配置组布局
            sync_config_group.setLayout(sync_config_layout)
            
            # === 同步状态监控区åŸ?===
            sync_monitor_group = QGroupBox("📊 同步状态监控")
            sync_monitor_group.setStyleSheet(get_sync_group_style("warning"))
            sync_monitor_layout = QGridLayout()
            sync_monitor_layout.setSpacing(10)
            
            # 同步状态指示器
            self.sync_status_label = QLabel("未同­?)
            self.sync_status_label.setStyleSheet(get_status_indicator_style("danger"))
            sync_monitor_layout.addWidget(QLabel("同步状态"), 0, 0)
            sync_monitor_layout.addWidget(self.sync_status_label, 0, 1)
            
            # 时间同步精度
            self.time_sync_precision_label = QLabel("--")
            self.time_sync_precision_label.setStyleSheet(get_label_style("muted", "normal"))
            sync_monitor_layout.addWidget(QLabel("时间同步精度:"), 1, 0)
            sync_monitor_layout.addWidget(self.time_sync_precision_label, 1, 1)
            
            # 数据融合质量
            self.fusion_quality_label = QLabel("--")
            self.fusion_quality_label.setStyleSheet(get_label_style("muted", "normal"))
            sync_monitor_layout.addWidget(QLabel("融合质量:"), 2, 0)
            sync_monitor_layout.addWidget(self.fusion_quality_label, 2, 1)
            
            # 异常检测状态
            self.anomaly_status_label = QLabel("正常")
            self.anomaly_status_label.setStyleSheet(get_status_indicator_style("success"))
            sync_monitor_layout.addWidget(QLabel("异常检µ?"), 3, 0)
            sync_monitor_layout.addWidget(self.anomaly_status_label, 3, 1)
            
            # 设置同步监控组布局
            sync_monitor_group.setLayout(sync_monitor_layout)
            
            # === 快速同步操作区åŸ?===
            quick_sync_group = QGroupBox("快速同步操作")
            quick_sync_group.setStyleSheet(get_sync_group_style("warning"))
            quick_sync_layout = QVBoxLayout()
            quick_sync_layout.setSpacing(10)
            
            # 一键同步按é'?
            self.one_click_sync_btn = QPushButton("🚀 一键启动多源同步")
            self.one_click_sync_btn.setStyleSheet(get_sync_button_style("primary"))
            self.one_click_sync_btn.clicked.connect(self._on_one_click_sync)
            quick_sync_layout.addWidget(self.one_click_sync_btn)
            
            # 同步控制按钮统?
            sync_control_layout = QHBoxLayout()
            sync_control_layout.setSpacing(10)
            
            # 开始同步按é'?
            self.start_sync_btn = QPushButton("▶️ 开始同步")
            self.start_sync_btn.setStyleSheet(get_sync_button_style("success"))
            self.start_sync_btn.clicked.connect(self._on_start_sync)
            sync_control_layout.addWidget(self.start_sync_btn)
            
            # 停止同步按钮
            self.stop_sync_btn = QPushButton("⏹️ 停止同步")
            self.stop_sync_btn.setStyleSheet(get_sync_button_style("danger"))
            self.stop_sync_btn.clicked.connect(self._on_stop_sync)
            self.stop_sync_btn.setEnabled(False)
            sync_control_layout.addWidget(self.stop_sync_btn)
            
            # 暂停同步按钮
            self.pause_sync_btn = QPushButton("⏸️ 暂停同步")
            self.pause_sync_btn.setStyleSheet(get_sync_button_style("warning"))
            self.pause_sync_btn.clicked.connect(self._on_pause_sync)
            self.pause_sync_btn.setEnabled(False)
            sync_control_layout.addWidget(self.pause_sync_btn)
            
            quick_sync_layout.addLayout(sync_control_layout)
            
            # 设置快速同步组布局
            quick_sync_group.setLayout(quick_sync_layout)
            
            # === 添加到左侧面板布局 ===
            main_layout.addWidget(sync_config_group)
            main_layout.addWidget(sync_monitor_group)
            main_layout.addWidget(quick_sync_group)
            
            # 连接信号
            self.sync_precision_combo.currentTextChanged.connect(self._on_sync_config_changed)
            self.fusion_algorithm_combo.currentTextChanged.connect(self._on_fusion_algorithm_changed)
            self.anomaly_threshold_spin.valueChanged.connect(self._on_sync_config_changed)
            
            # 记录组件引用
            self.sync_components = {
                'sync_config_group': sync_config_group,
                'sync_monitor_group': sync_monitor_group,
                'quick_sync_group': quick_sync_group,
                'sync_precision_combo': self.sync_precision_combo,
                'fusion_algorithm_combo': self.fusion_algorithm_combo,
                'anomaly_threshold_spin': self.anomaly_threshold_spin,
                'sync_status_label': self.sync_status_label,
                'time_sync_precision_label': self.time_sync_precision_label,
                'fusion_quality_label': self.fusion_quality_label,
                'anomaly_status_label': self.anomaly_status_label,
                'one_click_sync_btn': self.one_click_sync_btn,
                'start_sync_btn': self.start_sync_btn,
                'stop_sync_btn': self.stop_sync_btn,
                'pause_sync_btn': self.pause_sync_btn
            }
            
            print("œ?多源同步功能已成功添加到左侧面板")
            
        except Exception as e:
            print(f"?添加多源同步功能失败: {e}")
            import traceback
            traceback.print_exc()
    # 同步指标更新方法已移动到新的左侧控制面板中
    
    def create_menu_bar(self):
        """"""         menubar = self.menuBar()
        
        # 文件菜单
        file_menu = menubar.addMenu(translations[self.current_lang]['file'])
        
        # 新建
        new_action = QAction("📄 " + translations[self.current_lang]['new_session'], self)
        new_action.setShortcut("Ctrl+N")
        new_action.triggered.connect(self.on_new_session)
        file_menu.addAction(new_action)
        
        # 打开
        open_action = QAction("📂 " + translations[self.current_lang]['open_data_file'], self)
        open_action.setShortcut("Ctrl+O")
        open_action.triggered.connect(self.on_open_file)
        file_menu.addAction(open_action)
        
        # 保存
        save_action = QAction("💾 " + translations[self.current_lang]['save_current_data'], self)
        save_action.setShortcut("Ctrl+S")
        save_action.triggered.connect(self.on_save_data)
        file_menu.addAction(save_action)
        
        file_menu.addSeparator()
        
        # 配置管理
        config_action = QAction("⚙️ " + translations[self.current_lang]['configuration'], self)
        config_action.setShortcut("Ctrl+Shift+C")
        config_action.triggered.connect(self.show_configuration_dialog)
        file_menu.addAction(config_action)
        
        # 安全管理
        security_action = QAction("🔒 " + translations[self.current_lang]['system_settings'], self)
        security_action.setShortcut("Ctrl+Shift+S")
        security_action.triggered.connect(self.show_security_dialog)
        file_menu.addAction(security_action)
        
        # 用户管理
        user_action = QAction("👥 " + translations[self.current_lang]['source_management'], self)
        user_action.setShortcut("Ctrl+Shift+U")
        user_action.triggered.connect(self.show_user_dialog)
        file_menu.addAction(user_action)
        
        # 系统集成
        integration_action = QAction("🔗 " + translations[self.current_lang]['data_source_config'], self)
        integration_action.setShortcut("Ctrl+Shift+I")
        integration_action.triggered.connect(self.show_integration_dialog)
        file_menu.addAction(integration_action)
        
        file_menu.addSeparator()
        
        # 退å‡?
        exit_action = QAction("🚪 " + translations[self.current_lang]['exit'], self)
        exit_action.setShortcut("Ctrl+Q")
        exit_action.triggered.connect(self.close)
        file_menu.addAction(exit_action)
        
        # 视图菜单
        view_menu = menubar.addMenu("🎨 " + translations[self.current_lang]['view'])
        
        # 主题子菜å?
        theme_menu = view_menu.addMenu("🎨 " + translations[self.current_lang]['theme'])
        
        # 主题动作统?
        theme_group = QActionGroup(self)
        theme_group.setExclusive(True)
        
        light_action = QAction("☀ï¸?" + translations[self.current_lang]['light'], self, checkable=True)
        dark_action = QAction("🌙 " + translations[self.current_lang]['dark'], self, checkable=True)
        
        # 暂时注释掉,避免错误
        # if self.left_panel.theme_combo.currentText() == "Light":
        #     light_action.setChecked(True)
        # else:
        #     light_action.setChecked(True)
        light_action.setChecked(True)  # 默认选择亮色主题
            
        light_action.triggered.connect(lambda: self.set_theme("Light"))
        dark_action.triggered.connect(lambda: self.set_theme("Dark"))
        
        theme_group.addAction(light_action)
        theme_group.addAction(dark_action)
        theme_menu.addAction(light_action)
        theme_menu.addAction(dark_action)
        
        # 语言子菜å?
        lang_menu = view_menu.addMenu("🌐 " + translations[self.current_lang]['language'])
        
        # 语言动作统?
        lang_group = QActionGroup(self)
        lang_group.setExclusive(True)
        
        en_action = QAction("🇺🇸 " + translations[self.current_lang]['english'], self, checkable=True)
        zh_action = QAction("🇨🇳 " + translations[self.current_lang]['chinese'], self, checkable=True)
        
        en_action.setChecked(True)  # 默认英文
        
        en_action.triggered.connect(lambda: self.set_language('en'))
        zh_action.triggered.connect(lambda: self.set_language('zh'))
        
        lang_group.addAction(en_action)
        lang_group.addAction(zh_action)
        lang_menu.addAction(en_action)
        lang_menu.addAction(zh_action)
        
        # 帮助菜单
        help_menu = menubar.addMenu("" + translations[self.current_lang]['help'])
        
        # 关于
        about_action = QAction("ℹ️ " + translations[self.current_lang]['about'], self)
        about_action.triggered.connect(self.show_about_dialog)
        help_menu.addAction(about_action)
        
        # 帮助
        help_action = QAction("📖 " + translations[self.current_lang]['help'], self)
        help_action.triggered.connect(self.show_help_dialog)
        help_menu.addAction(help_action)
    
    def setup_exception_handling(self):
        """"""         import sys
        from PySide6.QtWidgets import QMessageBox
        
        def exception_hook(exctype, value, traceback):
            """"""             error_msg = f"未处理的异常:\n类型: {exctype.__name__}\nå? {value}"
            
            # 记录到日å¿?
            if hasattr(self, 'logger'):
                self.logger.error(error_msg)
                self.logger.error(f"Traceback: {traceback}")
            
            # 显示用户友好的错误对话框
            QMessageBox.critical(
                self, 
                "系统错误", 
                f"{error_msg}\n\n请检查系统日志获取详细信息,或联系技术支持?
            )
        
        # 设置全局异常钩子
        sys.excepthook = exception_hook
    
    def set_theme(self, theme_name: str):
        """"""         try:
            if theme_name == "Light":
                # 浅色主题
                self.setStyleSheet(get_light_theme_style())
            elif theme_name == "Dark":
                # 深色主题
                self.setStyleSheet(get_dark_theme_style())
            
            # 更新左侧面板主题
            if hasattr(self, 'left_panel'):
                # 暂时注释掉,避免错误
                # self.left_panel.theme_combo.setCurrentText(theme_name)
                pass  # 添加pass语句作为占位置¬?
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"设置主题失败: {e}")
    
    def set_language(self, lang: str):
        """"""         try:
            if lang in ['en', 'zh']:
                CoreUIMainWindow.current_lang = lang
                # 这里可以添加语言切换逻辑
                if hasattr(self, 'logger'):
                    self.logger.info(f"语言已切换到: {lang}")
        except Exception as e:
