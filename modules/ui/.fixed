        self.alarm_level_combo.addItems(["全部", "ä½?, "中, "é«?, "置´§?])
        alarm_filter_layout.addWidget(self.alarm_level_combo)
        alarm_filter_layout.addStretch()
        
        # 告警列表
        self.alarm_list = QListWidget()
        # 初始化时显示系统状态,不显示虚假告è­?
        self.alarm_list.addItem("📊 告警系统已初始化,等待真实告è­?..")
        
        # 连接告警级别选择信号
        self.alarm_level_combo.currentTextChanged.connect(self._filter_alarms_by_level)
        
        alarm_layout.addLayout(alarm_filter_layout)
        alarm_layout.addWidget(self.alarm_list)
        alarm_group.setLayout(alarm_layout)
        layout.addWidget(alarm_group)
        
        # === 系统日志 ===
        log_group = QGroupBox("📝 系统日志")
        log_layout = QVBoxLayout()
        
        # 日志过滤å™?
        log_filter_layout = QHBoxLayout()
        log_filter_layout.addWidget(QLabel("日志级别:"))
        self.log_filter_combo = QComboBox()
        self.log_filter_combo.addItems(["全部", "错误", "警告", "信息", "调试"])
        log_filter_layout.addWidget(self.log_filter_combo)
        
        # 日志操作按钮
        self.refresh_logs_btn = QPushButton("🔄 刷新")
        self.clear_logs_btn = QPushButton("🗑ï¸?清理")
        self.export_logs_btn = QPushButton("📤 导出")
        
        log_filter_layout.addWidget(self.refresh_logs_btn)
        log_filter_layout.addWidget(self.clear_logs_btn)
        log_filter_layout.addWidget(self.export_logs_btn)
        log_filter_layout.addStretch()
        
        # 日志查看å™?
        self.log_viewer = QTextEdit()
        self.log_viewer.setReadOnly(True)
        # 初始化时显示系统状态,不显示虚假日å¿?
        self.log_viewer.append("📝 系统日志已初始化,等待真实日å¿?..")
        
        # 连接日志操作按钮信号
        self.refresh_logs_btn.clicked.connect(self._refresh_real_system_logs)
        self.clear_logs_btn.clicked.connect(self._clear_log_viewer)
        self.export_logs_btn.clicked.connect(self._export_system_logs)
        
        log_layout.addLayout(log_filter_layout)
        log_layout.addWidget(self.log_viewer)
        log_group.setLayout(log_layout)
        layout.addWidget(log_group)
        
        # 填充空间
        layout.addStretch()
        
