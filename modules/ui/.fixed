    def update_data(self):
        """"""         try:
            # 从左侧面板获取真实数据
            data = {}
            
            # 1. 获取解析状态监测面板的真实数据
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    # 计算总体数据率(所有数据源的速度总和ï¼?
                    total_speed = sum(status.get('speed', 0) for status in monitor.parsing_status.values())
                    data['data_rate'] = total_speed
                    
                    # 计算总体进度(所有数据源进度的平均值)
                    total_progress = sum(status.get('progress', 0) for status in monitor.parsing_status.values())
                    avg_progress = total_progress // len(monitor.parsing_status) if monitor.parsing_status else 0
                    data['progress'] = avg_progress
                    
                    # 获取连接状态(基于是否有活跃的数据源)
                    active_sources = [s for s in monitor.parsing_status.values() if s.get('status') == 'running']
                    data['connection_status'] = 'Connected' if active_sources else 'Disconnected'
                    
                    # 获取数据源类å析
                    source_types = list(monitor.parsing_status.keys())
                    if source_types:
                        data['source_type'] = ', '.join(source_types)
                    else:
                        data['source_type'] = '未选择'
                    
                    # 获取系统状态
                    if any(s.get('status') == 'running' for s in monitor.parsing_status.values()):
                        data['system_state'] = 'Running'
                    elif any(s.get('status') == 'completed' for s in monitor.parsing_status.values()):
                        data['system_state'] = 'Completed'
                    else:
                        data['system_state'] = 'Ready'
                    
                    # 获取分析状态
                    if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'analysis_control_panel'):
                        analysis_panel = self.left_panel.analysis_control_panel
                        if hasattr(analysis_panel, 'is_analyzing') and analysis_panel.is_analyzing:
                            data['analysis_state'] = 'running'
                        else:
                            data['analysis_state'] = 'ready'
                    else:
                        data['analysis_state'] = 'ready'
                    
                    # 格式化真实数据为Key Metrics显示
                    data['metrics'] = self._format_real_time_metrics(monitor.parsing_status)
            
            # 2. 获取Core系统桥接器的真实数据
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'data_source_panel'):
                data_source_panel = self.left_panel.data_source_panel
                if hasattr(data_source_panel, 'core_bridge'):
                    core_bridge = data_source_panel.core_bridge
                    if hasattr(core_bridge, 'multi_source_manager') and core_bridge.multi_source_manager:
                        # 获取真实的多源管理数据
                        source_status = core_bridge.multi_source_manager.get_source_status() if hasattr(core_bridge.multi_source_manager, 'get_source_status') else {}
                        data['source_status'] = source_status
                        
                        # 获取性能监控数据
                        if hasattr(core_bridge, 'performance_monitor') and core_bridge.performance_monitor:
                            perf_data = core_bridge.performance_monitor.get_current_metrics() if hasattr(core_bridge.performance_monitor, 'get_current_metrics') else {}
                            data['performance_data'] = perf_data
            
            # 3. 如果没有获取到真实数据,使用默认å?
            if not data:
                data = {
                    'data_rate': 0,
                    'progress': 0,
                    'connection_status': 'Disconnected',
                    'source_type': '未选择',
                    'system_state': 'Ready',
                    'analysis_state': 'ready',
                    'metrics': '等待数据源连Ž?..'
                }
            
            # 发送真实数据更新信å?
            if hasattr(self, 'data_updated'):
                self.data_updated.emit(data)
                if hasattr(self, 'logger'):
                    self.logger.info(f"📊 发送真实数据更新信å? {data}")
            
            # 更新固定显示区(与监控广播隔离)
            self._update_fixed_display_with_real_data(data)
            
            # 实时更新状态标置­?
            self._update_real_time_status_labels()
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"获取真实数据失败: {e}")
            # 发生错误时发送默认数据
            default_data = {
                'data_rate': 0,
                'progress': 0,
                'connection_status': 'Error',
                'source_type': 'Error',
                'system_state': 'Error',
                'analysis_state': 'error',
                'metrics': f'数据获取失败: {str(e)}'
            }
            if hasattr(self, 'data_updated'):
                self.data_updated.emit(default_data)
            
            # 记录更新失败
            self.data_update_failures += 1
        else:
            # 更新成功,重置失败计数和时间
            self.last_data_update_time = time.time()
            self.data_update_failures = 0
    
    def update_time(self):
        """"""         try:
            current_time = QDateTime.currentDateTime().toString("yyyy-MM-dd HH:mm:ss")
            if hasattr(self, 'top_status') and hasattr(self.top_status, 'time_label'):
                self.top_status.time_label.setText(current_time)
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"时间更新失败: {e}")
    
    def _check_data_update_health(self):
        """"""         try:
            import time
            current_time = time.time()
            
            # 检查数据更新定时器是否活跃
            if not hasattr(self, 'data_timer') or not self.data_timer.isActive():
                self.logger.warning("⚠️ 数据更新定时器已停止,正在重å?..")
                self._restart_data_update_timer()
                return
            
            # 检查数据更新是否超—?
            time_since_last_update = current_time - self.last_data_update_time
            if time_since_last_update > 20:  # 20秒没有更新
                self.logger.warning(f"⚠️ 数据更新超时 ({time_since_last_update:.1f}置§?,正在检Ÿ?..")
                self._diagnose_data_update_issue()
                return
            
            # 检查失败次数是否过å¤?
            if self.data_update_failures >= self.max_failures:
                self.logger.error(f"🚨 数据更新失败次数过多 ({self.data_update_failures}),正在重启系统?..")
                self._restart_data_update_system()
                return
            
            # 健康状态正å¸?
            if hasattr(self, 'logger'):
                self.logger.info(f"œ?数据更新健康检查通过 - 最后更新 {time_since_last_update:.1f}秒前, 失败次数: {self.data_update_failures}")
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"数据更新健康检查失败 {e}")
    
    def _restart_data_update_timer(self):
        """"""         try:
            if hasattr(self, 'data_timer'):
                self.data_timer.stop()
                self.data_timer.start(10000)  # 重新启动ï¼?0秒间éš?
                self.logger.info("œ?数据更新定时器已重启")
                
                # 立即执行一次数据更新
                self.update_data()
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"重启数据更新定时器失败 {e}")
    
    def _diagnose_data_update_issue(self):
        """"""         try:
            self.logger.info("🔍 开始诊断数据更新问é¢?..")
            
            # 检查左侧面板状态
            if hasattr(self, 'left_panel'):
                self.logger.info("œ?左侧面板存在")
                
                # 检查解析状态监测面?
                if hasattr(self.left_panel, 'parsing_status_monitor'):
                    monitor = self.left_panel.parsing_status_monitor
                    if hasattr(monitor, 'parsing_status'):
                        status_count = len(monitor.parsing_status)
                        self.logger.info(f"📊 解析状态监测面? {status_count} 个数据源")
                    else:
                        self.logger.warning("⚠️ 解析状态监测面板缺少parsing_status")
                else:
                    self.logger.warning("⚠️ 左侧面板缺少parsing_status_monitor")
                
                # 检查数据源面板
                if hasattr(self.left_panel, 'data_source_panel'):
                    self.logger.info("œ?数据源面板存åœ?)
                else:
                    self.logger.warning("⚠️ 左侧面板缺少data_source_panel")
            else:
                self.logger.error("?左侧面板不存åœ?)
            
            # 检查右侧标签页
            if hasattr(self, 'right_tab'):
                self.logger.info("œ?右侧标签页存åœ?)
                
                # 检查关键组组件
                key_components = ['data_rate_label', 'connection_label', 'source_type_label', 'metrics_display']
                for component in key_components:
                    if hasattr(self.right_tab, component):
                        self.logger.info(f"œ?{component} 存在")
                    else:
                        self.logger.warning(f"⚠️ {component} 不存åœ?)
            else:
                self.logger.error("?右侧标签页不存在")
            
            # 尝试手动触发数据更新
            self.logger.info("🔧 尝试手动触发数据更新...")
            self.update_data()
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"诊断数据更新问题失败: {e}")
    
    def _restart_data_update_system(self):
        """"""         try:
            self.logger.info("🔄 开始重启数据更新系统?..")
            
            # 停止所有定时器
            if hasattr(self, 'data_timer'):
                self.data_timer.stop()
            if hasattr(self, 'health_monitor_timer'):
                self.health_monitor_timer.stop()
            
            # 重置健康状态
            self.last_data_update_time = time.time()
            self.data_update_failures = 0
            
            # 重新启动定时å™?
            if hasattr(self, 'data_timer'):
                self.data_timer.start(10000)
            if hasattr(self, 'health_monitor_timer'):
                self.health_monitor_timer.start(30000)
            
            # 立即执行一次数据更新
            self.update_data()
            
            self.logger.info("œ?数据更新系统已重å?)
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"重启数据更新系统失败: {e}")
    
