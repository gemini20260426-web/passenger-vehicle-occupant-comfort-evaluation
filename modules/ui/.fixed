    def on_advanced_analysis_start_analysis(self):
        """"""         try:
            # 检查模型是否已训练
            model_status = self.advanced_analysis_control.model_status_label.text()
            if "未训统? in model_status or "错误" in model_status:
                QMessageBox.warning(
