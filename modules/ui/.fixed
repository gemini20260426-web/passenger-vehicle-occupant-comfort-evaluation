            )
            
            # 更新高级分析状态
            self.advanced_analysis_control.set_analysis_state(True)
            self.advanced_analysis_control.update_advanced_analysis_status("智能分析中)
            
            # 发送高级分析开始信å?
            self.advanced_analysis_started.emit()
            
        except Exception as e:
            QMessageBox.critical(
                self, 
                "智能分析启动失败", 
                f"启动智能分析时出现错è¯?\n{str(e)}\n\n请检查系统状态后重试?
            )
    
    def on_advanced_analysis_stop_analysis(self):
