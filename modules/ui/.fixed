    def _record_optimization_history(self, data_quality):
        """"""         try:
            from datetime import datetime
            
            optimization_record = {
                'timestamp': datetime.now().isoformat(),
                'data_quality': data_quality,
                'optimization_level': self.current_optimization_level,
                'window_size': 'unknown',  # 配置标签页已移除
                'confidence_threshold': getattr(self.left_panel, 'threshold_edit', None).text() if hasattr(self.left_panel, 'threshold_edit') else 'unknown',
                'sensitivity': getattr(self.left_panel, 'sensitivity_slider', None).value() if hasattr(self.left_panel, 'sensitivity_slider') else 'unknown'
            }
            
            self.optimization_history.append(optimization_record)
            
            # 限制历史记录长度
            if len(self.optimization_history) > 100:
                self.optimization_history.pop(0)
            
            self.logger.info(f"记录优化历史: {data_quality} -> {self.current_optimization_level}")
            
        except Exception as e:
            self.logger.error(f"记录优化历史失败: {e}")
    
    def _enable_real_time_monitoring(self):
        """"""         try:
            self.logger.info("启用实时数据监控")
            
            # 启用智能缓存管理
            self._enable_smart_caching()
            
            # 优化数据更新频率
            self._optimize_data_update_frequency()
            
            # 启用实时图表更新
            self._enable_real_time_charts()
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("实时数据监控已启用,包括智能缓存和性能优化")
                
        except Exception as e:
            self.logger.error(f"启用实时数据监控失败: {e}")
    
    def _enable_smart_caching(self):
        """"""         try:
            self.logger.info("启用智能缓存管理")
            
            # 设置缓存参数
            self.cache_enabled = True
            self.cache_size = 1000  # 缓存大小
            self.cache_ttl = 300    # 缓存生存时间(秒ï¼?
            
            # 初始化缓å­?
            self.data_cache = {}
            self.cache_timestamps = {}
            
            # 启动缓存清理定时å™?
            if not hasattr(self, 'cache_cleanup_timer'):
                self.cache_cleanup_timer = QTimer()
                self.cache_cleanup_timer.timeout.connect(self._cleanup_cache)
                self.cache_cleanup_timer.start(60000)  # 每分钟清理一¬?
            
            self.logger.info("智能缓存管理已启置"?)
            
        except Exception as e:
            self.logger.error(f"启用智能缓存管理失败: {e}")
    
    def _cleanup_cache(self):
        """"""         try:
            if not hasattr(self, 'cache_enabled') or not self.cache_enabled:
                return
            
            current_time = time.time()
            expired_keys = []
            
            # 查找过期的缓存项
            for key, timestamp in self.cache_timestamps.items():
                if current_time - timestamp > self.cache_ttl:
                    expired_keys.append(key)
            
            # 删除过期é¡?
            for key in expired_keys:
                if key in self.data_cache:
                    del self.data_cache[key]
                if key in self.cache_timestamps:
                    del self.cache_timestamps[key]
            
            if expired_keys:
                self.logger.info(f"清理äº?{len(expired_keys)} 个过期缓存项")
                
        except Exception as e:
            self.logger.error(f"清理缓存失败: {e}")
    
    def _optimize_data_update_frequency(self):
        """"""         try:
            self.logger.info("优化数据更新频率")
            
            # 根据数据源类型调整更新频成功率
            if hasattr(self, 'data_manager') and self.data_manager:
                source_type = getattr(self.data_manager, 'source_type', 'simulated')
                
                if source_type == 'simulated':
                    update_interval = 1000  # 1置§?
                elif source_type == 'file':
                    update_interval = 2000  # 2置§?
                elif source_type in ['serial', 'mqtt', 'tcp', 'udp']:
                    update_interval = 500   # 0.5置§?
                else:
                    update_interval = 1000  # 默认1置§?
                
                # 调整数据更新定时å™?
                if hasattr(self, 'data_timer'):
                    self.data_timer.setInterval(update_interval)
                    self.logger.info(f"数据更新频率已调整为 {update_interval}ms")
                    
        except Exception as e:
            self.logger.error(f"优化数据更新频率失败: {e}")
    
    def _enable_real_time_charts(self):
        """"""         try:
            self.logger.info("启用实时图表更新")
            
            # 启用图表动画
            if hasattr(self, 'right_tab'):
                # IMU可视化
                if hasattr(self.right_tab, 'imu_vis_tab') and hasattr(self.right_tab.imu_vis_tab, 'canvas'):
                    self.right_tab.imu_vis_tab.canvas.figure.set_facecolor('white')
                
                # CNAP可视化
                if hasattr(self.right_tab, 'cnap_vis_tab') and hasattr(self.right_tab.cnap_vis_tab, 'canvas'):
                    self.right_tab.cnap_vis_tab.canvas.figure.set_facecolor('white')
                
                # 分析结果可视化
                if hasattr(self.right_tab, 'analysis_vis_tab') and hasattr(self.right_tab.analysis_vis_tab, 'canvas'):
                    self.right_tab.analysis_vis_tab.canvas.figure.set_facecolor('white')
            
            self.logger.info("实时图表更新已启置"?)
            
        except Exception as e:
            self.logger.error(f"启用实时图表更新失败: {e}")
    
    def _enable_error_recovery(self):
        """"""         try:
            self.logger.info("启用自动错误恢复")
            
            # 设置错误检测阈值
            self.error_detection_threshold = 3  # 连续错误次数阈值
            self.consecutive_errors = 0  # 连续错误计数å™?
            
            # 启用自动重连机制
            self.auto_reconnect_enabled = True
            self.reconnect_attempts = 0
            self.max_reconnect_attempts = 5
            
            # 启动错误监控定时å™?
            if not hasattr(self, 'error_monitor_timer'):
                self.error_monitor_timer = QTimer()
                self.error_monitor_timer.timeout.connect(self._monitor_errors)
                self.error_monitor_timer.start(10000)  # ¯?0秒检查一¬?
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("自动错误恢复已启用,包括错误检测和自动重连")
                
        except Exception as e:
            self.logger.error(f"启用自动错误恢复失败: {e}")
    
    def _monitor_errors(self):
        """"""         try:
            # 检查数据管理器状态- DataManager已注é‡?
            # if hasattr(self, 'data_manager') and self.data_manager:
            #     if not self.data_manager.is_connected and self.auto_reconnect_enabled:
            #         self._attempt_reconnect()
            
            # 检查多源数据状态
            if hasattr(self, 'data_sources'):
                for source_id, source_info in self.data_sources.items():
                    if not source_info.get("is_connected", False) and self.auto_reconnect_enabled:
                        self._attempt_source_reconnect(source_id)
                        
        except Exception as e:
            self.logger.error(f"错误监控失败: {e}")
    
    def _attempt_reconnect(self):
        """"""         try:
            if self.reconnect_attempts >= self.max_reconnect_attempts:
                self.logger.warning("达到最大重连次数,停止自动重连")
                self.auto_reconnect_enabled = False
                return
            
            self.reconnect_attempts += 1
            self.logger.info(f"尝试重新连接主数据源 (第{self.reconnect_attempts}¬?")
            
            # 尝试重新连接
            if hasattr(self, 'data_manager') and self.data_manager:
                # 这里可以添加具体的重连逻辑
                # 例如:重新调用connect方法
                pass
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message(f"正在尝试重新连接... (第{self.reconnect_attempts}¬?")
                
        except Exception as e:
            self.logger.error(f"重连尝试失败: {e}")
    def _attempt_source_reconnect(self, source_id):
        """"""         try:
            if source_id in self.data_sources:
                source_info = self.data_sources[source_id]
                if source_info.get("reconnect_attempts", 0) >= self.max_reconnect_attempts:
                    return
                
                source_info["reconnect_attempts"] = source_info.get("reconnect_attempts", 0) + 1
                self.logger.info(f"尝试重新连接数据源{source_id} (第{source_info['reconnect_attempts']}¬?")
                
                # 这里可以添加具体的重连逻辑
                # 例如:重新调用connect方法
                
        except Exception as e:
            self.logger.error(f"重连数据源{source_id} 失败: {e}")
    
    def reset_error_counters(self):
        """"""         try:
            self.consecutive_errors = 0
            self.reconnect_attempts = 0
            
            # 重置多源数据的错误计数器
            if hasattr(self, 'data_sources'):
                for source_info in self.data_sources.values():
                    source_info["reconnect_attempts"] = 0
            
            self.logger.info("错误计数器已重置")
            
        except Exception as e:
            self.logger.error(f"重置错误计数器失败 {e}")
    
    def _optimize_existing_file_browsing(self, sources):
        """"""         try:
            self.logger.info(f"优化原有文件浏览功能: {sources}")
            
            # 安全处理sources参数
            if not sources:
                self.logger.info("没有数据源,跳过文件浏览优化")
                return
            
            # 检查sources的类型并相应处理
            if isinstance(sources[0], dict):
                # 如果是字典列表,直接获取类型
                source_types = [source.get('type', 'unknown') for source in sources]
            elif isinstance(sources[0], int):
                # 如果是整数ID列表,需要从数据源管理器获取类型信息
                source_types = []
                for source_id in sources:
                    # 尝试从left_panel获取数据源信?
                    if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'data_source_panel'):
                        if hasattr(self.left_panel.data_source_panel, 'data_sources'):
                            source_info = self.left_panel.data_source_panel.data_sources.get(source_id, {})
                            source_type = source_info.get('type', 'unknown')
                            source_types.append(source_type)
                    else:
                        source_types.append('')
            else:
                # 其他类型,设为空字符中
                source_types = [''] * len(sources)
            
            # 根据选择的数据源类型优化文件浏览体验
            if 'imu' in source_types and 'cnap' in source_types:
                # 全选:启用智能文件识别和批量处理,并提供依次加载提置¤?
                self._enable_smart_file_recognition(sources)
                self._show_sequential_loading_guide(sources)
            elif 'imu' in source_types:
                # 只选IMU:优化IMU文件浏览
                self._optimize_imu_file_browsing()
            elif 'cnap' in source_types:
                # 只选CNAP:优化CNAP文件浏览
                self._optimize_cnap_file_browsing()
                
        except Exception as e:
            self.logger.error(f"优化文件浏览功能失败: {e}")
    
    def _enable_smart_file_recognition(self, sources):
        """"""         try:
            self.logger.info(f"启用智能文件识别: {sources}")
            
            # 这里可以添加智能文件识别逻辑
            # 例如:自动识别文件类型、提供文件建议等
            
            # 更新状态栏提示
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("智能文件识别已启用,支持IMU和CNAP数据文件")
                
        except Exception as e:
            self.logger.error(f"启用智能文件识别失败: {e}")
    
