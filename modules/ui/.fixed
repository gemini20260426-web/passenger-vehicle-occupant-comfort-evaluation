        try:
            from modules.ui.real_time_monitoring_tab import RealTimeMonitoringTab
            self.real_time_behavior_monitoring_tab = RealTimeMonitoringTab()
            self.addTab(self.real_time_behavior_monitoring_tab, "🚗 实时行为监控")
