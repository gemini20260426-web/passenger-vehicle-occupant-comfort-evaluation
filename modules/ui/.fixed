    def _on_one_click_sync(self):
        """"""         try:
            # 检查是否有可用的数据源
            if hasattr(self, 'data_source_panel') and hasattr(self.data_source_panel, 'data_sources'):
                if not self.data_source_panel.data_sources:
                    QMessageBox.warning(self, "警告", "请先添加数据源)
                    return
            
            # 启动同步
            self._on_start_sync()
            QMessageBox.information(self, "信息", "多源同步已启åŠ?)
        except Exception as e:
            self.logger.error(f"一键启动多源同步失败 {e}")
            QMessageBox.critical(self, "错误", f"启动多源同步失败: {e}")

    def _on_start_sync(self):
        """"""         try:
            self.sync_status_label.setText("同步中)
            self.sync_status_label.setStyleSheet(get_status_indicator_style("danger"))
            
            # 更新按钮状态
            self.start_sync_btn.setEnabled(False)
            self.stop_sync_btn.setEnabled(True)
            self.pause_sync_btn.setEnabled(True)
            
            self.logger.info("多源同步已开始/)
            # 这里可以发送信号到主控制器
            # self.multi_source_sync_started.emit()
        except Exception as e:
            self.logger.error(f"开始同步失败 {e}")

    def _on_stop_sync(self):
        """"""         try:
            self.sync_status_label.setText("已停­?)
            self.sync_status_label.setStyleSheet(get_status_indicator_style("danger"))
            
            # 更新按钮状态
            self.start_sync_btn.setEnabled(True)
            self.stop_sync_btn.setEnabled(False)
            self.pause_sync_btn.setEnabled(False)
            
            self.logger.info("多源同步已停­?)
            # 这里可以发送信号到主控制器
            # self.multi_source_sync_stopped.emit()
        except Exception as e:
            self.logger.error(f"停止同步失败: {e}")

    def _on_pause_sync(self):
        """"""         try:
            self.sync_status_label.setText("已暂å?)
            self.sync_status_label.setStyleSheet(get_status_indicator_style("danger"))
            
            # 更新按钮状态
            self.start_sync_btn.setEnabled(True)
            self.stop_sync_btn.setEnabled(True)
            self.pause_sync_btn.setEnabled(False)
            
            self.logger.info("多源同步已暂å?)
        except Exception as e:
            self.logger.error(f"暂停同步失败: {e}")

    def update_sync_metrics(self, metrics):
        """"""         try:
            if 'time_sync_precision' in metrics:
                self.time_sync_precision_label.setText(f"{metrics['time_sync_precision']}ms")
            
            if 'fusion_quality' in metrics:
                quality = metrics['fusion_quality']
                self.fusion_quality_label.setText(f"{quality}%")
                
                # 根据质量设置颜色
                if quality >= 90:
                    color = "#28a745"  # 绿色
                elif quality >= 70:
                    color = "#ffc107"  # 黄色
                else:
                    color = "#dc3545"  # 红色
                
                self.fusion_quality_label.setStyleSheet(f""""""                     QLabel {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 12px;
            font-weight: 500;
            color: #6b7280;
            background-color: transparent;
            border: none;
            padding: 6px;
            margin: 2px;
        };
                        color: white;
                        padding: 5px 10px;
                        border-radius: 4px;
                        font-weight: bold;
                        font-size: 14px;
                    }}
                """"""         self.main_layout.setContentsMargins(10, 10, 10, 10)
        self.main_layout.setSpacing(10)
        
        # === 重构:使用左侧数据源管理面板和分析控制模å?===
        try:
            # 导入左侧数据源管理面?
            from modules.ui.left_data_source_panel import LeftDataSourcePanel
            
            # 创建左侧数据源管理面?
            self.data_source_panel = LeftDataSourcePanel(self)
            
            # 连接信号 - 使用左侧数据源管理面板的信号
            self.data_source_panel.data_source_changed.connect(self._on_data_source_changed)
            self.data_source_panel.load_file_requested.connect(self._on_load_file_requested)
            self.data_source_panel.data_sources_selected.connect(self._on_data_sources_selected)
            self.data_source_panel.source_added.connect(self._on_source_added)
            self.data_source_panel.source_removed.connect(self._on_source_removed)
            self.data_source_panel.active_source_changed.connect(self._on_active_source_changed)
            
            # 添加到主布局
            self.main_layout.addWidget(self.data_source_panel)
            
            self.logger.info("左侧数据源管理面板集成成åŠ?)
            
        except ImportError as e:
            self.logger.error(f"导入左侧数据源管理面板失败 {e}")
            # 如果导入失败,显示错误信?
            error_label = QLabel("?左侧数据源管理面板加载失败)
            error_label.setStyleSheet(get_error_label_style("normal"))
            self.main_layout.addWidget(error_label)
        except Exception as e:
            self.logger.error(f"集成左侧数据源管理面板失败 {e}")
            # 如果集成失败,显示错误信?
            error_label = QLabel("?左侧数据源管理面板集成失败)
            error_label.setStyleSheet(get_error_label_style("normal"))
            self.main_layout.addWidget(error_label)
        
        # === 分析控制模块 ===
        try:
            from modules.ui.analysis_control_panel import AnalysisControlPanel
            
            # 创建分析控制面板
            self.analysis_control_panel = AnalysisControlPanel(self)
            
            # 连接信号
