    def _calculate_optimal_confidence_threshold(self, data_quality):
        """"""         try:
            # 基于数据质量动态计算置信度阈值
            if data_quality == 'excellent':
                return 0.85  # 高质量数据,可以设置较高阈值
            elif data_quality == 'good':
                return 0.80  # 良好数据,标准阈值
            elif data_quality == 'fair':
                return 0.75  # 一般数据,降低阈值
            elif data_quality == 'poor':
                return 0.65  # 低质量数据,进一步降低阈值
            else:
                return 0.70  # 未知质量,保守阈值
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"计算最优置信度阈值失败 {e}")
            return 0.75  # 降级到默认å?
    def _calculate_optimal_sensitivity(self, data_quality):
        """"""         try:
            # 基于数据质量动态计算灵敏度
            if data_quality == 'excellent':
                return 7  # 高质量数据,较高灵敏度
            elif data_quality == 'good':
                return 6  # 良好数据,标准灵敏度
            elif data_quality == 'fair':
                return 5  # 一般数据,降低灵敏度
            elif data_quality == 'poor':
                return 3  # 低质量数据,进一步降低灵敏度
            else:
                return 4  # 未知质量,保守灵敏度
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"计算最优灵敏度失败: {e}")
            return 5  # 降级到默认å?
    
    def _filter_alarms_by_level(self, level):
        """"""         try:
            # 清空当前告警列表
            self.alarm_list.clear()
            
            # 获取真实告警数据
            real_alarms = self._get_real_system_alarms()
            
            if not real_alarms:
                self.alarm_list.addItem("📊 暂无告警信息")
                return
            
            # 根据级别过滤告警
            filtered_alarms = []
            if level == "全部":
                filtered_alarms = real_alarms
            else:
                level_mapping = {": "low", ": "medium", ": "high", "紧: "critical"}
                target_level = level_mapping.get(level, "all")
                filtered_alarms = [alarm for alarm in real_alarms if alarm.get('level') == target_level]
            
            # 显示过滤后的告警
            if filtered_alarms:
                for alarm in filtered_alarms:
                    alarm_text = f"{alarm.get('icon', '🔴')} {alarm.get('level_name', '未知')}: {alarm.get('message', '无描è¿?)} - {alarm.get('timestamp', '未知时间')}"
                    self.alarm_list.addItem(alarm_text)
            else:
                self.alarm_list.addItem(f"📊 级别 '{level}' 暂无告警信息")
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"过滤告警失败: {e}")
            self.alarm_list.addItem("?告警过滤失败")
    
