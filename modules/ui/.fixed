    def on_analysis_toggled(self):
        """"""         try:
            self.analysis_running = not self.analysis_running
            if self.analysis_running:
                # 开始分析
                self.analysis_btn.setText("⏸️ 暂停分析")
                self.analysis_btn.setStyleSheet(get_button_style("primary", "medium"))
                self.stop_analysis_btn.setEnabled(False)
                
                # 显示进度?
                self.analysis_progress.setVisible(True)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("基础分析中)
                self.analysis_status_label.setStyleSheet(get_status_indicator_style("info", "normal"))
                
                # 发送信å?
                self.analysis_toggled.emit(True, "basic")
                
                # 显示开始提置¤?
                QMessageBox.information(
                    self, 
                    "基础分析已开始/, 
                    f"已开始基础模式分析\n\n分析参数:\n- 灵敏度 {self.sensitivity_slider.value()}\n- 置信度阈值 {self.threshold_edit.text()}\n\n请等待分析完ˆ?.."
                )
            else:
                # 停止分析
                self.analysis_btn.setText("▶️ 开始分析)
                self.analysis_btn.setStyleSheet(get_button_style("primary", "medium"))
                self.stop_analysis_btn.setEnabled(False)
                
                # 隐藏进度?
                self.analysis_progress.setVisible(False)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("已停­?)
                self.analysis_status_label.setStyleSheet(get_status_indicator_style("normal", "normal"))
                
                # 发送信å?
                self.analysis_toggled.emit(False, "")
                
                # 显示停止提示
                QMessageBox.information(
                    self, 
                    "分析已停­?, 
                    "分析已停止\n\n您可以查看已分析的结果,或重新开始分析?
                )
        except Exception as e:
            QMessageBox.critical(
                self, 
                "分析状态切换失败, 
                f"切换分析状态时出现错误:\n{str(e)}\n\n请检查系统状态后重试?
            )
    
    def on_stop_analysis(self):
        """"""         try:
            if self.analysis_running:
                # 停止分析
                self.analysis_running = False
                self.analysis_btn.setText("▶️ 开始分析)
                self.analysis_btn.setStyleSheet(get_button_style("primary", "medium"))
                self.stop_analysis_btn.setEnabled(False)
                
                # 隐藏进度?
                self.analysis_progress.setVisible(False)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("已停­?)
                self.analysis_status_label.setStyleSheet(get_status_indicator_style("normal", "normal"))
                
                # 发送信å?
                self.analysis_toggled.emit(False, "")
                
                # 显示停止提示
                QMessageBox.information(
                    self, 
                    "分析已停­?, 
                    "分析已通过暂停按钮停止\n\n您可以查看已分析的结果,或重新开始分析?
                )
        except Exception as e:
            QMessageBox.critical(
                self, 
                "停止分析失败", 
                f"停止分析时出现错è¯?\n{str(e)}\n\n请检查系统状态后重试?
            )
    
    def on_record_toggled(self):
        """"""         self.record_running = not self.record_running
        if self.record_running:
            self.record_btn.setText("⏹️ 停止记录")
            self.record_btn.setStyleSheet(get_button_style("success", "medium"))
            self.export_btn.setEnabled(False)
            # 更新记录状态显置¤?
            self._update_recording_status_display("记录中)
            self.record_toggled.emit(True)
        else:
            self.record_btn.setText("🔴 开始记录)
            self.record_btn.setStyleSheet(get_button_style("success", "medium"))
            self.export_btn.setEnabled(True)
            # 更新记录状态显置¤?
            self._update_recording_status_display("已停­?)
            self.record_toggled.emit(False)
    



    

