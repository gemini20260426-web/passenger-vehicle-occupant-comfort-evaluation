    def update_translations(self, lang):
        # 已注释DataManager相关逻辑
        # 原方法内容已注释
        pass
        
        # 原始方法内容:
        # 
        # 更新标签页标题(配置标签页已移除,索引相应调整)
        self.setTabText(0, translations[lang]['real_time_monitoring'])
        self.setTabText(1, "🚗 实时行为监控")  # 新增的标签页
        self.setTabText(2, f"🔍 {translations[lang]['system_monitoring']}")
        self.setTabText(3, f"📊 {translations[lang]['comprehensive_monitoring']}")
        self.setTabText(4, f"🤖 {translations[lang]['fused_analysis']}")
        self.setTabText(5, translations[lang]['data_source'])
        self.setTabText(6, translations[lang]['behavior_analysis'])
        self.setTabText(7, translations[lang]['analysis_visualization'])
        self.setTabText(8, translations[lang]['imu_visualization'])
        self.setTabText(9, translations[lang]['cnap_visualization'])
        
        # 更新各个组的标题
        for group in self.findChildren(QGroupBox):
            current_title = group.title()
            for key, value in translations['en'].items():
                if current_title == value:
                    group.setTitle(translations[lang][key])
                    break
        
        # 更新按钮文本
        self.start_analysis_btn.setText(translations[lang]['start_analysis'])
        self.stop_analysis_btn.setText(translations[lang]['stop_analysis'])
        # 配置按钮已移除,配置管理功能移至菜单
        
        # 更新标签文本
        labels = self.findChildren(QLabel)
        for label in labels:
            current_text = label.text()
            for key, value in translations['en'].items():
                if current_text.startswith(value):
                    # 处理包含动态内容的标签
                    if current_text == f"{value} {translations['en']['status_ready']}":
                        label.setText(f"{translations[lang][key]} {translations[lang]['status_ready']}")
                    elif current_text == f"{value} 0 Hz":
                        label.setText(f"{translations[lang][key]} 0 Hz")
                    elif current_text == f"{value} {translations['en']['status_ready'].lower()}":
                        label.setText(f"{translations[lang][key]} {translations[lang]['status_ready'].lower()}")
                    elif current_text == f"{value} Disconnected":
                        label.setText(f"{translations[lang][key]} Disconnected")
                    else:
                        label.setText(translations[lang][key])
                    break
        
        # 更新可视化组件的翻译
        self.analysis_vis_tab.update_translations(lang)
        self.imu_vis_tab.update_translations(lang)
        self.cnap_vis_tab.update_translations(lang)
    def _create_connection_panel(self):
        """"""         group = QGroupBox("🔗 数据源连接管置?)
        group.setStyleSheet(get_groupbox_style("primary"))
        
        layout = QVBoxLayout(group)
        layout.setSpacing(15)
        
        # 连接状态显置¤?
        self.connection_status_list = QListWidget()
        self.connection_status_list.setMaximumHeight(120)
        self.connection_status_list.setStyleSheet(get_listwidget_style())
        
        # 初始化后通过真实状态刷新填充(避免硬编码占位项ï¼?
        if hasattr(self, '_refresh_real_connection_status'):
            try:
                self._refresh_real_connection_status()
            except Exception as _:
                pass
        
        layout.addWidget(self.connection_status_list)
        
        # 连接控制按钮
        control_layout = QHBoxLayout()
        
        self.add_source_btn = QPushButton("析添加数据源)
        self.add_source_btn.setStyleSheet(get_button_style("success"))
        self.connect_source_btn = QPushButton("🔌 连接")
        self.connect_source_btn.setStyleSheet(get_button_style("primary"))
        self.disconnect_source_btn = QPushButton("🔌 断开")
        self.disconnect_source_btn.setStyleSheet(get_button_style("danger"))
        self.remove_source_btn = QPushButton("🗑ï¸?删除")
        self.remove_source_btn.setStyleSheet(get_button_style("muted"))
        
        control_layout.addWidget(self.add_source_btn)
        control_layout.addWidget(self.connect_source_btn)
        control_layout.addWidget(self.disconnect_source_btn)
        control_layout.addWidget(self.remove_source_btn)
        
        layout.addLayout(control_layout)
        
        return group

    

    

    

    

    

    def _create_data_source_status_panel(self):
        """"""         group = QGroupBox("📊 数据源状态监控)
        group.setStyleSheet(get_groupbox_style("info"))
        
        layout = QVBoxLayout(group)
        layout.setSpacing(15)
        
        # 数据源状态表 ?
        self.data_source_status_table = QTableWidget()
        self.data_source_status_table.setColumnCount(5)
        self.data_source_status_table.setHorizontalHeaderLabels([
            "数据源类å析, "连接状态, "数据流量", "延迟(ms)", "最后更新
        ])
        self.data_source_status_table.setRowCount(0)
        self.data_source_status_table.setStyleSheet(get_listwidget_style())
        layout.addWidget(self.data_source_status_table)
        
        # 状态更新按é'?
        refresh_status_layout = QHBoxLayout()
        self.refresh_status_btn = QPushButton("🔄 刷新状态)
        self.refresh_status_btn.setStyleSheet(get_button_style("info"))
        refresh_status_layout.addWidget(self.refresh_status_btn)
        refresh_status_layout.addStretch()
        layout.addLayout(refresh_status_layout)
        
        # 绑定刷新动作
        try:
            self.refresh_status_btn.clicked.connect(self._refresh_real_connection_status)
        except Exception:
            pass
        
        return group

