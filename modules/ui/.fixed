    def _on_unified_data_source_selected(self, sources: list):
        """"""         try:
            self.logger.info(f"统一数据源管理面?- 数据源选择变化: {sources}")
            self.selected_sources = sources.copy()
            self.data_sources_selected.emit(sources)
            
            # 更新原有UI状态(如果存在ï¼?
            if hasattr(self, 'multi_source_status_label'):
                if sources:
                    self.multi_source_status_label.setText(f"已选择 {len(sources)} 个数据源")
                else:
                    self.multi_source_status_label.setText("未选择数据源)
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源选择信号失败: {e}")
    
    def _on_unified_data_source_changed(self, source_id: str, config: dict):
        """"""         try:
            self.logger.info(f"统一数据源管理面?- 数据源配置变åŒ? {source_id} - {config}")
            
            # 更新原有UI状态(如果存在ï¼?
            if hasattr(self, 'source_status_label'):
                self.source_status_label.setText("已配置?)
                self.source_status_label.setStyleSheet(get_status_indicator_style("success", "normal"))
                
        except Exception as e:
            self.logger.error(f"处理统一数据源配置变化信号失败 {e}")
    
    def _on_unified_analysis_toggled(self, enabled: bool):
        """"""         try:
            self.logger.info(f"统一数据源管理面?- 分析开å…? {enabled}")
            
            # 转发到原有的分析系统
            self.analysis_toggled.emit(enabled, "unified")
            
            # 更新原有UI状态(如果存在ï¼?
            if hasattr(self, 'analysis_btn'):
                if enabled:
                    self.analysis_btn.setText("⏸️ 暂停分析")
                    self.analysis_running = True
                else:
                    self.analysis_btn.setText("▶️ 开始分析)
                    self.analysis_running = False
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源分析开关信号失败 {e}")
    
    def _on_unified_record_toggled(self, enabled: bool):
        """"""         try:
            self.logger.info(f"统一数据源管理面?- 记录开å…? {enabled}")
            
            # 转发到原有的记录系统
            self.record_toggled.emit(enabled)
            
            # 更新原有UI状态(如果存在ï¼?
            if hasattr(self, 'record_btn'):
                if enabled:
                    self.record_btn.setText("⏸️ 停止记录")
                    self.record_running = True
                else:
                    self.record_btn.setText("🔴 开始记录)
                    self.record_running = False
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源记录开关信号失败 {e}")
    
    def get_unified_panel(self):
        """"""         if hasattr(self, 'unified_data_source_panel'):
            return self.unified_data_source_panel
        return None
    
    def refresh_unified_panel(self):
        """"""         try:
            if hasattr(self, 'unified_data_source_panel'):
                self.unified_data_source_panel._refresh_sources_list()
                self.logger.info("统一数据源管理面板已刷新")
            else:
                self.logger.warning("统一数据源管理面板未初始åŒ?)
        except Exception as e:
            self.logger.error(f"刷新统一数据源管理面板失败 {e}")
    
    def _on_export_data_requested(self):
        """"""         try:
            self.logger.info("统一数据源管理面?- 导出数据请求")
            # 这里可以添加导出数据的逻辑
            # 例如:显示导出对话框、选择导出格式置­?
            QMessageBox.information(self, "导出数据", "导出数据功能待实成功率)
        except Exception as e:
            self.logger.error(f"处理导出数据请求失败: {e}")
# 数据源选择对话¡?
class DataSourceSelectionDialog(QDialog):
    def __init__(self, parent=None, selected_sources=None, available_sources=None):
        super().__init__(parent)
        # 初始化日志记录器
        try:
            from config.logging_setup import get_logger
            self.logger = get_logger(__name__)
        except ImportError:
            import logging
            self.logger = logging.getLogger(__name__)
        
        self.logger.debug(f"DataSourceSelectionDialog 初始化,parent: {parent}")
        
        # 获取当前语言,从父窗口或使用默认语言
        if hasattr(parent, 'current_lang'):
            current_lang = parent.current_lang
        elif hasattr(parent, 'parent') and hasattr(parent.parent(), 'current_lang'):
            current_lang = parent.parent().current_lang
        else:
            current_lang = 'en'  # 默认使用英文
            
        self.logger.debug(f"当前语言: {current_lang}")
        self.current_lang = current_lang
        self.setWindowTitle(translations[current_lang]['select_data_sources'])
        self.selected_sources = selected_sources if selected_sources else []
        self.available_sources = available_sources if available_sources else [
            'imu', 'cnap'  # 当前可用数据源,未来可扩å±?
        ]
        
        self.logger.debug(f"选中的数据源: {self.selected_sources}")
        self.logger.debug(f"可用数据源 {self.available_sources}")
        
        self.init_ui()
        self.logger.debug("DataSourceSelectionDialog UI 初始化完ˆ?)
        
    def init_ui(self):
        self.logger.debug("开始初始化 DataSourceSelectionDialog UI")
        layout = QVBoxLayout(self)
        
        # 数据源列è¡?
        from PySide6.QtWidgets import QListWidget, QListWidgetItem
        self.source_list = QListWidget()
        self.source_list.setSelectionMode(QListWidget.ExtendedSelection)
        
        # 添加数据源项
        source_display_names = {
            'imu': 'IMU',
            'cnap': 'CNAP'
        }
        
        self.logger.debug("正在添加数据源项...")
        for source in self.available_sources:
            # 安全处理source,确保转换为字符中
            display_name = source_display_names.get(source, str(source))
            item = QListWidgetItem(display_name)
            item.setData(Qt.UserRole, source)
            item.setSelected(source in self.selected_sources)
            self.source_list.addItem(item)
            self.logger.debug(f"添加数据源项: {source}")
        
        layout.addWidget(QLabel(translations[self.current_lang]['data_sources']))
        layout.addWidget(self.source_list)
        
        # 全é?取消全选按é'?
        btn_layout = QHBoxLayout()
        self.select_all_btn = QPushButton(translations[self.current_lang]['select_all'])
        self.deselect_all_btn = QPushButton(translations[self.current_lang]['deselect_all'])
        
        self.select_all_btn.clicked.connect(self.select_all)
        self.deselect_all_btn.clicked.connect(self.deselect_all)
        
        btn_layout.addWidget(self.select_all_btn)
        btn_layout.addWidget(self.deselect_all_btn)
        layout.addLayout(btn_layout)
        
        # 确认/取消按钮
        dialog_buttons = QDialogButtonBox(
            QDialogButtonBox.Ok | QDialogButtonBox.Cancel,
            Qt.Horizontal, self
        )
        dialog_buttons.accepted.connect(self.accept)
        dialog_buttons.rejected.connect(self.reject)
        
        # 翻译按钮文本
        dialog_buttons.button(QDialogButtonBox.Ok).setText(translations[self.current_lang]['ok'])
        dialog_buttons.button(QDialogButtonBox.Cancel).setText(translations[self.current_lang]['cancel'])
        
        layout.addWidget(dialog_buttons)
        
    def select_all(self):
        """"""         for i in range(self.source_list.count()):
            self.source_list.item(i).setSelected(True)
        
        # 显示全选确è®?
        selected_count = self.source_list.count()
        QMessageBox.information(
            self, 
            "全选完ˆ?, 
            f"已全é?{selected_count} 个数据源:\n\n" + 
            "\n".join([self.source_list.item(i).text() for i in range(selected_count)]) +
            "\n\n点击 '确定' 按钮确认选择?
        )
            
    def deselect_all(self):
        """"""         for i in range(self.source_list.count()):
            self.source_list.item(i).setSelected(False)
        
        # 显示取消全选确è®?
        QMessageBox.information(
            self, 
            "取消全选完ˆ?, 
            "已取消选择所有数据源。\n\n请手动选择需要的数据源?
        )
        
    def get_selected_sources(self):
        """"""         selected = []
        for i in range(self.source_list.count()):
            if self.source_list.item(i).isSelected():
                selected.append(self.source_list.item(i).data(Qt.UserRole))
        
        # 验证选择结果
        if not selected:
            QMessageBox.warning(
                self, 
                "未选择数据源, 
                "请至少选择一个数据源。\n\n可用的数据源:\n- IMU (惯性测量单å…?\n- CNAP (心血管监µ?"
            )
            return []
        
        # 显示选择确认
        source_names = [self.source_list.item(i).text() for i in range(self.source_list.count()) 
                       if self.source_list.item(i).isSelected()]
        
        QMessageBox.information(
            self, 
            "数据源选择确认", 
            f"已选择以下数据源\n\n" + "\n".join(source_names) + 
            f"\n\n总计: {len(selected)} 个数据源\n\n点击 '确定' 按钮继续?
        )
        
        return selected
    


class RightTabContainer(QTabWidget):
    """"""     def __init__(self, parent=None):
        super().__init__(parent)
        self.analyzer = None
        self.init_ui()
        
    def set_analyzer(self, analyzer):
        self.analyzer = analyzer
        self.analysis_vis_tab.set_analyzer(analyzer)
        
