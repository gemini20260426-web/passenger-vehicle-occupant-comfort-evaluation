    def init_system_monitor_tab(self):
        """"""         # 创建滚动区域
        scroll_area = QScrollArea()
        scroll_widget = QWidget()
        layout = QVBoxLayout(scroll_widget)
        
        # 设置滚动区域属?
        scroll_area.setWidget(scroll_widget)
        scroll_area.setWidgetResizable(True)
        scroll_area.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        scroll_area.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        scroll_area.setStyleSheet(get_scroll_area_style())
        
        # 将滚动区域添加到标签页
        tab_layout = QVBoxLayout(self.system_monitor_tab)
        tab_layout.addWidget(scroll_area)
        
        # === 系统健康度概è§?===
        health_group = QGroupBox("🏥 系统健康度概è§?)
        health_layout = QVBoxLayout()
        
        # 健康度评åˆ?
        health_score_layout = QHBoxLayout()
        self.health_score_label = QLabel("系统健康度评åˆ?")
        self.health_score_value = QLabel("95")
        self.health_score_value.setStyleSheet(get_count_label_style("success"))
        self.health_score_max = QLabel("/100")
        self.health_score_max.setStyleSheet(get_label_style("muted", "xlarge"))
        
        health_score_layout.addWidget(self.health_score_label)
        health_score_layout.addWidget(self.health_score_value)
        health_score_layout.addWidget(self.health_score_max)
        health_score_layout.addStretch()
        
        # 健康度进度条
        self.health_score_progress = QProgressBar()
        self.health_score_progress.setRange(0, 100)
        # 动态设置健康度 - 基于系统实际状态
        current_health = self._get_dynamic_system_health()
        self.health_score_progress.setValue(current_health)
        self.health_score_progress.setStyleSheet(get_progress_bar_style("success"))
        
        health_layout.addLayout(health_score_layout)
        health_layout.addWidget(self.health_score_progress)
        health_group.setLayout(health_layout)
        layout.addWidget(health_group)
        
        # === 实时性能监控 ===
        performance_group = QGroupBox("š?实时性能监控")
        performance_layout = QGridLayout()
        
        # CPU使用成功率
        self.cpu_usage_label = QLabel("CPU使用成功率")
        self.cpu_usage_value = QLabel("0%")
        self.cpu_usage_value.setStyleSheet(get_performance_value_style("info"))
        
        # 内存使用成功率
        self.memory_usage_label = QLabel("内存使用成功率")
        self.memory_usage_value = QLabel("0%")
        self.memory_usage_value.setStyleSheet(get_performance_value_style("secondary"))
        
        # 网络状态
        self.network_status_label = QLabel("网络状态")
        self.network_status_value = QLabel("正常")
        self.network_status_value.setStyleSheet(get_performance_value_style("success"))
        
        # 磁盘使用成功率
        self.disk_usage_label = QLabel("磁盘使用成功率")
        self.disk_usage_value = QLabel("0%")
        self.disk_usage_value.setStyleSheet(get_performance_value_style("warning"))
        
        performance_layout.addWidget(self.cpu_usage_label, 0, 0)
        performance_layout.addWidget(self.cpu_usage_value, 0, 1)
        performance_layout.addWidget(self.memory_usage_label, 0, 2)
        performance_layout.addWidget(self.memory_usage_value, 0, 3)
        performance_layout.addWidget(self.network_status_label, 1, 0)
        performance_layout.addWidget(self.network_status_value, 1, 1)
        performance_layout.addWidget(self.disk_usage_label, 1, 2)
        performance_layout.addWidget(self.disk_usage_value, 1, 3)
        
        performance_group.setLayout(performance_layout)
        layout.addWidget(performance_group)
        
        # === 数据质量评估 ===
        data_quality_group = QGroupBox("📊 数据质量评估")
        data_quality_layout = QGridLayout()
        
        # 数据完整?
        self.data_integrity_label = QLabel("数据完整?")
        self.data_integrity_value = QLabel("检测中...")
        self.data_integrity_value.setStyleSheet(get_performance_value_style("warning"))
        
        # 数据一致?
        self.data_consistency_label = QLabel("数据一致?")
        self.data_consistency_value = QLabel("检测中...")
        self.data_consistency_value.setStyleSheet(get_performance_value_style("warning"))
        
        # 数据延迟
        self.data_latency_label = QLabel("数据延迟:")
        self.data_latency_value = QLabel("检测中...")
        self.data_latency_value.setStyleSheet(get_performance_value_style("warning"))
        
        # 数据吞吐é‡?
        self.data_throughput_label = QLabel("数据吞吐é‡?")
        self.data_throughput_value = QLabel("检测中...")
        self.data_throughput_value.setStyleSheet(get_performance_value_style("warning"))
        
        data_quality_layout.addWidget(self.data_integrity_label, 0, 0)
        data_quality_layout.addWidget(self.data_integrity_value, 0, 1)
        data_quality_layout.addWidget(self.data_consistency_label, 0, 2)
        data_quality_layout.addWidget(self.data_consistency_value, 0, 3)
        data_quality_layout.addWidget(self.data_latency_label, 1, 0)
        data_quality_layout.addWidget(self.data_latency_value, 1, 1)
        data_quality_layout.addWidget(self.data_throughput_label, 1, 2)
        data_quality_layout.addWidget(self.data_throughput_value, 1, 3)
        
        data_quality_group.setLayout(data_quality_layout)
        layout.addWidget(data_quality_group)
        
        # === 告警管理 ===
        alarm_group = QGroupBox("🚨 告警管理")
        alarm_layout = QVBoxLayout()
        
        # 告警级别选择
        alarm_filter_layout = QHBoxLayout()
        alarm_filter_layout.addWidget(QLabel("告警级别:"))
