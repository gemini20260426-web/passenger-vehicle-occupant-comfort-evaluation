                self.right_tab.analysis_state_label.setText("分析状态 高级分析运行中)
                self.right_tab.analysis_state_label.setStyleSheet(get_label_style("secondary", "normal", "bold"))
            
            # 显示开始成功提置¤?
            QMessageBox.information(
                self, 
                "高级分析启动成功", 
                "机器学习模型训练已开始\n\n"
