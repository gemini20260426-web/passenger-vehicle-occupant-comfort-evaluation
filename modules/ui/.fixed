            title_label = QLabel("📚 数据加载指南")
            title_label.setStyleSheet(get_label_style("primary", "xlarge", "bold"))
            layout.addWidget(title_label)
            
            # 说明文字
            guide_text = QLabel(""""""         QMessageBox.information(self, "Help", translations[CoreUIMainWindow.current_lang]['help_text'])
    
    def setup_left_control_panel(self):
        """"""         self.left_panel_manager = LeftPanelManager(self)
        
        # 创建并注册所有面?
        self.data_source_panel = DataSourceControlPanel()
        self.parsing_panel = ParsingControlPanel()
        self.analysis_panel = AnalysisControlPanel()
        self.sync_panel = SyncControlPanel()
        self.system_panel = SystemControlPanel()
        
        self.left_panel_manager.register_panel(self.data_source_panel)
        self.left_panel_manager.register_panel(self.parsing_panel)
        self.left_panel_manager.register_panel(self.analysis_panel)
        self.left_panel_manager.register_panel(self.sync_panel)
        self.left_panel_manager.register_panel(self.system_panel)
        
        # 添加到主布局
        self.main_layout.addWidget(self.left_panel_manager)
        
    def handle_control_action(self, action_type, payload):
        """"""         print(f"处理控制面板动作: {action_type}, 数据: {payload}")
        
        # 基础分析相关动作
        if action_type == "BASIC_ANALYSIS_START":
            self._handle_basic_analysis(payload)
            self.analysis_panel.update_status("基础分析运行中)
            self.analysis_panel.show_progress(True, 10)
        elif action_type == "BASIC_ANALYSIS_PAUSE":
            # 暂停基础分析
            self.analysis_panel.update_status("基础分析已暂å?)
        elif action_type == "BASIC_ANALYSIS_STOP":
            # 停止基础分析
            self.analysis_panel.update_status("基础分析已停­?)
            self.analysis_panel.show_progress(False)
            
        # 高级分析相关动作
        elif action_type == "ADVANCED_ANALYSIS_START":
            self._handle_advanced_analysis(payload)
            self.analysis_panel.update_status("高级分析运行中)
        elif action_type == "ADVANCED_ANALYSIS_PAUSE":
            # 暂停高级分析
            self.analysis_panel.update_status("高级分析已暂å?)
        elif action_type == "ADVANCED_ANALYSIS_STOP":
            # 停止高级分析
            self.analysis_panel.update_status("高级分析已停­?)
            
        # 模型相关动作
        elif action_type == "MODEL_LOAD_REQUEST":
            self.on_model_load_requested()
        elif action_type == "MODEL_UNLOAD_REQUEST":
            self.on_model_unload_requested()
            
        # 训练相关动作
        elif action_type == "TRAINING_START":
            # 开始训统?
            self.analysis_panel.update_status("模型训练中)
        elif action_type == "TRAINING_STOP":
            # 停止训练
            self.analysis_panel.update_status("训练已停­?)
            
        # 数据源相关动ä½?
        elif action_type == "DATA_SOURCE_CHANGED":
            self.on_data_source_changed(payload["type"], {})
        elif action_type == "LOAD_DATA":
            # 加载数据
            self.on_load_file()
            self.data_source_panel.update_status("数据加载中)
        elif action_type == "CLEAR_DATA":
            # 清除数据
            self.data_source_panel.update_status("数据已清é™?)
        elif action_type == "ADD_SOURCE":
            # 添加数据源
            self.data_source_panel.update_status("数据源已添加")
        elif action_type == "REMOVE_SOURCE":
            # 移除数据源
            self.data_source_panel.update_status("数据源已移除")
        elif action_type == "SET_ACTIVE_SOURCE":
            # 设置活跃数据源
            self.data_source_panel.update_status("活跃数据源已设置")
            
        # 解析相关动作
        elif action_type == "START_PARSING":
            # 启动解析
            self.parsing_panel.set_parsing_state(True)
            self.parsing_panel.update_status("解析)
        elif action_type == "STOP_PARSING":
            # 停止解析
            self.parsing_panel.set_parsing_state(False)
            self.parsing_panel.update_status("已停­?)
        elif action_type == "PAUSE_PARSING":
            # 暂停解析
            self.parsing_panel.update_status("已暂å?)
        elif action_type == "PARSING_CONFIG_CHANGED":
            # 解析配置变化
            print(f"解析配置已更新 {payload}")
            
        # 同步相关动作
        elif action_type == "START_SYNC":
            # 启动同步
            self.sync_panel.set_sync_state(True)
            self.sync_panel.update_status("同步中)
        elif action_type == "STOP_SYNC":
            # 停止同步
            self.sync_panel.set_sync_state(False)
            self.sync_panel.update_status("已停­?)
        elif action_type == "PAUSE_SYNC":
            # 暂停同步
            self.sync_panel.update_status("已暂å?)
        elif action_type == "ONE_CLICK_SYNC":
            # 一键同­?
            self.sync_panel.set_sync_state(True)
            self.sync_panel.update_status("同步中)
        elif action_type == "SYNC_CONFIG_CHANGED":
            # 同步配置变化
            print(f"同步配置已更新 {payload}")
            
        # 系统控制相关动作
        elif action_type == "THEME_CHANGED":
            self.set_theme(payload["theme"])
        elif action_type == "LOG_LEVEL_CHANGED":
            print(f"日志级别已更改为: {payload['level']}")
        elif action_type == "AUTO_SAVE_CHANGED":
            print(f"自动保存已{'启用' if payload['enabled'] else '禁用'}")
        elif action_type == "AUTO_OPTIMIZATION_CHANGED":
            print(f"自动优化间隔已更改为: {payload['interval']} 分钟")
        elif action_type == "SAVE_CONFIG":
            print("配置已保å­?)
        elif action_type == "LOAD_CONFIG":
            print("配置已加è½?)
        elif action_type == "EXPORT_DATA":
            self.on_export_data()
        elif action_type == "SYSTEM_OPTIMIZATION":
            print("系统优化已启åŠ?)
        elif action_type == "CLEAR_CACHE":
            print("缓存已清置?)
        elif action_type == "RESTART_SYSTEM":
            print("系统重启请求")
        elif action_type == "TOGGLE_RECORD":
            self.on_record_toggled(True)  # 简单实成功率
        elif action_type == "RESET_SYSTEM":
            print("系统重置")
            
        # 其他动作处理...
        else:
            print(f"未处理的动作类型: {action_type}")
    
    def cleanup(self):
        """"""         try:
            self.logger.info("开始清理Core UI资源")
            
            # 禁用自动优化
            if hasattr(self, 'auto_optimization_enabled') and self.auto_optimization_enabled:
                self._disable_auto_optimization()
            
            # 停止所有定时器
            if hasattr(self, 'optimization_timer') and self.optimization_timer:
                if self.optimization_timer.isActive():
                    self.optimization_timer.stop()
                    self.logger.debug("停止优化定时å™?)
                self.optimization_timer.deleteLater()
                self.optimization_timer = None
            
            # 重置状态
            self.auto_optimization_enabled = False
            self._optimization_in_progress = False
            
            self.logger.info("Core UI资源清理完成")
            
        except Exception as e:
            self.logger.error(f"清理Core UI资源时出é"? {e}")
    
    def closeEvent(self, event):
        """"""         try:
            self.logger.info("Core UI窗口关闭事件触发")
            
            # 清理资源
            self.cleanup()
            
            # 调用父类的closeEvent
            super().closeEvent(event)
            
        except Exception as e:
            self.logger.error(f"处理窗口关闭事件时出é"? {e}")
            # 确保事件被处置?
            event.accept()

    

    

    

    

    

    def _create_multi_source_sync_panel(self):
        """"""         group = QGroupBox("🔄 多源异构数据同步控制")
        group.setStyleSheet(get_groupbox_style("dark"))
        
        layout = QVBoxLayout(group)
        layout.setSpacing(15)
        
        # 同步状态显置¤?
        self.sync_status_label = QLabel("同步状态 未同­?)
        self.sync_status_label.setStyleSheet(get_status_label_style("muted"))
        layout.addWidget(self.sync_status_label)
        
        # 同步进度?
        self.sync_progress = QProgressBar()
        self.sync_progress.setRange(0, 100)
        self.sync_progress.setValue(0)
        self.sync_progress.setStyleSheet(get_progress_bar_style())
