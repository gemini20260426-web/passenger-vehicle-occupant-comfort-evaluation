    def _update_right_tab_data(self, data):
        """"""         try:
            if hasattr(self, 'right_tab'):
                # 更新System Status Summary
                if hasattr(self.right_tab, 'data_rate_label'):
                    data_rate = data.get('data_rate', 0)
                    self.right_tab.data_rate_label.setText(f"数据成功率 {data_rate} Hz")
                
                if hasattr(self.right_tab, 'progress_bar'):
                    progress = data.get('progress', 0)
                    self.right_tab.progress_bar.setValue(progress)
                
                # 更新连接状态
                if hasattr(self.right_tab, 'connection_label'):
                    connection_status = data.get('connection_status', 'Disconnected')
                    self.right_tab.connection_label.setText(f"连接: {connection_status}")
                
                if hasattr(self.right_tab, 'connection_status_label'):
                    connection_status = data.get('connection_status', '未连Ž?)
                    self.right_tab.connection_status_label.setText(f"连接状态 {connection_status}")
                
                # 更新数据源类å析
                if hasattr(self.right_tab, 'source_type_label'):
                    source_type = data.get('source_type', '未选择')
                    self.right_tab.source_type_label.setText(f"数据源类å析 {source_type}")
                
                # 更新系统状态
                if hasattr(self.right_tab, 'system_state_label'):
                    system_state = data.get('system_state', 'Ready')
                    self.right_tab.system_state_label.setText(f"状态 {system_state}")
                
                # 更新分析状态
                if hasattr(self.right_tab, 'analysis_state_label'):
                    analysis_state = data.get('analysis_state', 'ready')
                    self.right_tab.analysis_state_label.setText(f"分析: {analysis_state}")
                
                # 更新关键指标
                if hasattr(self.right_tab, 'metrics_display'):
                    metrics_text = data.get('metrics', '')
                    if metrics_text:
                        self.right_tab.metrics_display.setPlainText(metrics_text)
                
                # 更新分析标签页
                if hasattr(self.right_tab, 'analysis_tab'):
                    if hasattr(self.right_tab.analysis_tab, 'analysis_results'):
                        analysis_text = data.get('analysis_results', '')
                        if analysis_text:
                            self.right_tab.analysis_tab.analysis_results.setPlainText(analysis_text)
                
                # 更新数据源标签页
                if hasattr(self.right_tab, 'data_source_tab'):
                    # 这里可以添加数据源状态更新逻辑
                    pass
                    
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"更新右侧标签页数据失败 {e}")
    
    def _update_monitoring_from_left_panel(self, data):
        """"""         try:
            # 检查监控广播是否已停止
            if hasattr(self, 'monitoring_broadcast_enabled') and not self.monitoring_broadcast_enabled:
                self.logger.debug("📡 监控广播已停止,跳过更新")
                return
            
            self.logger.info(f"📡 收到左侧面板数据: {type(data).__name__}")
            
            if hasattr(self, 'right_tab'):
                # 检查是否是传感器数据
                if isinstance(data, dict) and data.get('type') == 'sensor_data':
                    # 这是传感器数据,转发到实时驾驶行为监控标签页
                    self._forward_sensor_data_to_behavior_monitoring(data)
                else:
                    # 更新Key Metrics显示
                    if hasattr(self.right_tab, 'metrics_display'):
                        # 格式化左侧面板的数据
                        formatted_metrics = self._format_left_panel_metrics(data)
                        self.right_tab.metrics_display.setPlainText(formatted_metrics)
                        self.logger.info("œ?右侧监控面板数据更新成功")
                    else:
                        self.logger.warning("⚠️ 无法找到metrics_display")
            else:
                self.logger.warning("⚠️ 无法找到right_tab")
                    
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"从左侧面板更新监控数据失败 {e}")
    
    def _forward_sensor_data_to_behavior_monitoring(self, sensor_data):
        """"""         try:
            if hasattr(self.right_tab, 'real_time_behavior_monitoring_tab'):
                # 检查标签页是否有update_sensor_data方法
                if hasattr(self.right_tab.real_time_behavior_monitoring_tab, 'update_sensor_data'):
                    # 提取传感器数据
                    actual_sensor_data = sensor_data.get('data', {})
                    if actual_sensor_data:
                        # 调用标签页的更新方法
                        self.right_tab.real_time_behavior_monitoring_tab.update_sensor_data(actual_sensor_data)
                        self.logger.info("œ?传感器数据已转发到实时驾驶行为监控标签页")
                    else:
                        self.logger.warning("⚠️ 传感器数据包中没有实际数据)
                else:
                    self.logger.warning("⚠️ 实时驾驶行为监控标签页没有update_sensor_data方法")
            else:
                self.logger.warning("⚠️ 无法找到实时驾驶行为监控标签页)
                
        except Exception as e:
            self.logger.error(f"转发传感器数据到行为监控标签页失败 {e}")
    def _format_left_panel_metrics(self, data):
        """"""         try:
            from datetime import datetime
            
            # 根据数据类型格式化显示内容
            if isinstance(data, dict):
                # 解析状态数据
                if 'IMU' in data and 'CNAP' in data:
                    # 这是解析状态数据
                    return self._format_parsing_status_metrics(data)
                elif 'total_data_points' in data:
                    # 这是解析统计数据
                    return self._format_parsing_stats_metrics(data)
                elif 'total_errors' in data:
                    # 这是错误监控数据
                    return self._format_error_monitor_metrics(data)
                else:
                    # 其他类型数据
                    return self._format_general_metrics(data)
            else:
                return f"数据类型: {type(data).__name__}\n内容: {str(data)}"
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化左侧面板数据失败 {e}")
            return f"数据格式化失败 {str(e)}"
    
    def _format_parsing_status_metrics(self, parsing_status):
        """"""         try:
            current_time = datetime.now().strftime("%H:%M:%S")
            
            metrics_text = f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化解析状态数据失败 {e}")
            return f"解析状态数据格式化失败: {str(e)}"
    
    def _format_parsing_stats_metrics(self, parsing_stats):
        """"""         try:
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 计算成功成功率
            total_parses = parsing_stats.get('successful_parses', 0) + parsing_stats.get('failed_parses', 0)
            success_rate = 0
            if total_parses > 0:
                success_rate = (parsing_stats.get('successful_parses', 0) / total_parses) * 100
            
            metrics_text = f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化解析统计数据失败 {e}")
            return f"解析统计数据格式化失败 {str(e)}"
    
    def _format_error_monitor_metrics(self, error_data):
        """"""         try:
            current_time = datetime.now().strftime("%H:%M:%S")
            
            metrics_text = f""""""             
            # 添加错误详情
            for error_detail in error_data.get('error_details', []):
                metrics_text += f""""""             
            if not error_data.get('error_details'):
                metrics_text += "\n   œ?当前无错è¯?
            
            metrics_text += f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化错误监控数据失败 {e}")
            return f"错误监控数据格式化失败 {str(e)}"
    
    def _format_real_time_metrics(self, parsing_status):
        """"""         try:
            from datetime import datetime
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 计算总体统计
            total_speed = sum(status.get('speed', 0) for status in parsing_status.values())
            total_progress = sum(status.get('progress', 0) for status in parsing_status.values())
            avg_progress = total_progress // len(parsing_status) if parsing_status else 0
            total_errors = sum(status.get('errors', 0) for status in parsing_status.values())
            active_sources = sum(1 for status in parsing_status.values() if status.get('status') == 'running')
            
            metrics_text = f""""""             
            # 添加各数据源的详细状态
            for source_type, status in parsing_status.items():
                status_icon = "🟢" if status.get('status') == 'running' else "🔴" if status.get('status') == 'error' else "🟡"
                progress_bar = "–? * (status.get('progress', 0) // 10) + "–? * (10 - status.get('progress', 0) // 10)
                
                metrics_text += f""""""             
            metrics_text += f""""""             
            return metrics_text
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"格式化实时解析状态数据失败 {e}")
            return f"实时解析状态数据格式化失败: {str(e)}"
    
    def update_fixed_display_area(self, data_type: str, content: str):
        """"""         try:
            if hasattr(self, 'right_tab'):
                if data_type == 'parsed_data':
                    if hasattr(self.right_tab, 'parsed_data_display'):
                        self.right_tab.parsed_data_display.setText(content)
                        if hasattr(self, 'logger'):
                            self.logger.info(f"œ?固定显示åŒ?- 解析数据已更新 {content[:50]}...")
                elif data_type == 'basic_analysis':
                    if hasattr(self.right_tab, 'basic_analysis_display'):
                        self.right_tab.basic_analysis_display.setText(content)
                        if hasattr(self, 'logger'):
                            self.logger.info(f"œ?固定显示åŒ?- 基础分析结果已更新 {content[:50]}...")
                elif data_type == 'advanced_analysis':
                    if hasattr(self.right_tab, 'advanced_analysis_display'):
                        self.right_tab.advanced_analysis_display.setText(content)
                        if hasattr(self, 'logger'):
                            self.logger.info(f"œ?固定显示åŒ?- 高级分析结果已更新 {content[:50]}...")
                elif data_type == 'status_indicator':
                    if hasattr(self.right_tab, 'status_indicator_display'):
                        self.right_tab.status_indicator_display.setText(content)
                        if hasattr(self, 'logger'):
                            self.logger.info(f"œ?固定显示åŒ?- 状态指示器已更新 {content[:50]}...")
                elif data_type == 'offline_dataset':
                    if hasattr(self.right_tab, 'offline_dataset_display'):
                        self.right_tab.offline_dataset_display.setText(content)
                        if hasattr(self, 'logger'):
                            self.logger.info(f"œ?固定显示åŒ?- 离线数据集状态已更新: {content[:50]}...")
                else:
                    if hasattr(self, 'logger'):
                        self.logger.warning(f"⚠️ 未知的数据类å析 {data_type}")
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"更新固定显示区失败 {e}")
    
    def _start_real_fixed_display_data(self):
        """"""         try:
            self.logger.info("🚀 开始真实固定显示区数据更新...")
            
            # 获取真实数据
            real_data = self._get_real_fixed_display_data()
            if not real_data:
                self.logger.warning("⚠️ 无法获取真实数据,降级到模拟模式")
                self._fallback_to_fixed_display_simulation()
                return
            
            # 更新固定显示åŒ?
            self._update_fixed_display_with_real_data(real_data)
            
            self.logger.info("œ?真实固定显示区数据更新完ˆ?)
            
        except Exception as e:
            self.logger.error(f"真实固定显示区数据更新失败 {e}")
            self._fallback_to_fixed_display_simulation()
    
    def _get_real_fixed_display_data(self):
        """"""         try:
            # 从解析状态监测面板获取数据
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                parsing_data = self.left_panel.parsing_status_monitor.get_parsing_status()
                parsing_stats = self.left_panel.parsing_status_monitor.get_parsing_stats()
                
                if parsing_data and parsing_stats:
                    self.logger.info(f"œ?获取到真实固定显示区数据: {len(parsing_data)} 个数据源")
                    return {
                        'parsing_status': parsing_data,
                        'parsing_stats': parsing_stats
                    }
                else:
                    self.logger.warning("⚠️ 固定显示区数据为置©?)
                    return None
            else:
                self.logger.warning("⚠️ 无法找到解析状态监测面?)
                return None
                
        except Exception as e:
            self.logger.error(f"获取真实固定显示区数据失败 {e}")
            return None
    
    def _fallback_to_fixed_display_simulation(self):
        """"""         try:
            self.logger.warning("⚠️ 降级到固定显示区模拟模式")
            self._simulate_fixed_display_data()
        except Exception as e:
            self.logger.error(f"降级到固定显示区模拟模式失败: {e}")
    
    def _simulate_fixed_display_data(self):
        """"""         try:
            from datetime import datetime
            current_time = datetime.now().strftime("%H:%M:%S")
            
            # 降级显示 - 明确标识为备用状态
            parsed_data = f"⚠️ 数据源未连接 | 状态 等待连接 | 时间: {current_time}"
            self.update_fixed_display_area('parsed_data', parsed_data)
            
            # 降级显示 - 明确标识为备用状态
            basic_analysis = f"⚠️ 分析引擎未启åŠ?| 状态 等待数据 | 时间: {current_time}"
            self.update_fixed_display_area('basic_analysis', basic_analysis)
            
            # 降级显示 - 明确标识为备用状态
            advanced_analysis = f"⚠️ 高级分析未训统?| 状态 等待基础分析 | 时间: {current_time}"
            self.update_fixed_display_area('advanced_analysis', advanced_analysis)
            
            # 降级状态指示器
            status_indicator = f"⚠️ 系统降级模式 | 数据质量: 未知 | 同步状态 未连Ž?| 时间: {current_time}"
            self.update_fixed_display_area('status_indicator', status_indicator)
            
            # 降级离线数据集状态
            offline_dataset_status = f"⚠️ 数据集未加载 | 状态 等待连接 | 时间: {current_time}"
            self.update_fixed_display_area('offline_dataset', offline_dataset_status)
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"降级显示区数据失败 {e}")
    
    def _get_dynamic_anomaly_threshold(self):
        """"""         try:
            # 尝试从系统配置获å?
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    # 基于数据质量动态调整阈值
                    data_quality = self._assess_data_quality(monitor.parsing_status)
                    if data_quality == 'excellent':
                        return 85  # 高质量数据,提高阈值
                    elif data_quality == 'good':
                        return 80  # 良好数据,标准阈值
                    elif data_quality == 'poor':
                        return 75  # 低质量数据,降低阈值
                    else:
                        return 70  # 未知质量,保守阈值
            return 80  # 默认阈值
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态异常检测阈值失败 {e}")
            return 80  # 降级到默认å?
    
    def _get_dynamic_system_health(self):
        """"""         try:
            # 基于多个指标计算系统健康度
            health_score = 0
            total_indicators = 0
            
            # 1. 数据源健康度
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'data_source_panel'):
                data_sources = getattr(self.left_panel.data_source_panel, 'data_sources', {})
                if data_sources:
                    active_sources = [s for s in data_sources.values() if s.get('is_active', False)]
                    source_health = len(active_sources) / len(data_sources) * 100
                    health_score += source_health
                    total_indicators += 1
            
            # 2. 解析状态健康度
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        running_sources = [s for s in parsing_status.values() if s.get('status') == 'running']
                        parsing_health = len(running_sources) / len(parsing_status) * 100
                        health_score += parsing_health
                        total_indicators += 1
            
            # 3. 分析引擎健康度
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'analysis_control_panel'):
                analysis_panel = self.left_panel.analysis_control_panel
                if hasattr(analysis_panel, 'basic_analysis_running') and analysis_panel.basic_analysis_running:
                    health_score += 100
                    total_indicators += 1
                else:
                    health_score += 50  # 未运行但可用
                    total_indicators += 1
            
            # 计算平均健康度
            if total_indicators > 0:
                return int(health_score / total_indicators)
            else:
                return 50  # 默认中等健康度
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态系统健康度失败: {e}")
            return 50  # 降级到默认å?
    
    def _get_dynamic_data_completeness(self):
        """"""         try:
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算数据完整?
                        total_sources = len(parsing_status)
                        complete_sources = 0
                        
                        for status in parsing_status.values():
                            if status.get('status') == 'running' and status.get('data_count', 0) > 0:
                                complete_sources += 1
                        
                        if total_sources > 0:
                            completeness = (complete_sources / total_sources) * 100
                            return int(completeness)
            
            return 0  # 默认无数据
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态数据完整性失败 {e}")
            return 0
    
    def _get_dynamic_data_accuracy(self):
        """"""         try:
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算数据准确?
                        total_sources = len(parsing_status)
                        accurate_sources = 0
                        
                        for status in parsing_status.values():
                            if status.get('status') == 'running':
                                error_count = status.get('error_count', 0)
                                data_count = status.get('data_count', 0)
                                if data_count > 0:
                                    accuracy = max(0, 100 - (error_count / data_count) * 100)
                                    if accuracy >= 90:  # 90%以上认为准确
                                        accurate_sources += 1
                        
                        if total_sources > 0:
                            accuracy = (accurate_sources / total_sources) * 100
                            return int(accuracy)
            
            return 0  # 默认无数据
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态数据准确性失败 {e}")
            return 0
    
    def _get_dynamic_sync_interval(self):
        """"""         try:
            # 基于系统负载动态调整同步间éš?
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算数据源数é‡?
                        source_count = len(parsing_status)
                        if source_count > 5:
                            return 10  # 多数据源,增加间éš?
                        elif source_count > 2:
                            return 5   # 中等数据源,标准间隔
                        else:
                            return 3   # 少数据源,减少间éš?
            
            return 5  # 默认间隔
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态同步间隔失败 {e}")
            return 5
    
    def _get_dynamic_buffer_size(self):
        """"""         try:
            # 基于数据源类型和数量动态调整缓冲区
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'data_source_panel'):
                data_sources = getattr(self.left_panel.data_source_panel, 'data_sources', {})
                if data_sources:
                    # 根据数据源类型调整缓冲区
                    total_sources = len(data_sources)
                    if total_sources > 3:
                        return 2000  # 多数据源,增加缓冲区
                    elif total_sources > 1:
                        return 1000  # 中等数据源,标准缓冲åŒ?
                    else:
                        return 500   # 单数据源,减少缓冲区
            
            return 1000  # 默认缓冲区大å°?
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态缓冲区大小失败: {e}")
            return 1000
    
    def _get_dynamic_time_window(self):
        """"""         try:
            # 基于数据更新频率动态调整时间窗å?
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算平均数据更新频率
                        total_frequency = 0
                        active_sources = 0
                        
                        for status in parsing_status.values():
                            if status.get('status') == 'running':
                                frequency = status.get('speed', 0)
                                if frequency > 0:
                                    total_frequency += frequency
                                    active_sources += 1
                        
                        if active_sources > 0:
                            avg_frequency = total_frequency / active_sources
                            if avg_frequency > 100:  # 高频数据
                                return 5   # 短时间窗å?
                            elif avg_frequency > 10:  # 中频数据
                                return 10  # 标准时间窗口
                            else:  # 低频数据
                                return 20  # 长时间窗å?
            
            return 10  # 默认时间窗口
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取动态时间窗口失败 {e}")
            return 10
    
    def _assess_data_quality(self, parsing_status):
        """"""         try:
            if not parsing_status:
                return 'unknown'
            
            # 计算数据质量指标
            total_sources = len(parsing_status)
            running_sources = 0
            high_quality_sources = 0
            
            for status in parsing_status.values():
                if status.get('status') == 'running':
                    running_sources += 1
                    
                    # 评估单个数据源质é‡?
                    error_rate = status.get('error_count', 0) / max(status.get('data_count', 1), 1)
                    if error_rate < 0.01:  # 错误率小äº?%
                        high_quality_sources += 1
            
            # 计算质量等级
            if running_sources == 0:
                return 'poor'
            elif running_sources == total_sources and high_quality_sources == total_sources:
                return 'excellent'
            elif running_sources >= total_sources * 0.8 and high_quality_sources >= total_sources * 0.6:
                return 'good'
            else:
                return 'poor'
                
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"评估数据质量失败: {e}")
            return 'unknown'
    
    def _update_real_time_status_labels(self):
        """"""         try:
            # 更新同步状态标置­?
            if hasattr(self, 'sync_status_label'):
                sync_status = self._get_sync_status()
                self.sync_status_label.setText(sync_status['text'])
                self.sync_status_label.setStyleSheet(get_status_indicator_style(sync_status['style']))
            
            # 更新性能指标标签
            if hasattr(self, 'network_status_value'):
                network_status = self._get_network_status()
                self.network_status_value.setText(network_status['text'])
                self.network_status_value.setStyleSheet(get_performance_value_style(network_status['style']))
            
            # 更新数据质量标签
            if hasattr(self, 'data_integrity_value'):
                data_quality = self._get_data_quality_status()
                self.data_integrity_value.setText(data_quality['integrity'])
                self.data_consistency_value.setText(data_quality['consistency'])
                self.data_latency_value.setText(data_quality['latency'])
                self.data_throughput_value.setText(data_quality['throughput'])
            
            # 更新系统健康度
            if hasattr(self, 'health_score_progress'):
                current_health = self._get_dynamic_system_health()
                self.health_score_progress.setValue(current_health)
                
                # 根据健康度调整颜è‰?
                if current_health >= 80:
                    self.health_score_progress.setStyleSheet(get_progress_bar_style("success"))
                elif current_health >= 60:
                    self.health_score_progress.setStyleSheet(get_progress_bar_style("warning"))
                else:
                    self.health_score_progress.setStyleSheet(get_progress_bar_style("danger"))
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.error(f"更新实时状态标签失败 {e}")
    
    def _get_sync_status(self):
        """"""         try:
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        running_sources = [s for s in parsing_status.values() if s.get('status') == 'running']
                        if running_sources:
                            return {'text': '同步中, 'style': 'success'}
                        else:
                            return {'text': '未同­', 'style': 'danger'}
            
            return {'text': '等待初始åŒ', 'style': 'warning'}
        except Exception as e:
            return {'text': '状态未置Ÿ', 'style': 'danger'}
    
