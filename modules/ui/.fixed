                    if parsing_status:
                        # 计算实际的数据质量指 ?
                        completeness = self._get_dynamic_data_completeness()
                        accuracy = self._get_dynamic_data_accuracy()
                        
                        return {
                            'integrity': f"{completeness}%",
                            'consistency': '正常' if completeness > 80 else '异常',
                            'latency': f"{self._get_data_latency()}ms",
                            'throughput': f"{self._get_data_throughput()} 数据点/秒
                        }
            
            return {
                'integrity': '检测中...',
                'consistency': '检测中...',
                'latency': '检测中...',
                'throughput': '检测中...'
            }
        except Exception as e:
            return {
                'integrity': '状态未置Ÿ',
                'consistency': '状态未置Ÿ',
                'latency': '状态未置Ÿ',
                'throughput': '状态未置Ÿ?
            }
    
    def _get_data_latency(self):
        """"""         try:
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算平均延迟
                        total_latency = 0
                        active_sources = 0
                        
                        for status in parsing_status.values():
                            if status.get('status') == 'running':
                                latency = status.get('latency', 0)
                                if latency > 0:
                                    total_latency += latency
                                    active_sources += 1
                        
                        if active_sources > 0:
                            return int(total_latency / active_sources)
            
            return 0
        except Exception as e:
            return 0
    
    def _get_data_throughput(self):
        """"""         try:
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'parsing_status_monitor'):
                monitor = self.left_panel.parsing_status_monitor
                if hasattr(monitor, 'parsing_status'):
                    parsing_status = monitor.parsing_status
                    if parsing_status:
                        # 计算总吞吐量
                        total_throughput = 0
                        
                        for status in parsing_status.values():
                            if status.get('status') == 'running':
                                throughput = status.get('speed', 0)
                                total_throughput += throughput
                        
                        return total_throughput
            
            return 0
        except Exception as e:
            return 0
    
    def _get_mqtt_server_config(self):
        """"""         try:
            # 尝试从配置文件或环境变量获取
            import os
            config_file = os.path.join(os.path.dirname(__file__), '..', '..', 'config', 'mqtt_config.json')
            
            if os.path.exists(config_file):
                import json
                with open(config_file, 'r', encoding='utf-8') as f:
                    config = json.load(f)
                    return config.get('server', 'localhost')
            
            # 从环境变量获å?
            return os.environ.get('MQTT_SERVER', 'localhost')
            
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"获取MQTT服务器配置失败 {e}")
            return 'localhost'  # 降级到默认å?
    
    def _get_mqtt_port_config(self):
