    def _refresh_real_system_logs(self):
        """"""         try:
            # 清空日志查看å™?
            self.log_viewer.clear()
            
            # 获取真实系统日志
            real_logs = self._get_real_system_logs()
            
            if not real_logs:
                self.log_viewer.append("📝 暂无系统日志")
