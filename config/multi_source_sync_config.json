{
  "config_version": "1.0.0",
  "last_modified": 1779208915.9811218,
  "general": {
    "system_name": "多源异构数据同步系统",
    "version": "1.0.0",
    "debug_mode": false,
    "log_level": "INFO",
    "max_log_files": 10,
    "log_rotation_size": 100
  },
  "sync_engine": {
    "sync_interval": 0.01,
    "max_concurrent_sources": 10,
    "enable_auto_recovery": true,
    "recovery_timeout": 30.0,
    "enable_adaptive_sync": true,
    "adaptive_threshold": 0.8
  },
  "data_sources": [
    {
      "source_id": "mqtt_source_1",
      "source_type": "mqtt",
      "connection_string": "mqtt://localhost:1883/topic1",
      "enabled": true,
      "priority": 1,
      "timeout": 5.0,
      "retry_count": 3,
      "retry_delay": 1.0
    },
    {
      "source_id": "serial_source_1",
      "source_type": "serial",
      "connection_string": "COM1:9600",
      "enabled": true,
      "priority": 2,
      "timeout": 5.0,
      "retry_count": 3,
      "retry_delay": 1.0
    },
    {
      "source_id": "file_source_1",
      "source_type": "file",
      "connection_string": "/data/source1.txt",
      "enabled": true,
      "priority": 3,
      "timeout": 5.0,
      "retry_count": 3,
      "retry_delay": 1.0
    }
  ],
  "time_alignment": {
    "sync_strategy": "adaptive",
    "max_time_offset": 0.1,
    "quality_threshold": 0.8,
    "enable_ntp_sync": true,
    "ntp_servers": [
      "pool.ntp.org"
    ],
    "sync_interval": 1.0
  },
  "data_fusion": {
    "fusion_algorithm": "weighted_average",
    "quality_weight": 0.7,
    "time_weight": 0.3,
    "enable_adaptive_fusion": true,
    "fusion_threshold": 0.6,
    "max_fusion_delay": 0.5
  },
  "performance": {
    "max_memory_usage": 1024,
    "enable_memory_optimization": true,
    "gc_threshold": 0.8,
    "enable_async_processing": true,
    "max_worker_threads": 8,
    "queue_size": 1000
  },
  "monitoring": {
    "enable_performance_monitoring": true,
    "monitoring_interval": 1.0,
    "enable_alerting": true,
    "alert_thresholds": {
      "cpu_usage": {
        "warning": 70.0,
        "critical": 90.0
      },
      "memory_usage": {
        "warning": 80.0,
        "critical": 95.0
      },
      "response_time": {
        "warning": 100.0,
        "critical": 500.0
      },
      "sync_latency": {
        "warning": 50.0,
        "critical": 200.0
      }
    },
    "enable_metrics_storage": true,
    "metrics_retention_days": 30
  },
  "security": {
    "enable_authentication": false,
    "enable_encryption": false,
    "encryption_algorithm": "AES-256",
    "enable_audit_log": true,
    "max_login_attempts": 5,
    "session_timeout": 3600.0
  },
  "metadata": {
    "created_at": 1779208915.9804876,
    "created_by": "system",
    "description": "多源异构数据同步系统默认配置"
  }
}