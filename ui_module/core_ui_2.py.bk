    def setup_system_monitoring(self):
        """设置系统监控"""
        try:
            import psutil
            import threading
            import time
            
            def monitor_system():
                """系统监控线程"""
                while hasattr(self, 'data_timer') and self.data_timer.isActive():
                    try:
                        # CPU使用率
                        cpu_percent = psutil.cpu_percent(interval=1)
                        
                        # 内存使用率
                        memory = psutil.virtual_memory()
                        memory_percent = memory.percent
                        
                        # 磁盘使用率
                        disk = psutil.disk_usage('/')
                        disk_percent = disk.percent
                        
                        # 更新UI（需要在主线程中执行）
                        self.update_system_metrics.emit(cpu_percent, memory_percent, disk_percent)
                        
                        time.sleep(5)  # 每5秒更新一次
                        
                    except Exception as e:
                        if hasattr(self, 'logger'):
                            self.logger.warning(f"系统监控更新失败: {e}")
                        time.sleep(10)  # 出错后等待更长时间
            
            # 启动监控线程
            monitor_thread = threading.Thread(target=monitor_system, daemon=True)
            monitor_thread.start()
            
            self.logger.info("系统监控已启动")
            
        except ImportError:
            self.logger.warning("psutil模块未安装，系统监控功能不可用")
        except Exception as e:
            self.logger.error(f"启动系统监控失败: {e}")

    def update_system_metrics_ui(self, cpu_percent, memory_percent, disk_percent):
        """更新系统指标UI显示"""
        try:
            if hasattr(self, 'right_tab') and hasattr(self.right_tab, 'system_monitor_tab'):
                # 更新CPU使用率
                if hasattr(self.right_tab.system_monitor_tab, 'cpu_usage_value'):
                    self.right_tab.system_monitor_tab.cpu_usage_value.setText(f"{cpu_percent:.1f}%")
                
                # 更新内存使用率
                if hasattr(self.right_tab.system_monitor_tab, 'memory_usage_value'):
                    self.right_tab.system_monitor_tab.memory_usage_value.setText(f"{memory_percent:.1f}%")
                
                # 更新磁盘使用率
                if hasattr(self.right_tab.system_monitor_tab, 'disk_usage_value'):
                    self.right_tab.system_monitor_tab.disk_usage_value.setText(f"{disk_percent:.1f}%")
                
                # 更新系统健康度评分
                health_score = self._calculate_health_score(cpu_percent, memory_percent, disk_percent)
                if hasattr(self.right_tab.system_monitor_tab, 'health_score_value'):
                    self.right_tab.system_monitor_tab.health_score_value.setText(str(health_score))
                    self.right_tab.system_monitor_tab.health_score_progress.setValue(health_score)
                    
        except Exception as e:
            if hasattr(self, 'logger'):
                self.logger.warning(f"更新系统指标UI失败: {e}")
    
    def _calculate_health_score(self, cpu_percent, memory_percent, disk_percent):
        """计算系统健康度评分 - 增强版"""
        try:
            # 基础系统资源评分
            cpu_score = max(0, 100 - cpu_percent)
            memory_score = max(0, 100 - memory_percent)
            disk_score = max(0, 100 - disk_percent)
            
            # 数据质量评分
            data_quality_score = self._calculate_data_quality_score()
            
            # 连接状态评分
            connection_score = self._calculate_connection_score()
            
            # 分析性能评分
            analysis_score = self._calculate_analysis_performance_score()
            
            # 加权平均计算最终健康度
            health_score = (
                cpu_score * 0.25 +           # CPU权重25%
                memory_score * 0.25 +        # 内存权重25%
                disk_score * 0.15 +          # 磁盘权重15%
                data_quality_score * 0.20 +  # 数据质量权重20%
                connection_score * 0.10 +    # 连接状态权重10%
                analysis_score * 0.05        # 分析性能权重5%
            )
            
            return int(max(0, min(100, health_score)))
            
        except Exception as e:
            self.logger.error(f"计算系统健康度评分失败: {e}")
            return 50  # 返回默认中等评分
    
    def _calculate_data_quality_score(self):
        """计算数据质量评分"""
        try:
            if not hasattr(self, 'data_manager') or not self.data_manager:
                return 50
            
            # 获取数据统计信息
            data_points = 0
            data_integrity = 0.0
            
            if hasattr(self.data_manager, 'data'):
                imu_points = len(self.data_manager.data.get('imu', {}).get('timestamps', []))
                cnap_points = len(self.data_manager.data.get('cnap', {}).get('timestamps', []))
                data_points = imu_points + cnap_points
            
            if hasattr(self.data_manager, 'data_integrity'):
                data_integrity = self.data_manager.data_integrity
            
            # 根据数据点数量和质量计算评分
            if data_points > 1000 and data_integrity > 0.9:
                return 100
            elif data_points > 500 and data_integrity > 0.8:
                return 85
            elif data_points > 100 and data_integrity > 0.7:
                return 70
            elif data_points > 50 and data_integrity > 0.6:
                return 55
            else:
                return 40
                
        except Exception as e:
            self.logger.error(f"计算数据质量评分失败: {e}")
            return 50
    
    def _calculate_connection_score(self):
        """计算连接状态评分"""
        try:
            if not hasattr(self, 'data_manager') or not self.data_manager:
                return 50
            
            # 检查主数据源连接状态
            main_connected = getattr(self.data_manager, 'is_connected', False)
            
            # 检查多源数据连接状态
            multi_source_connected = False
            if hasattr(self, 'data_sources'):
                connected_sources = sum(1 for source_info in self.data_sources.values() 
       if source_info.get("is_connected", False))
                multi_source_connected = connected_sources > 0
            
            # 根据连接状态计算评分
            if main_connected and multi_source_connected:
                return 100
            elif main_connected or multi_source_connected:
                return 75
            else:
                return 25
                
        except Exception as e:
            self.logger.error(f"计算连接状态评分失败: {e}")
            return 50
    
    def _calculate_analysis_performance_score(self):
        """计算分析性能评分"""
        try:
            if not hasattr(self, 'analyzer') or not self.analyzer:
                return 50
            
            # 检查分析器状态
            analyzer_running = getattr(self.analyzer, 'is_running', False)
            
            # 检查分析结果质量
            analysis_results_count = 0
            if hasattr(self.analyzer, 'analysis_results_history'):
                analysis_results_count = len(self.analyzer.analysis_results_history)
            
            # 根据分析状态和结果数量计算评分
            if analyzer_running and analysis_results_count > 100:
                return 100
            elif analyzer_running and analysis_results_count > 50:
                return 85
            elif analyzer_running and analysis_results_count > 10:
                return 70
            elif analyzer_running:
                return 60
            else:
                return 40
                
        except Exception as e:
            self.logger.error(f"计算分析性能评分失败: {e}")
            return 50

