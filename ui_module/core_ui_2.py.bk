            # 连接信号
            def on_add_source():
                source_type = source_type_combo.currentText()
                transmission_type = transmission_combo.currentText()
                
                # 创建数据源配置
                params = {
                    'host': host_edit.text(),
                    'port': port_edit.text(),
                    'topic': topic_edit.text()
                }
                
                # 添加到数据源列表
                self.add_source(transmission_type.lower(), params)
                
                # 刷新显示
                sources_info = "当前配置的数据源:\n"
                for source_id, source_info in self.sources.items():
                    status = "🟢 活动" if source_info.get("is_active", False) else "⚪ 非活动"
                    sources_info += f"\nID {source_id}: {source_info['type']} - {status}"
                    if 'params' in source_info:
                        for key, value in source_info['params'].items():
                            sources_info += f"\n  {key}: {value}"
                
                sources_text.setText(sources_info)
                
                QMessageBox.information(config_dialog, "成功", f"数据源已添加:\n类型: {source_type}\n传输: {transmission_type}")
            
            def on_refresh_sources():
                sources_info = "当前配置的数据源:\n"
                if self.sources:
                    for source_id, source_info in self.sources.items():
                        status = "🟢 活动" if source_info.get("is_active", False) else "⚪ 非活动"
                        sources_info += f"\nID {source_id}: {source_info['type']} - {status}"
                        if 'params' in source_info:
                            for key, value in source_info['params'].items():
 sources_info += f"\n  {key}: {value}"
                else:
                    sources_info += "\n暂无配置的数据源"
                
                sources_text.setText(sources_info)
            
            def on_test_connection():
                QMessageBox.information(config_dialog, "测试连接", "连接测试功能正在开发中...")
            
            def on_apply_config():
                QMessageBox.information(config_dialog, "应用配置", "配置已应用并保存！")
            
            def on_close():
                config_dialog.accept()
            
            add_btn.clicked.connect(on_add_source)
            refresh_btn.clicked.connect(on_refresh_sources)

    
    def update_multi_source_status(self, status_info: dict):
        """更新多源管理状态显示"""
        try:
            if 'system_status' in status_info:
                self.multi_source_status_label.setText(status_info['system_status'])
                if '运行中' in status_info['system_status']:
                    self.multi_source_status_label.setStyleSheet("color: #28a745; font-size: 11px; font-weight: bold;")
                elif '错误' in status_info['system_status']:
                    self.multi_source_status_label.setStyleSheet("color: #dc3545; font-size: 11px; font-weight: bold;")
                else:
                    self.multi_source_status_label.setStyleSheet("color: #6c757d; font-size: 11px;")
            
            if 'sync_status' in status_info:
                self.multi_source_sync_label.setText(status_info['sync_status'])
                if '同步中' in status_info['sync_status']:
                    self.multi_source_sync_label.setStyleSheet("color: #17a2b8; font-size: 11px; font-weight: bold;")
                elif '错误' in status_info['sync_status']:
                    self.multi_source_sync_label.setStyleSheet("color: #dc3545; font-size: 11px; font-weight: bold;")
                else:
                    self.multi_source_sync_label.setStyleSheet("color: #6c757d; font-size: 11px;")
            
            if 'health_status' in status_info:
                self.multi_source_health_label.setText(status_info['health_status'])
                if '健康' in status_info['health_status']:
                    self.multi_source_health_label.setStyleSheet("color: #28a745; font-size: 11px; font-weight: bold;")
                elif '警告' in status_info['health_status']:
                    self.multi_source_health_label.setStyleSheet("color: #ffc107; font-size: 11px; font-weight: bold;")
                elif '错误' in status_info['health_status']:
                    self.multi_source_health_label.setStyleSheet("color: #dc3545; font-size: 11px; font-weight: bold;")
                else:
                    self.multi_source_health_label.setStyleSheet("color: #6c757d; font-size: 11px;")
                    
        except Exception as e:
            print(f"更新多源管理状态显示失败: {e}")
    
    # === 高级分析控制方法 ===
    def on_advanced_analysis_start(self):
        """处理高级分析开始训练请求"""
        try:
            # 检查基础分析是否已完成
            if not self.analysis_running:
                QMessageBox.warning(
                    self, 
                    "高级分析启动失败", 
                    "请先完成基础分析，收集足够的数据后再启动高级分析训练。"
                )
                return
            
            # 显示高级分析启动确认
            QMessageBox.information(
                self, 
                "高级分析启动", 
                "正在启动机器学习模型训练...\n\n"
                "训练参数:\n"
                f"- 自动训练: {'是' if self.advanced_analysis_control.get_auto_training() else '否'}\n"
                f"- 交叉验证: {'是' if self.advanced_analysis_control.get_cross_validation() else '否'}\n"
                f"- 算法比较: {'是' if self.advanced_analysis_control.get_compare_algorithms() else '否'}\n\n"
                "请等待训练完成..."
            )
            
            # 更新高级分析状态
            self.advanced_analysis_control.set_training_state(True)
            self.advanced_analysis_control.update_advanced_analysis_status("训练中")
            
            # 发送高级分析开始信号
            self.advanced_analysis_started.emit()
            
        except Exception as e:
            QMessageBox.critical(
                self, 
                "高级分析启动失败", 
                f"启动高级分析时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    def on_advanced_analysis_stop(self):
        """处理高级分析停止训练请求"""
        try:
            # 显示高级分析停止确认
            QMessageBox.information(
                self, 
                "高级分析停止", 
                "正在停止机器学习模型训练...\n\n"
                "已收集的训练数据将保存，下次可以继续训练。"
            )
            
            # 更新高级分析状态
            self.advanced_analysis_control.set_training_state(False)
            self.advanced_analysis_control.update_advanced_analysis_status("已停止")
            
            # 发送高级分析停止信号
            self.advanced_analysis_stopped.emit()
            
        except Exception as e:
            QMessageBox.critical(
                self, 
                "高级分析停止失败", 
                f"停止高级分析时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    def on_model_load_requested(self):
        """处理模型加载请求"""
        try:
            # 显示模型加载对话框
            QMessageBox.information(
                self, 
                "模型加载", 
                "正在加载预训练模型...\n\n"
                "请选择要加载的模型文件。"
            )
            
            # 这里可以添加文件选择对话框
            # 暂时模拟加载成功
            self.advanced_analysis_control.update_model_status("已加载")
            self.advanced_analysis_control.update_model_accuracy(85.5)
            self.advanced_analysis_control.update_model_algorithm("随机森林")
            
        except Exception as e:
            QMessageBox.critical(
                self, 
                "模型加载失败", 
                f"加载模型时出现错误:\n{str(e)}\n\n请检查模型文件后重试。"
            )
    
    def on_model_unload_requested(self):
        """处理模型卸载请求"""
        try:
            # 显示模型卸载确认
            QMessageBox.information(
                self, 
                "模型卸载", 
                "正在卸载当前模型...\n\n"
                "模型将保存到本地，下次可以重新加载。"
            )
            
            # 更新模型状态
            self.advanced_analysis_control.update_model_status("未训练")
            self.advanced_analysis_control.update_model_accuracy(0.0)
            self.advanced_analysis_control.update_model_algorithm("无")
            
        except Exception as e:
            QMessageBox.critical(
                self, 
                "模型卸载失败", 
                f"卸载模型时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    # === 统一数据源管理面板信号处理方法 ===
    def _on_unified_data_source_selected(self, sources: list):
        """处理统一数据源管理面板的数据源选择信号"""
        try:
            self.logger.info(f"统一数据源管理面板 - 数据源选择变化: {sources}")
            self.selected_sources = sources.copy()
            self.data_sources_selected.emit(sources)
            
            # 更新原有UI状态（如果存在）
            if hasattr(self, 'multi_source_status_label'):
                if sources:
                    self.multi_source_status_label.setText(f"已选择 {len(sources)} 个数据源")
                else:
                    self.multi_source_status_label.setText("未选择数据源")
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源选择信号失败: {e}")
    
    def _on_unified_data_source_changed(self, source_id: str, config: dict):
        """处理统一数据源管理面板的数据源配置变化信号"""
        try:
            self.logger.info(f"统一数据源管理面板 - 数据源配置变化: {source_id} - {config}")
            
            # 更新原有UI状态（如果存在）
            if hasattr(self, 'source_status_label'):
                self.source_status_label.setText("已配置")
                self.source_status_label.setStyleSheet("color: #28a745; font-size: 11px;")
                
        except Exception as e:
            self.logger.error(f"处理统一数据源配置变化信号失败: {e}")
    
    def _on_unified_analysis_toggled(self, enabled: bool):
        """处理统一数据源管理面板的分析开关信号"""
        try:
            self.logger.info(f"统一数据源管理面板 - 分析开关: {enabled}")
            
            # 转发到原有的分析系统
            self.analysis_toggled.emit(enabled, "unified")
            
            # 更新原有UI状态（如果存在）
            if hasattr(self, 'analysis_btn'):
                if enabled:
                    self.analysis_btn.setText("⏸️ 暂停分析")
                    self.analysis_running = True
                else:
                    self.analysis_btn.setText("▶️ 开始分析")
                    self.analysis_running = False
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源分析开关信号失败: {e}")
    
    def _on_unified_record_toggled(self, enabled: bool):
        """处理统一数据源管理面板的记录开关信号"""
        try:
            self.logger.info(f"统一数据源管理面板 - 记录开关: {enabled}")
            
            # 转发到原有的记录系统
            self.record_toggled.emit(enabled)
            
            # 更新原有UI状态（如果存在）
            if hasattr(self, 'record_btn'):
                if enabled:
                    self.record_btn.setText("⏸️ 停止记录")
                    self.record_running = True
                else:
                    self.record_btn.setText("🔴 开始记录")
                    self.record_running = False
                    
        except Exception as e:
            self.logger.error(f"处理统一数据源记录开关信号失败: {e}")
    
    def get_unified_panel(self):
        """获取统一数据源管理面板实例"""
        if hasattr(self, 'unified_data_source_panel'):
            return self.unified_data_source_panel
        return None
    
    def refresh_unified_panel(self):
        """刷新统一数据源管理面板"""
        try:
            if hasattr(self, 'unified_data_source_panel'):
                self.unified_data_source_panel._refresh_sources_list()
                self.logger.info("统一数据源管理面板已刷新")
            else:
                self.logger.warning("统一数据源管理面板未初始化")
        except Exception as e:
            self.logger.error(f"刷新统一数据源管理面板失败: {e}")

# 数据源选择对话框
class DataSourceSelectionDialog(QDialog):
    def __init__(self, parent=None, selected_sources=None, available_sources=None):
        super().__init__(parent)
        print(f"DEBUG: DataSourceSelectionDialog 初始化，parent: {parent}")  # 调试信息
        
        # 获取当前语言，从父窗口或使用默认语言
        if hasattr(parent, 'current_lang'):
            current_lang = parent.current_lang
        elif hasattr(parent, 'parent') and hasattr(parent.parent(), 'current_lang'):
            current_lang = parent.parent().current_lang
        else:
            current_lang = 'en'  # 默认使用英文
            
        print(f"DEBUG: 当前语言: {current_lang}")  # 调试信息
        self.current_lang = current_lang
        self.setWindowTitle(translations[current_lang]['select_data_sources'])
        self.selected_sources = selected_sources if selected_sources else []
        self.available_sources = available_sources if available_sources else [
            'imu', 'cnap'  # 当前可用数据源，未来可扩展
        ]
        
        print(f"DEBUG: 选中的数据源: {self.selected_sources}")  # 调试信息
        print(f"DEBUG: 可用数据源: {self.available_sources}")  # 调试信息
        
        self.init_ui()
        print("DEBUG: DataSourceSelectionDialog UI 初始化完成")  # 调试信息
        
    def init_ui(self):
        print("DEBUG: 开始初始化 DataSourceSelectionDialog UI")  # 调试信息
        layout = QVBoxLayout(self)
        
        # 数据源列表
        from PySide6.QtWidgets import QListWidget, QListWidgetItem
        self.source_list = QListWidget()
        self.source_list.setSelectionMode(QListWidget.ExtendedSelection)
        
        # 添加数据源项
        source_display_names = {
            'imu': 'IMU',
            'cnap': 'CNAP'
        }
        
        print(f"DEBUG: 正在添加数据源项...")  # 调试信息
        for source in self.available_sources:
            item = QListWidgetItem(source_display_names.get(source, source.upper()))
            item.setData(Qt.UserRole, source)
            item.setSelected(source in self.selected_sources)
            self.source_list.addItem(item)
            print(f"DEBUG: 添加数据源项: {source}")  # 调试信息
        
        layout.addWidget(QLabel(translations[self.current_lang]['data_sources']))
        layout.addWidget(self.source_list)
        
        # 全选/取消全选按钮
        btn_layout = QHBoxLayout()
        self.select_all_btn = QPushButton(translations[self.current_lang]['select_all'])
        self.deselect_all_btn = QPushButton(translations[self.current_lang]['deselect_all'])
        
        self.select_all_btn.clicked.connect(self.select_all)
        self.deselect_all_btn.clicked.connect(self.deselect_all)
        
        btn_layout.addWidget(self.select_all_btn)
        btn_layout.addWidget(self.deselect_all_btn)
        layout.addLayout(btn_layout)
        
        # 确认/取消按钮
        dialog_buttons = QDialogButtonBox(
            QDialogButtonBox.Ok | QDialogButtonBox.Cancel,
            Qt.Horizontal, self
        )
        dialog_buttons.accepted.connect(self.accept)
        dialog_buttons.rejected.connect(self.reject)
        
        # 翻译按钮文本
        dialog_buttons.button(QDialogButtonBox.Ok).setText(translations[self.current_lang]['ok'])
        dialog_buttons.button(QDialogButtonBox.Cancel).setText(translations[self.current_lang]['cancel'])
        
        layout.addWidget(dialog_buttons)
        
    def select_all(self):
        """全选所有数据源"""
        for i in range(self.source_list.count()):
            self.source_list.item(i).setSelected(True)
        
        # 显示全选确认
        selected_count = self.source_list.count()
        QMessageBox.information(
            self, 
            "全选完成", 
            f"已全选 {selected_count} 个数据源:\n\n" + 
            "\n".join([self.source_list.item(i).text() for i in range(selected_count)]) +
            "\n\n点击 '确定' 按钮确认选择。"
        )
            
    def deselect_all(self):
        """取消全选所有数据源"""
        for i in range(self.source_list.count()):
            self.source_list.item(i).setSelected(False)
        
        # 显示取消全选确认
        QMessageBox.information(
            self, 
            "取消全选完成", 
            "已取消选择所有数据源。\n\n请手动选择需要的数据源。"
        )
        
    def get_selected_sources(self):
        """获取选中的数据源"""
        selected = []
        for i in range(self.source_list.count()):
            if self.source_list.item(i).isSelected():
                selected.append(self.source_list.item(i).data(Qt.UserRole))
        
        # 验证选择结果
        if not selected:
            QMessageBox.warning(
                self, 
                "未选择数据源", 
                "请至少选择一个数据源。\n\n可用的数据源:\n- IMU (惯性测量单元)\n- CNAP (心血管监测)"
            )
            return []
        
        # 显示选择确认
        source_names = [self.source_list.item(i).text() for i in range(self.source_list.count()) 
                       if self.source_list.item(i).isSelected()]
        
        QMessageBox.information(
            self, 
            "数据源选择确认", 
            f"已选择以下数据源:\n\n" + "\n".join(source_names) + 
            f"\n\n总计: {len(selected)} 个数据源\n\n点击 '确定' 按钮继续。"
        )
        
        return selected
    


class RightTabContainer(QTabWidget):
    """右侧标签页容器组件"""
    def __init__(self, parent=None):
        super().__init__(parent)
        self.analyzer = None
        self.init_ui()
        
    def set_analyzer(self, analyzer):
        self.analyzer = analyzer
        self.analysis_vis_tab.set_analyzer(analyzer)
        
    def init_ui(self):
        # 设置标签页样式
        self.setTabShape(QTabWidget.Rounded)
        
        # 设置标签页美化样式 - 优化字体大小和视觉效果
        self.setStyleSheet("""
            QTabWidget::pane {
                border: 3px solid #e0e0e0;
                border-radius: 12px;
                background-color: #ffffff;
                margin-top: 8px;
                padding: 10px;
            }
            QTabWidget::tab-bar {
                alignment: left;
            }
            QTabBar::tab {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #f8f9fa, stop:1 #e9ecef);
                border: 2px solid #dee2e6;
                border-bottom: none;
                border-top-left-radius: 12px;
                border-top-right-radius: 12px;
                padding: 12px 20px;  /* 增加内边距 */
                margin-right: 4px;
                font-weight: bold;
                font-size: 16px;  /* 进一步增大标签页字号 */
                min-width: 140px;  /* 增加最小宽度 */
                min-height: 40px;  /* 增加最小高度 */
            }
            QTabBar::tab:hover {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #e3f2fd, stop:1 #bbdefb);
                border-color: #2196f3;
                transform: scale(1.05);
            }
            QTabBar::tab:selected {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #2196f3, stop:1 #1976d2);
                color: white;
                border-color: #1976d2;
                font-size: 17px;  /* 选中标签使用更大字体 */
            }
            QTabBar::tab:disabled {
                background: #f5f5f5;
                color: #999999;
            }
        """)
        
        # 实时监控标签页
        self.monitoring_tab = QWidget()
        self.init_monitoring_tab()
        self.addTab(self.monitoring_tab, f"📊 {translations['en']['real_time_monitoring']}")
        
        # 系统监控标签页 - 新增
        self.system_monitor_tab = QWidget()
        self.init_system_monitor_tab()
        self.addTab(self.system_monitor_tab, f"🖥️ {translations['en']['system_monitoring']}")
        
        # 综合监控标签页 - 新增
        if ComprehensiveMonitoringWidget:
            self.comprehensive_monitoring_tab = ComprehensiveMonitoringWidget()
            self.addTab(self.comprehensive_monitoring_tab, f"🔍 {translations['en']['comprehensive_monitoring']}")
        else:
            self.comprehensive_monitoring_tab = QWidget()
            self.init_comprehensive_monitoring_placeholder()
            self.addTab(self.comprehensive_monitoring_tab, f"🔍 {translations['en']['comprehensive_monitoring']}")
        
        # 融合分析标签页 - 新增
        if FusedAnalysisWidget:
            self.fused_analysis_tab = FusedAnalysisWidget()
            self.addTab(self.fused_analysis_tab, f"🤖 {translations['en']['fused_analysis']}")
        else:
            self.fused_analysis_tab = QWidget()
            self.init_fused_analysis_placeholder()
            self.addTab(self.fused_analysis_tab, f"🤖 {translations['en']['fused_analysis']}")
        
        # 配置标签页已移除，配置管理功能移至菜单
        
        # 数据源配置标签页
        self.data_source_tab = QWidget()
        self.init_data_source_tab()
        self.addTab(self.data_source_tab, f"📡 {translations['en']['data_source']}")
        
        # 行为分析标签页
        self.analysis_tab = QWidget()
        self.init_analysis_tab()
        self.addTab(self.analysis_tab, f"🧠 {translations['en']['behavior_analysis']}")
        
        # 分析结果可视化标签页
        self.analysis_vis_tab = AnalysisVisualizationWidget()
        self.addTab(self.analysis_vis_tab, f"📈 {translations['en']['analysis_visualization']}")
        
        # IMU数据可视化标签页
        self.imu_vis_tab = IMUVisualizationWidget()
        self.addTab(self.imu_vis_tab, f"📱 {translations['en']['imu_visualization']}")
        
        # CNAP数据可视化标签页
        self.cnap_vis_tab = CNAPVisualizationWidget()
        self.addTab(self.cnap_vis_tab, f"💓 {translations['en']['cnap_visualization']}")
        

        
    def init_monitoring_tab(self):
