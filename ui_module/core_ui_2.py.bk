        # 如果都导入失败，创建一个简单的替代类
        class AdvancedAnalysisControl(QWidget):
            # 定义信号 - 必须在类级别定义
            start_training_requested = Signal()
            stop_training_requested = Signal()
            load_model_requested = Signal()
            unload_model_requested = Signal()
            
            def __init__(self):
                super().__init__()
                self.setMinimumHeight(120)  # 增加高度以容纳更大的字体
                self.setStyleSheet("""
                    QWidget {
                        border: 2px solid #6c757d;
                        border-radius: 8px;
                        background-color: #f8f9fa;
                        padding: 15px;
                    }
                """)
                
                # 创建简单的UI
                layout = QVBoxLayout(self)
                layout.setContentsMargins(15, 15, 15, 15)  # 增加边距
                layout.setSpacing(12)  # 增加组件间距
                
                # 标题 - 使用更大的字体
                title_label = QLabel("🤖 高级智能分析 (替代组件)")
                title_label.setStyleSheet("""
                    font-weight: bold; 
                    color: #6f42c1; 
                    font-size: 16px;  /* 增大字体 */
                    padding: 8px;
                    background-color: #e9ecef;
                    border-radius: 6px;
                """)
                layout.addWidget(title_label)
                
                # 状态标签 - 使用更大的字体
                self.status_label = QLabel("状态: 未初始化")
                self.status_label.setStyleSheet("""
                    color: #6c757d; 
                    font-size: 14px;  /* 增大字体 */
                    font-weight: bold;
                    padding: 6px;
                """)
                layout.addWidget(self.status_label)
                
                # 说明文字 - 使用更大的字体
                info_label = QLabel("💡 这是替代组件，原组件导入失败")
                info_label.setStyleSheet("""
                    color: #6c757d; 
                    font-size: 13px;  /* 增大字体 */
                    font-style: italic;
                    padding: 6px;
                    background-color: #f8f9fa;
                    border-radius: 4px;
                """)
                layout.addWidget(info_label)
            
            # 添加其他必要的方法
            def set_training_state(self, state):
                if state:
                    self.status_label.setText("状态: 训练中")
                    self.status_label.setStyleSheet("""
                        color: #6f42c1; 
                        font-size: 14px; 
                        font-weight: bold;
                        padding: 6px;
                        background-color: #e8f4fd;
                        border-radius: 4px;
                    """)
                else:
                    self.status_label.setText("状态: 已停止")
                    self.status_label.setStyleSheet("""
                        color: #6c757d; 
                        font-size: 14px; 
                        font-weight: bold;
                        padding: 6px;
                    """)
            
            def update_advanced_analysis_status(self, status):
                self.status_label.setText(f"状态: {status}")
            
            def update_model_status(self, status):
                pass
            
            def update_model_accuracy(self, accuracy):
                pass
            
            def update_model_algorithm(self, algorithm):
