        self.main_layout.addStretch()
        

        

        

        
        # 信号连接 - 管理模块按钮
        self.vehicle_management_btn.clicked.connect(self.open_vehicle_management)
        self.driver_management_btn.clicked.connect(self.open_driver_management)
        self.fleet_management_btn.clicked.connect(self.open_fleet_management)
        self.trip_management_btn.clicked.connect(self.open_trip_management)
        

    

            

            

            
    def on_analysis_toggled(self):
        """切换分析状态"""
        try:
            self.analysis_running = not self.analysis_running
            if self.analysis_running:
                # 开始分析
                self.analysis_btn.setText("⏸️ 暂停分析")
                self.analysis_btn.setStyleSheet("""
                    QPushButton {
                        background-color: #ffc107;
                        color: #212529;
                        border: none;
                        padding: 10px 20px;
                        border-radius: 5px;
                        font-size: 12px;
                        font-weight: bold;
                    }
                    QPushButton:hover {
                        background-color: #e0a800;
                    }
                """)
                self.stop_analysis_btn.setEnabled(False)
                
                # 显示进度条
                self.analysis_progress.setVisible(True)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("基础分析中")
                self.analysis_status_label.setStyleSheet("color: #17a2b8; font-size: 11px;")
                
                # 发送信号
                self.analysis_toggled.emit(True, "basic")
                
                # 显示开始提示
                QMessageBox.information(
                    self, 
                    "基础分析已开始", 
                    f"已开始基础模式分析\n\n分析参数:\n- 灵敏度: {self.sensitivity_slider.value()}\n- 置信度阈值: {self.threshold_edit.text()}\n\n请等待分析完成..."
                )
            else:
                # 停止分析
                self.analysis_btn.setText("▶️ 开始分析")
                self.analysis_btn.setStyleSheet("""
                    QPushButton {
                        background-color: #17a2b8;
                        color: white;
                        border: none;
                        padding: 10px 20px;
                        border-radius: 5px;
                        font-size: 12px;
                        font-weight: bold;
                    }
                    QPushButton:hover {
                        background-color: #138496;
                    }
                """)
                self.stop_analysis_btn.setEnabled(False)
                
                # 隐藏进度条
                self.analysis_progress.setVisible(False)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("已停止")
                self.analysis_status_label.setStyleSheet("color: #6c757d; font-size: 11px;")
                
                # 发送信号
                self.analysis_toggled.emit(False, "")
                
                # 显示停止提示
                QMessageBox.information(
                    self, 
                    "分析已停止", 
                    "分析已停止\n\n您可以查看已分析的结果，或重新开始分析。"
                )
        except Exception as e:
            QMessageBox.critical(
                self, 
                "分析状态切换失败", 
                f"切换分析状态时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    def on_stop_analysis(self):
        """停止分析"""
        try:
            if self.analysis_running:
                # 停止分析
                self.analysis_running = False
                self.analysis_btn.setText("▶️ 开始分析")
                self.analysis_btn.setStyleSheet("""
                    QPushButton {
                        background-color: #17a2b8;
                        color: white;
                        border: none;
                        padding: 10px 20px;
                        border-radius: 5px;
                        font-size: 12px;
                        font-weight: bold;
                    }
                    QPushButton:hover {
                        background-color: #138496;
                    }
                """)
                self.stop_analysis_btn.setEnabled(False)
                
                # 隐藏进度条
                self.analysis_progress.setVisible(False)
                self.analysis_progress.setValue(0)
                
                # 更新状态
                self.analysis_status_label.setText("已停止")
                self.analysis_status_label.setStyleSheet("color: #6c757d; font-size: 11px;")
                
                # 发送信号
                self.analysis_toggled.emit(False, "")
                
                # 显示停止提示
                QMessageBox.information(
                    self, 
                    "分析已停止", 
                    "分析已通过暂停按钮停止\n\n您可以查看已分析的结果，或重新开始分析。"
                )
        except Exception as e:
            QMessageBox.critical(
                self, 
                "停止分析失败", 
                f"停止分析时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    def on_record_toggled(self):
