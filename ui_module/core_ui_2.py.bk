    def show_help_dialog(self):
        """显示帮助对话框"""
        QMessageBox.information(self, "Help", translations[CoreUIMainWindow.current_lang]['help_text'])
    
    def cleanup(self):
        """清理资源，停止所有定时器"""
        try:
            self.logger.info("开始清理Core UI资源")
            
            # 禁用自动优化
            if hasattr(self, 'auto_optimization_enabled') and self.auto_optimization_enabled:
                self._disable_auto_optimization()
            
            # 停止所有定时器
            if hasattr(self, 'optimization_timer') and self.optimization_timer:
                if self.optimization_timer.isActive():
                    self.optimization_timer.stop()
                    self.logger.debug("停止优化定时器")
                self.optimization_timer.deleteLater()
                self.optimization_timer = None
            
            # 重置状态
            self.auto_optimization_enabled = False
            self._optimization_in_progress = False
            
            self.logger.info("Core UI资源清理完成")
            
        except Exception as e:
            self.logger.error(f"清理Core UI资源时出错: {e}")
    
    def closeEvent(self, event):
        """窗口关闭事件"""
        try:
            self.logger.info("Core UI窗口关闭事件触发")
            
            # 清理资源
            self.cleanup()
            
            # 调用父类的closeEvent
            super().closeEvent(event)
            
        except Exception as e:
            self.logger.error(f"处理窗口关闭事件时出错: {e}")
            # 确保事件被处理
            event.accept()

    def apply_high_dpi_styles(self):
        """应用高DPI样式优化，解决字体过小和按钮显示问题"""
        try:
            self.logger.info("开始应用高DPI样式优化")
            
            # 检测系统DPI并设置合适的缩放比例
            import platform
            if platform.system() == "Windows":
                # Windows系统下检测DPI
                try:
                    import ctypes
                    user32 = ctypes.windll.user32
                    dpi = user32.GetDpiForSystem()
                    if dpi >= 144:  # 150%及以上缩放
                        scale_factor = 1.8
                    elif dpi >= 120:  # 125%缩放
                        scale_factor = 1.5
                    else:  # 100%缩放
                        scale_factor = 1.2
                except:
                    scale_factor = 1.5  # 默认1.5倍
            else:
                scale_factor = 1.5  # 非Windows系统默认1.5倍
            
            self.logger.info(f"检测到DPI缩放比例: {scale_factor:.2f}")
            
            # 计算适配的字体大小
            base_font_size = 14  # 提高基础字体大小
            adjusted_font_size = int(base_font_size * scale_factor)
            
            # 计算适配的按钮尺寸
            base_button_height = 40  # 提高基础按钮高度
            adjusted_button_height = int(base_button_height * scale_factor)
            
            # 应用高DPI优化的全局样式
            high_dpi_stylesheet = f"""
            /* 全局字体大小优化 */
            QWidget {{
                font-size: {adjusted_font_size}px;
                font-family: 'Microsoft YaHei', 'Segoe UI', sans-serif;
            }}
            
            /* 按钮样式优化 - 解决色块和反色显示问题 */
            QPushButton {{
                font-size: {adjusted_font_size}px;
                font-weight: bold;
                padding: {int(10 * scale_factor)}px {int(20 * scale_factor)}px;
                border: 3px solid #007bff;
                border-radius: {int(8 * scale_factor)}px;
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #ffffff, stop:1 #f8f9fa);
                color: #007bff;
                min-height: {adjusted_button_height}px;
                min-width: {int(100 * scale_factor)}px;
            }}
            
            QPushButton:hover {{
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #007bff, stop:1 #0056b3);
                color: #ffffff;
                border-color: #0056b3;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }}
            
            QPushButton:pressed {{
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #0056b3, stop:1 #004085);
                border-color: #004085;
                color: #ffffff;
                transform: translateY(0px);
            }}
            
            QPushButton:disabled {{
                background: #e9ecef;
                border-color: #dee2e6;
                color: #adb5bd;
            }}
            
            /* 输入框样式优化 */
            QLineEdit, QTextEdit, QComboBox {{
                font-size: {adjusted_font_size}px;
                padding: {int(8 * scale_factor)}px {int(12 * scale_factor)}px;
                border: 3px solid #ced4da;
                border-radius: {int(6 * scale_factor)}px;
                min-height: {int(35 * scale_factor)}px;
                min-width: {int(100 * scale_factor)}px;
                background-color: #ffffff;
            }}
            
            QLineEdit:focus, QTextEdit:focus, QComboBox:focus {{
                border-color: #007bff;
                border-width: 4px;
            }}
            
            /* 标签页样式优化 */
            QTabBar::tab {{
                font-size: {int(14 * scale_factor)}px;
                font-weight: bold;
                padding: {int(10 * scale_factor)}px {int(20 * scale_factor)}px;
                min-height: {int(35 * scale_factor)}px;
                min-width: {int(100 * scale_factor)}px;
            }}
            
            /* 分组框样式优化 */
            QGroupBox {{
                font-size: {int(14 * scale_factor)}px;
                font-weight: bold;
                margin-top: {int(15 * scale_factor)}px;
                padding-top: {int(10 * scale_factor)}px;
            }}
            
            /* 滚动条样式优化 */
            QScrollBar:vertical {{
                width: {int(18 * scale_factor)}px;
                background-color: #f8f9fa;
                border-radius: {int(9 * scale_factor)}px;
            }}
            
            QScrollBar::handle:vertical {{
                min-height: {int(25 * scale_factor)}px;
                background-color: #ced4da;
                border-radius: {int(9 * scale_factor)}px;
            }}
            
            QScrollBar::handle:vertical:hover {{
                background-color: #adb5bd;
            }}
            
            /* 标签样式优化 */
            QLabel {{
                font-size: {adjusted_font_size}px;
                color: #495057;
            }}
            
            /* 复选框样式优化 */
            QCheckBox {{
                font-size: {adjusted_font_size}px;
                spacing: {int(12 * scale_factor)}px;
            }}
            
            QCheckBox::indicator {{
                width: {int(22 * scale_factor)}px;
                height: {int(22 * scale_factor)}px;
                border: 3px solid #ced4da;
                border-radius: {int(6 * scale_factor)}px;
            }}
            """
            
            # 应用样式表 - 使用更强的优先级
            self.setStyleSheet(high_dpi_stylesheet)
            
            # 强制刷新所有子部件
            self.update()
            
            # 确保样式被应用
            QApplication.processEvents()
            
            self.logger.info(f"高DPI样式优化应用成功，字体大小: {adjusted_font_size}px，按钮高度: {adjusted_button_height}px")
            
        except Exception as e:
            self.logger.error(f"应用高DPI样式优化失败: {e}")
            # 不抛出异常，避免影响主程序运行