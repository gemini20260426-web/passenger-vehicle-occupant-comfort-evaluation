# 模拟Core模块的相关类和接口
class DataManager:
    """数据管理模块，支持多源数据处理功能"""
    def __init__(self):
        self.source_type = "simulated"  # 数据源类型: simulated, file, serial, mqtt, tcp, udp
        self.connection = None  # 连接对象
        self.selected_sources = ['imu', 'cnap']  # 选中的数据源
        self.data = {
            'imu': {
                'timestamps': [],
                'accelerometer': {'x': [], 'y': [], 'z': []},
                'gyroscope': {'x': [], 'y': [], 'z': []},
                'magnetometer': {'x': [], 'y': [], 'z': []}
            },
            'cnap': {
                'timestamps': [],
                'heart_rate': [],
                'blood_pressure_systolic': [],
                'blood_pressure_diastolic': [],
                'oxygen_level': []
            }
        }
        self.max_data_points = 100  # 最大数据点数量
        self.is_connected = False
        self.is_recording = False
        self.recorded_data = None
        
        # 数据管理状态
        self.data_quality = "未知"
        self.data_sync_status = "未同步"
        self.last_data_update = "无"
        self.data_integrity = 0.0
        
    def connect(self, source_type, params=None):
        """连接到数据源"""
        self.source_type = source_type
        self.disconnect()  # 断开现有连接
        
        try:
            if source_type == "serial":
                import serial
                self.connection = serial.Serial(
                    port=params.get("port", "COM3"),
                    baudrate=int(params.get("baud rate", 9600))
                )
            elif source_type == "mqtt":
                import paho.mqtt.client as mqtt
                self.connection = mqtt.Client()
                self.connection.connect(
                    params.get("broker", "localhost"),
                    int(params.get("port", 1883))
                )
                self.connection.subscribe(params.get("topic", "sensors/data"))
                self.connection.on_message = self._on_mqtt_message
            elif source_type == "tcp":
                import socket
                self.connection = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                self.connection.connect(
                    (params.get("host", "localhost"), 
                     int(params.get("port", 5000)))
                )
            elif source_type == "udp":
                import socket
                self.connection = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                self.connection.bind(
                    (params.get("host", "localhost"), 
                     int(params.get("port", 6000)))
                )
            # simulated和file类型不需要特殊连接处理
            
            self.is_connected = True
            self._update_connection_status("已连接")
            return True
        except Exception as e:
            print(f"Connection failed: {e}")
            self.is_connected = False
            self._update_connection_status("连接失败")
            return False
        
    def disconnect(self):
        """断开数据源连接"""
        if self.connection:
            if self.source_type in ["serial", "tcp"]:
                self.connection.close()
            elif self.source_type == "mqtt":
                self.connection.disconnect()
            self.connection = None
        self.is_connected = False
        self._update_connection_status("已断开")
        return True
        
    def get_latest_data(self):
        """获取最新数据，支持多种数据源类型"""
        if not self.is_connected:
            return None
            
        # 根据不同数据源类型获取数据
        if self.source_type in ["simulated", "file"]:
            # 模拟数据生成
            return self._generate_simulated_data()
        elif self.source_type == "mqtt":
            # MQTT数据已通过回调处理
            return self._get_stored_data()
        elif self.source_type in ["serial", "tcp", "udp"]:
            # 从串口/TCP/UDP读取数据
            return self._read_from_stream()
            
        return None
    
    def set_selected_sources(self, sources):
        """设置选中的数据源"""
        self.selected_sources = sources
        self._update_data_source_status()
        
    def _generate_simulated_data(self):
        """生成模拟数据，根据选中的数据源生成对应数据"""
        timestamp = time.time()
        data = {}
        
        # 根据选中的数据源生成对应数据
        if 'imu' in self.selected_sources:
            imu_data = {
                'timestamp': timestamp,
                'accelerometer': [random.uniform(-2, 2) for _ in range(3)],
                'gyroscope': [random.uniform(-10, 10) for _ in range(3)],
                'magnetometer': [random.uniform(-50, 50) for _ in range(3)]
            }
            data['imu'] = imu_data
            
            # 存储IMU数据
            self._store_imu_data(imu_data)
            
            # 如果正在记录数据，保存到记录数据中
            if self.is_recording:
                if not hasattr(self, 'recorded_data') or not self.recorded_data:
                    self.recorded_data = {'imu': [], 'cnap': []}
                self.recorded_data['imu'].append(imu_data)
        
        if 'cnap' in self.selected_sources:
            cnap_data = {
                'timestamp': timestamp,
                'heart_rate': random.uniform(60, 100),
                'blood_pressure': [random.uniform(90, 140), random.uniform(60, 90)],
                'oxygen_level': random.uniform(95, 100)
            }
            data['cnap'] = cnap_data
            
            # 存储CNAP数据
            self._store_cnap_data(cnap_data)
            
            # 如果正在记录数据，保存到记录数据中
            if self.is_recording:
                if not hasattr(self, 'recorded_data') or not self.recorded_data:
                    self.recorded_data = {'imu': [], 'cnap': []}
                self.recorded_data['cnap'].append(cnap_data)
        
        # 更新数据状态
        self._update_data_status(data)
        return data
    
    def _store_imu_data(self, imu_data):
        """存储IMU数据"""
        self.data['imu']['timestamps'].append(imu_data['timestamp'])
        self.data['imu']['accelerometer']['x'].append(imu_data['accelerometer'][0])
        self.data['imu']['accelerometer']['y'].append(imu_data['accelerometer'][1])
        self.data['imu']['accelerometer']['z'].append(imu_data['accelerometer'][2])
        self.data['imu']['gyroscope']['x'].append(imu_data['gyroscope'][0])
        self.data['imu']['gyroscope']['y'].append(imu_data['gyroscope'][1])
        self.data['imu']['gyroscope']['z'].append(imu_data['gyroscope'][2])
        self.data['imu']['magnetometer']['x'].append(imu_data['magnetometer'][0])
        self.data['imu']['magnetometer']['y'].append(imu_data['magnetometer'][1])
        self.data['imu']['magnetometer']['z'].append(imu_data['magnetometer'][2])
        
        # 如果数据点超过最大值，移除最旧的数据
        if len(self.data['imu']['timestamps']) > self.max_data_points:
            self._trim_imu_data()
    
    def _store_cnap_data(self, cnap_data):
        """存储CNAP数据"""
        self.data['cnap']['timestamps'].append(cnap_data['timestamp'])
        self.data['cnap']['heart_rate'].append(cnap_data['heart_rate'])
        self.data['cnap']['blood_pressure_systolic'].append(cnap_data['blood_pressure'][0])
        self.data['cnap']['blood_pressure_diastolic'].append(cnap_data['blood_pressure'][1])
        self.data['cnap']['oxygen_level'].append(cnap_data['oxygen_level'])
        
        # 如果数据点超过最大值，移除最旧的数据
        if len(self.data['cnap']['timestamps']) > self.max_data_points:
            self._trim_cnap_data()
        
    def _read_from_stream(self):
        """从串口/TCP/UDP流读取数据"""
        try:
            # 实际应用中需要根据协议解析数据
            # 这里简化处理，返回模拟数据
            return self._generate_simulated_data()
        except Exception as e:
            print(f"Error reading from stream: {e}")
            return None
    
    def _on_mqtt_message(self, client, userdata, msg):
        """MQTT消息处理"""
        try:
            data = json.loads(msg.payload.decode())
            # 假设数据格式与我们需要的格式一致
            if 'imu' in data and 'cnap' in data:
                self._store_data(data['imu'], data['cnap'])
                
                if self.is_recording:
                    self.recorded_data['imu'].append(data['imu'])
                    self.recorded_data['cnap'].append(data['cnap'])
        except Exception as e:
            print(f"MQTT message error: {e}")
    
    def _get_stored_data(self):
        """获取已存储的数据"""
        if not self.data['imu']['timestamps']:
            return None
            
        # 返回最新的数据点
        last_idx = len(self.data['imu']['timestamps']) - 1
        return {
            'imu': {
                'timestamp': self.data['imu']['timestamps'][last_idx],
                'accelerometer': [
                    self.data['imu']['accelerometer']['x'][last_idx],
                    self.data['imu']['accelerometer']['y'][last_idx],
                    self.data['imu']['accelerometer']['z'][last_idx]
                ],
                'gyroscope': [
                    self.data['imu']['gyroscope']['x'][last_idx],
                    self.data['imu']['gyroscope']['y'][last_idx],
                    self.data['imu']['gyroscope']['z'][last_idx]
                ],
                'magnetometer': [
                    self.data['imu']['magnetometer']['x'][last_idx],
                    self.data['imu']['magnetometer']['y'][last_idx],
                    self.data['imu']['magnetometer']['z'][last_idx]
                ]
            },
            'cnap': {
                'timestamp': self.data['cnap']['timestamps'][last_idx],
                'heart_rate': self.data['cnap']['heart_rate'][last_idx],
                'blood_pressure': [
                    self.data['cnap']['blood_pressure_systolic'][last_idx],
                    self.data['cnap']['blood_pressure_diastolic'][last_idx]
                ],
                'oxygen_level': self.data['cnap']['oxygen_level'][last_idx]
            }
        }
        
    def _store_data(self, imu_data, cnap_data):
        """存储数据用于图表展示，保持数据点数量在限制范围内"""
        # 存储IMU数据
        self.data['imu']['timestamps'].append(imu_data['timestamp'])
        self.data['imu']['accelerometer']['x'].append(imu_data['accelerometer'][0])
        self.data['imu']['accelerometer']['y'].append(imu_data['accelerometer'][1])
        self.data['imu']['accelerometer']['z'].append(imu_data['accelerometer'][2])
        self.data['imu']['gyroscope']['x'].append(imu_data['gyroscope'][0])
        self.data['imu']['gyroscope']['y'].append(imu_data['gyroscope'][1])
        self.data['imu']['gyroscope']['z'].append(imu_data['gyroscope'][2])
        self.data['imu']['magnetometer']['x'].append(imu_data['magnetometer'][0])
        self.data['imu']['magnetometer']['y'].append(imu_data['magnetometer'][1])
        self.data['imu']['magnetometer']['z'].append(imu_data['magnetometer'][2])
        
        # 存储CNAP数据
        self.data['cnap']['timestamps'].append(cnap_data['timestamp'])
        self.data['cnap']['heart_rate'].append(cnap_data['heart_rate'])
        self.data['cnap']['blood_pressure_systolic'].append(cnap_data['blood_pressure'][0])
        self.data['cnap']['blood_pressure_diastolic'].append(cnap_data['blood_pressure'][1])
        self.data['cnap']['oxygen_level'].append(cnap_data['oxygen_level'])
        
        # 如果数据点超过最大值，移除最旧的数据
        if len(self.data['imu']['timestamps']) > self.max_data_points:
            self._trim_data()
    
    def _trim_imu_data(self):
        """修剪IMU数据，保持在最大数据点数量以内"""
        excess = len(self.data['imu']['timestamps']) - self.max_data_points
        if excess <= 0:
            return
            
        # 修剪IMU数据
        self.data['imu']['timestamps'] = self.data['imu']['timestamps'][excess:]
        for axis in ['x', 'y', 'z']:
            self.data['imu']['accelerometer'][axis] = self.data['imu']['accelerometer'][axis][excess:]
            self.data['imu']['gyroscope'][axis] = self.data['imu']['gyroscope'][axis][excess:]
            self.data['imu']['magnetometer'][axis] = self.data['imu']['magnetometer'][axis][excess:]
    
    def _trim_cnap_data(self):
        """修剪CNAP数据，保持在最大数据点数量以内"""
        excess = len(self.data['cnap']['timestamps']) - self.max_data_points
        if excess <= 0:
            return
            
        # 修剪CNAP数据
        self.data['cnap']['timestamps'] = self.data['cnap']['timestamps'][excess:]
        self.data['cnap']['heart_rate'] = self.data['cnap']['heart_rate'][excess:]
        self.data['cnap']['blood_pressure_systolic'] = self.data['cnap']['blood_pressure_systolic'][excess:]
        self.data['cnap']['blood_pressure_diastolic'] = self.data['cnap']['blood_pressure_diastolic'][excess:]
        self.data['cnap']['oxygen_level'] = self.data['cnap']['oxygen_level'][excess:]
            
    def _trim_data(self):
        """修剪数据，保持在最大数据点数量以内"""
        excess = len(self.data['imu']['timestamps']) - self.max_data_points
        
        # 修剪IMU数据
        self.data['imu']['timestamps'] = self.data['imu']['timestamps'][excess:]
        for axis in ['x', 'y', 'z']:
            self.data['imu']['accelerometer'][axis] = self.data['imu']['accelerometer'][axis][excess:]
            self.data['imu']['gyroscope'][axis] = self.data['imu']['gyroscope'][axis][excess:]
            self.data['imu']['magnetometer'][axis] = self.data['imu']['magnetometer'][axis][excess:]
            
        # 修剪CNAP数据
        self.data['cnap']['timestamps'] = self.data['cnap']['timestamps'][excess:]
        self.data['cnap']['heart_rate'] = self.data['cnap']['heart_rate'][excess:]
        self.data['cnap']['blood_pressure_systolic'] = self.data['cnap']['blood_pressure_systolic'][excess:]
        self.data['cnap']['blood_pressure_diastolic'] = self.data['cnap']['blood_pressure_diastolic'][excess:]
        self.data['cnap']['oxygen_level'] = self.data['cnap']['oxygen_level'][excess:]
        
    def load_from_file(self, file_path):
        """从文件加载数据"""
        try:
            print(f"开始加载文件: {file_path}")
            
            # 检查文件扩展名
            if not file_path.lower().endswith(('.json', '.txt', '.csv')):
                print(f"不支持的文件格式: {file_path}")
                self._update_data_quality("格式不支持", "#dc3545")
                return False
            
            # 检查文件是否存在
            import os
            if not os.path.exists(file_path):
                print(f"文件不存在: {file_path}")
                self._update_data_quality("文件不存在", "#dc3545")
                return False
            
            # 检查文件大小
            file_size = os.path.getsize(file_path)
            print(f"文件大小: {file_size} 字节")
            
            if file_size == 0:
                print(f"文件为空: {file_path}")
                self._update_data_quality("文件为空", "#dc3545")
                return False
            
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read().strip()
                print(f"文件内容长度: {len(content)} 字符")
                
                # 尝试解析JSON
                if file_path.lower().endswith('.json'):
                    try:
                        data = json.loads(content)
                        # 验证数据格式
                        if isinstance(data, dict) and ('imu' in data or 'cnap' in data):
                            imu_count = len(data.get('imu', []))
                            cnap_count = len(data.get('cnap', []))
                            print(f"成功加载 {imu_count} 个IMU数据点和 {cnap_count} 个CNAP数据点，来自文件: {file_path}")
                            
                            # 更新数据管理器状态
                            self.is_connected = True
                            self.current_file = file_path
                            self.data_buffer = data
                            
                            # 更新数据质量状态
                            total_points = imu_count + cnap_count
                            if total_points > 1000:
 self._update_data_quality("优秀", "#28a745")
                            elif total_points > 100:
 self._update_data_quality("良好", "#17a2b8")
                            else:
 self._update_data_quality("一般", "#ffc107")
                            
                            self._update_data_integrity(0.95)  # 假设JSON数据完整性较高
                            return True
                        else:
                            print(f"文件 {file_path} 中的数据格式无效")
                            self._update_data_quality("格式无效", "#dc3545")
                            return False
                    except json.JSONDecodeError as e:
                        print(f"JSON解析错误，文件 {file_path}: {str(e)}")
                        self._update_data_quality("解析错误", "#dc3545")
                        return False
                
                # 对于其他格式，暂时返回成功（可以后续扩展解析逻辑）
                elif file_path.lower().endswith(('.txt', '.csv')):
                    print(f"已加载文本文件: {file_path} (格式解析尚未实现)")
                    
                    # 更新数据管理器状态
                    self.is_connected = True
                    self.current_file = file_path
                    self.data_buffer = {'raw_content': content}
                    
                    # 更新数据质量状态
                    self._update_data_quality("待解析", "#ffc107")
                    self._update_data_integrity(0.5)  # 文本格式完整性较低
                    
                    return True
                    
        except FileNotFoundError:
            print(f"文件未找到: {file_path}")
            self._update_data_quality("文件未找到", "#dc3545")
            return False
        except PermissionError:
            print(f"权限被拒绝: {file_path}")
            self._update_data_quality("权限被拒绝", "#dc3545")
            return False
        except UnicodeDecodeError as e:
            print(f"文件编码错误: {file_path}, 错误: {str(e)}")
            self._update_data_quality("编码错误", "#dc3545")
            return False
        except Exception as e:
            print(f"加载文件时出错: {str(e)}")
            self._update_data_quality("加载错误", "#dc3545")
            import traceback
            traceback.print_exc()
            return False
            
    def start_recording(self):
        """开始记录数据"""
        self.is_recording = True
        self.recorded_data = {
            'imu': [],
            'cnap': [],
            'start_time': datetime.now().isoformat()
        }
        self._update_recording_status("记录中")
        return True
        
    def stop_recording(self):
        """停止记录数据"""
        self.is_recording = False
        if self.recorded_data:
            self.recorded_data['end_time'] = datetime.now().isoformat()
        self._update_recording_status("已停止")
        return self.recorded_data
        
    def export_data(self, file_path, data=None):
        """导出数据到文件"""
        try:
            data_to_export = data if data else self.recorded_data
            if not data_to_export:
                return False
                
            with open(file_path, 'w') as f:
                json.dump(data_to_export, f, indent=2)
            return True
        except Exception as e:
            print(f"Error exporting data: {str(e)}")
            return False
    
    # === 新增的状态更新方法，用于UI显示 ===
    def _update_connection_status(self, status):
        """更新连接状态"""
        self.connection_status = status
        self.last_data_update = datetime.now().strftime("%H:%M:%S")
    
    def _update_data_source_status(self):
        """更新数据源状态"""
        if 'imu' in self.selected_sources and 'cnap' in self.selected_sources:
            self.data_sync_status = "双源同步"
        elif 'imu' in self.selected_sources:
            self.data_sync_status = "IMU单源"
        elif 'cnap' in self.selected_sources:
            self.data_sync_status = "CNAP单源"
        else:
            self.data_sync_status = "未选择"
    
    def _update_data_status(self, data):
        """更新数据状态"""
        if data and ('imu' in data or 'cnap' in data):
            self.last_data_update = datetime.now().strftime("%H:%M:%S")
            # 可以在这里添加数据质量评估逻辑
    
    def _update_data_quality(self, quality, color="#6c757d"):
        """更新数据质量"""
        self.data_quality = quality
        self.data_quality_color = color
    
    def _update_data_integrity(self, integrity):
        """更新数据完整性"""
        self.data_integrity = max(0.0, min(1.0, integrity))
    
    def _update_recording_status(self, status):
        """更新记录状态"""
        self.recording_status = status
    
    def get_data_status_summary(self):
        """获取数据状态摘要"""
        return {
            'connection_status': getattr(self, 'connection_status', '未知'),
            'data_quality': self.data_quality,
            'data_sync_status': self.data_sync_status,
            'last_update': self.last_data_update,
            'data_integrity': self.data_integrity,
            'recording_status': getattr(self, 'recording_status', '未记录'),
            'source_type': self.source_type,
            'selected_sources': self.selected_sources,
            'data_points': {
                'imu': len(self.data['imu']['timestamps']),
                'cnap': len(self.data['cnap']['timestamps'])
            }
        }

class BaseAnalyzer:
    """分析引擎，模拟core的分析功能"""
    def __init__(self):
        self.is_running = False
        self.analysis_level = "basic"  # basic, advanced
        self.analysis_results_history = []
        self.data_manager = None  # 绑定的数据管理器
        
    def set_data_manager(self, data_manager):
        """设置数据管理器"""
        self.data_manager = data_manager
        
    def start_analysis(self, level="basic"):
        """开始分析"""
        self.analysis_level = level
        self.is_running = True
        self.analysis_results_history = []  # 清空历史记录
        return True
        
    def stop_analysis(self):
        """停止分析"""
        self.is_running = False
        return True
        
    def get_analysis_results(self):
        """获取分析结果"""
        if not self.is_running:
            return None
            
        # 模拟分析结果
        result = {
            'timestamp': time.time(),
            'behavior': random.choice(["normal", "aggressive", "fatigued", "distracted"]),
            'confidence': random.uniform(0.7, 1.0),
            'metrics': {
                'speed': random.uniform(0, 120),
                'acceleration': random.uniform(-5, 5),
                'steering_angle': random.uniform(-30, 30)
            }
        }
        
        # 保存结果到历史记录
        self.analysis_results_history.append(result)
        # 限制历史记录长度
        if len(self.analysis_results_history) > 100:
            self.analysis_results_history.pop(0)
            
        return result
        
    def export_analysis_results(self, file_path):
        """导出分析结果"""
        try:
            with open(file_path, 'w') as f:
                json.dump({
                    'analysis_level': self.analysis_level,
                    'results': self.analysis_results_history,
                    'export_time': datetime.now().isoformat()
                }, f, indent=2)
            return True
        except Exception as e:
            print(f"Error exporting analysis results: {str(e)}")
            return False

# 图表画布组件
class MplCanvas(FigureCanvas):
    """matplotlib画布组件，用于在Qt中显示图表"""
    def __init__(self, parent=None, width=5, height=4, dpi=100):
        self.fig = Figure(figsize=(width, height), dpi=dpi)
        self.axes = self.fig.add_subplot(111)
        super(MplCanvas, self).__init__(self.fig)
        self.fig.tight_layout()
        self.setParent(parent)
        
    def clear(self):
        """清除图表"""
        self.axes.clear()
        self.draw()

# 自定义组件
class DataVisualizationWidget(QWidget):
    """数据可视化组件，用于展示IMU和CNAP数据"""
    def __init__(self, title, parent=None):
        super().__init__(parent)
        self.title = title
        self.data_manager = None
        self.init_ui()
        
    def init_ui(self):
        layout = QVBoxLayout(self)
        
        # 标题和控制按钮
        top_layout = QHBoxLayout()
        
        # 标题
        self.title_label = QLabel(f"<b>{self.title}</b>")
        self.title_label.setFont(QFont("Microsoft YaHei", 16, QFont.Weight.Bold))  # 增大字体
        self.title_label.setStyleSheet("""
            color: #2c3e50;
            padding: 8px 12px;
            background-color: #e8f4fd;
            border-radius: 8px;
            border: 2px solid #3498db;
        """)
        top_layout.addWidget(self.title_label)
        
        # 填充空间
        top_layout.addStretch()
        
        # 控制按钮
        self.start_btn = QPushButton("Start")
        self.start_btn.setStyleSheet("""
            QPushButton {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #28a745, stop:1 #20c997);
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                font-size: 14px;  /* 增大字体 */
                font-weight: bold;
                min-width: 80px;
                min-height: 40px;
            }
            QPushButton:hover {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #20c997, stop:1 #1ea085);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }
            QPushButton:pressed {
                transform: translateY(0px);
            }
        """)
        
        self.stop_btn = QPushButton("Stop")
        self.stop_btn.setEnabled(False)
        self.stop_btn.setStyleSheet("""
            QPushButton {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #dc3545, stop:1 #c82333);
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                font-size: 14px;  /* 增大字体 */
                font-weight: bold;
                min-width: 80px;
                min-height: 40px;
            }
            QPushButton:hover {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #c82333, stop:1 #bd2130);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }
            QPushButton:pressed {
                transform: translateY(0px);
            }
            QPushButton:disabled {
                background: #6c757d;
                color: #adb5bd;
            }
        """)
        
        top_layout.addWidget(self.start_btn)
        top_layout.addWidget(self.stop_btn)
        
        layout.addLayout(top_layout)
        
        # 图表区域
        self.chart_container = QWidget()
        chart_layout = QVBoxLayout(self.chart_container)
        
        # 添加图表画布
        self.canvas = MplCanvas(self.chart_container, width=5, height=4, dpi=100)
        chart_layout.addWidget(self.canvas)
        
        # 数据文本显示区域
        self.data_display = QTextEdit()
        self.data_display.setReadOnly(True)
        self.data_display.setMaximumHeight(120)  # 增加高度以容纳更大的字体
        self.data_display.setStyleSheet("""
            QTextEdit {
                font-family: 'Consolas', 'Microsoft YaHei', monospace;
                font-size: 13px;  /* 增大字体 */
                font-weight: bold;
                color: #2c3e50;
                background-color: #f8f9fa;
                border: 2px solid #dee2e6;
                border-radius: 8px;
                padding: 10px;
                line-height: 1.4;
            }
            QTextEdit:focus {
                border-color: #3498db;
                border-width: 3px;
            }
        """)
        chart_layout.addWidget(self.data_display)
        
        layout.addWidget(self.chart_container)
        
        # 连接信号
        self.start_btn.clicked.connect(self.start_visualization)
        self.stop_btn.clicked.connect(self.stop_visualization)
        
        # 定时器用于更新数据
        self.timer = QTimer(self)
        self.timer.timeout.connect(self.update_data)
        
    def set_data_manager(self, data_manager):
        self.data_manager = data_manager
        
    def start_visualization(self):
        self.start_btn.setEnabled(False)
        self.stop_btn.setEnabled(True)
        self.timer.start(1000)  # 每秒更新一次
        self.update_data()  # 立即更新一次
        
    def stop_visualization(self):
        self.start_btn.setEnabled(True)
        self.stop_btn.setEnabled(False)
        self.timer.stop()
        
    def update_data(self):
        """更新显示数据，实际应用中应该从数据源获取"""
        pass  # 由子类实现
        
    def update_translations(self, lang):
        """更新翻译"""
        self.start_btn.setText(translations[lang]['start_analysis'])
        self.stop_btn.setText(translations[lang]['stop_analysis'])
        self.title_label.setText(f"<b>{self.title}</b>")

class IMUVisualizationWidget(DataVisualizationWidget):
    """IMU数据可视化组件"""
    def __init__(self, parent=None):
        super().__init__("IMU Data Visualization", parent)
        
        # 添加图表选择下拉框
        self.add_chart_selector()
        
    def add_chart_selector(self):
        """添加图表选择器"""
        selector_layout = QHBoxLayout()
        selector_layout.setSpacing(15)  # 增加间距
        
        # 标签 - 使用更大的字体
        self.chart_label = QLabel("显示类型:")
        self.chart_label.setStyleSheet("""
            font-size: 14px;  /* 增大字体 */
            font-weight: bold;
            color: #495057;
            padding: 5px;
        """)
        selector_layout.addWidget(self.chart_label)
        
        # 下拉选择器 - 优化样式
        self.chart_selector = QComboBox()
        self.chart_selector.addItems(["Accelerometer", "Gyroscope", "Magnetometer", "All"])
        self.chart_selector.currentIndexChanged.connect(self.update_data)
        self.chart_selector.setStyleSheet("""
            QComboBox {
                border: 2px solid #ced4da;
                border-radius: 8px;
                padding: 8px 12px;
                background-color: white;
                min-height: 35px;
                font-size: 13px;  /* 增大字体 */
                font-weight: bold;
                min-width: 120px;
            }
            QComboBox:focus {
                border-color: #3498db;
                border-width: 3px;
            }
            QComboBox::drop-down {
                border: none;
                width: 30px;
            }
            QComboBox::down-arrow {
                image: none;
                border-left: 5px solid transparent;
                border-right: 5px solid transparent;
                border-top: 5px solid #6c757d;
                margin-right: 10px;
            }
        """)
        selector_layout.addWidget(self.chart_selector)
        selector_layout.addStretch()
        
        # 将选择器添加到顶部布局
        top_layout = self.layout().itemAt(0).layout()
        top_layout.insertLayout(1, selector_layout)
        
    def update_data(self):
        if self.data_manager and self.data_manager.is_connected:
            data = self.data_manager.get_latest_data()
            if data and 'imu' in data:
                imu = data['imu']
                # 更新文本显示
                display_text = f"Timestamp: {imu['timestamp']:.2f}\n"
                display_text += f"Accelerometer: X={imu['accelerometer'][0]:.2f}, Y={imu['accelerometer'][1]:.2f}, Z={imu['accelerometer'][2]:.2f}\n"
                display_text += f"Gyroscope: X={imu['gyroscope'][0]:.2f}, Y={imu['gyroscope'][1]:.2f}, Z={imu['gyroscope'][2]:.2f}\n"
                display_text += f"Magnetometer: X={imu['magnetometer'][0]:.2f}, Y={imu['magnetometer'][1]:.2f}, Z={imu['magnetometer'][2]:.2f}\n"
                self.data_display.setText(display_text)
                
                # 更新图表
                self.update_chart()
    
    def update_chart(self):
        """更新IMU数据图表"""
        self.canvas.clear()
        ax = self.canvas.axes
        
        # 获取要显示的数据类型
        chart_type = self.chart_selector.currentText()
        
        # 转换时间戳为相对时间（秒）
        if self.data_manager.data['imu']['timestamps']:
            start_time = self.data_manager.data['imu']['timestamps'][0]
            times = [t - start_time for t in self.data_manager.data['imu']['timestamps']]
            
            # 根据选择的图表类型绘制数据
            if chart_type == "Accelerometer" or chart_type == "All":
                ax.plot(times, self.data_manager.data['imu']['accelerometer']['x'], label='X', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['accelerometer']['y'], label='Y', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['accelerometer']['z'], label='Z', linestyle='-', marker='')
                ax.set_ylabel('Acceleration (m/s²)')
                
            if chart_type == "Gyroscope" or chart_type == "All":
                ax.plot(times, self.data_manager.data['imu']['gyroscope']['x'], label='X', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['gyroscope']['y'], label='Y', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['gyroscope']['z'], label='Z', linestyle='-', marker='')
                ax.set_ylabel('Angular Velocity (°/s)')
                
            if chart_type == "Magnetometer" or chart_type == "All":
                ax.plot(times, self.data_manager.data['imu']['magnetometer']['x'], label='X', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['magnetometer']['y'], label='Y', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['imu']['magnetometer']['z'], label='Z', linestyle='-', marker='')
                ax.set_ylabel('Magnetic Field (μT)')
            
            ax.set_xlabel('Time (s)')
            ax.set_title(f'IMU {chart_type} Data')
            ax.legend()
            ax.grid(True)
            
            self.canvas.draw()
            
    def update_translations(self, lang):
        super().update_translations(lang)
        self.chart_label.setText("Show:")  # 可根据需要翻译
        # 可以在这里更新图表选择器的选项文本

class CNAPVisualizationWidget(DataVisualizationWidget):
    """CNAP数据可视化组件"""
    def __init__(self, parent=None):
        super().__init__("CNAP Data Visualization", parent)
        
        # 添加图表选择下拉框
        self.add_chart_selector()
        
    def add_chart_selector(self):
        """添加图表选择器"""
        selector_layout = QHBoxLayout()
        selector_layout.setSpacing(15)  # 增加间距
        
        # 标签 - 使用更大的字体
        self.chart_label = QLabel("显示类型:")
        self.chart_label.setStyleSheet("""
            font-size: 14px;  /* 增大字体 */
            font-weight: bold;
            color: #495057;
            padding: 5px;
        """)
        selector_layout.addWidget(self.chart_label)
        
        # 下拉选择器 - 优化样式
        self.chart_selector = QComboBox()
        self.chart_selector.addItems(["Heart Rate", "Blood Pressure", "Oxygen Level", "All"])
        self.chart_selector.currentIndexChanged.connect(self.update_data)
        self.chart_selector.setStyleSheet("""
            QComboBox {
                border: 2px solid #ced4da;
                border-radius: 8px;
                padding: 8px 12px;
                background-color: white;
                min-height: 35px;
                font-size: 13px;  /* 增大字体 */
                font-weight: bold;
                min-width: 120px;
            }
            QComboBox:focus {
                border-color: #3498db;
                border-width: 3px;
            }
            QComboBox::drop-down {
                border: none;
                width: 30px;
            }
            QComboBox::down-arrow {
                image: none;
                border-left: 5px solid transparent;
                border-right: 5px solid transparent;
                border-top: 5px solid #6c757d;
                margin-right: 10px;
            }
        """)
        selector_layout.addWidget(self.chart_selector)
        selector_layout.addStretch()
        
        # 将选择器添加到顶部布局
        top_layout = self.layout().itemAt(0).layout()
        top_layout.insertLayout(1, selector_layout)
        
    def update_data(self):
        if self.data_manager and self.data_manager.is_connected:
            data = self.data_manager.get_latest_data()
            if data and 'cnap' in data:
                cnap = data['cnap']
                # 更新文本显示
                display_text = f"Timestamp: {cnap['timestamp']:.2f}\n"
                display_text += f"Heart Rate: {cnap['heart_rate']:.1f} bpm\n"
                display_text += f"Blood Pressure: {cnap['blood_pressure'][0]:.1f}/{cnap['blood_pressure'][1]:.1f} mmHg\n"
                display_text += f"Oxygen Level: {cnap['oxygen_level']:.1f}%\n"
                self.data_display.setText(display_text)
                
                # 更新图表
                self.update_chart()
    
    def update_chart(self):
        """更新CNAP数据图表"""
        self.canvas.clear()
        ax = self.canvas.axes
        
        # 获取要显示的数据类型
        chart_type = self.chart_selector.currentText()
        
        # 转换时间戳为相对时间（秒）
        if self.data_manager.data['cnap']['timestamps']:
            start_time = self.data_manager.data['cnap']['timestamps'][0]
            times = [t - start_time for t in self.data_manager.data['cnap']['timestamps']]
            
            # 根据选择的图表类型绘制数据
            if chart_type == "Heart Rate" or chart_type == "All":
                ax.plot(times, self.data_manager.data['cnap']['heart_rate'], label='Heart Rate', 
                        color='red', linestyle='-', marker='')
                ax.set_ylabel('Heart Rate (bpm)')
                
            if chart_type == "Blood Pressure" or chart_type == "All":
                ax.plot(times, self.data_manager.data['cnap']['blood_pressure_systolic'], 
                        label='Systolic', color='blue', linestyle='-', marker='')
                ax.plot(times, self.data_manager.data['cnap']['blood_pressure_diastolic'], 
                        label='Diastolic', color='green', linestyle='-', marker='')
                ax.set_ylabel('Blood Pressure (mmHg)')
                
            if chart_type == "Oxygen Level" or chart_type == "All":
                ax.plot(times, self.data_manager.data['cnap']['oxygen_level'], 
                        label='Oxygen Level', color='purple', linestyle='-', marker='')
                ax.set_ylabel('Oxygen Level (%)')
            
            ax.set_xlabel('Time (s)')
            ax.set_title(f'CNAP {chart_type} Data')
            ax.legend()
            ax.grid(True)
            
            self.canvas.draw()
            
    def update_translations(self, lang):
        super().update_translations(lang)
        self.chart_label.setText("Show:")  # 可根据需要翻译
        # 可以在这里更新图表选择器的选项文本

class AnalysisVisualizationWidget(QWidget):
    """分析结果可视化组件"""
    def __init__(self, parent=None):
        super().__init__(parent)
        self.title = "Analysis Results Visualization"
        self.analyzer = None
        self.init_ui()
        
    def init_ui(self):
        layout = QVBoxLayout(self)
        
        # 标题和控制按钮
        top_layout = QHBoxLayout()
        
        # 标题
        self.title_label = QLabel(f"<b>{self.title}</b>")
        self.title_label.setFont(QFont("Microsoft YaHei", 16, QFont.Weight.Bold))  # 增大字体
        self.title_label.setStyleSheet("""
            color: #2c3e50;
            padding: 8px 12px;
            background-color: #e8f4fd;
            border-radius: 8px;
            border: 2px solid #3498db;
        """)
        top_layout.addWidget(self.title_label)
        
        # 填充空间
        top_layout.addStretch()
        
        # 控制按钮
        self.export_btn = QPushButton("Export Results")
        self.export_btn.clicked.connect(self.export_results)
        self.export_btn.setStyleSheet("""
            QPushButton {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #17a2b8, stop:1 #138496);
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                font-size: 14px;  /* 增大字体 */
                font-weight: bold;
                min-width: 120px;
                min-height: 40px;
            }
            QPushButton:hover {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #138496, stop:1 #117a8b);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }
            QPushButton:pressed {
                transform: translateY(0px);
            }
        """)
        top_layout.addWidget(self.export_btn)
        
        layout.addLayout(top_layout)
        
        # 图表区域
        self.chart_container = QWidget()
        chart_layout = QVBoxLayout(self.chart_container)
        
        # 添加图表画布
        self.canvas = MplCanvas(self.chart_container, width=5, height=4, dpi=100)
        chart_layout.addWidget(self.canvas)
        
        # 分析结果文本显示区域
        self.results_display = QTextEdit()
        self.results_display.setReadOnly(True)
        self.results_display.setMaximumHeight(120)  # 增加高度以容纳更大的字体
        self.results_display.setStyleSheet("""
            QTextEdit {
                font-family: 'Consolas', 'Microsoft YaHei', monospace;
                font-size: 13px;  /* 增大字体 */
                font-weight: bold;
                color: #2c3e50;
                background-color: #f8f9fa;
                border: 2px solid #dee2e6;
                border-radius: 8px;
                padding: 10px;
                line-height: 1.4;
            }
            QTextEdit:focus {
                border-color: #3498db;
                border-width: 3px;
            }
        """)
        chart_layout.addWidget(self.results_display)
        
        layout.addWidget(self.chart_container)
        
        # 定时器用于更新数据
        self.timer = QTimer(self)
        self.timer.timeout.connect(self.update_analysis)
        
    def set_analyzer(self, analyzer):
        self.analyzer = analyzer
        
    def start_updating(self):
        self.timer.start(1000)  # 每秒更新一次
        self.update_analysis()  # 立即更新一次
        
    def stop_updating(self):
        self.timer.stop()
        
    def update_analysis(self):
        if self.analyzer and self.analyzer.is_running:
            result = self.analyzer.get_analysis_results()
            if result:
                # 更新文本显示
                display_text = f"Timestamp: {result['timestamp']:.2f}\n"
                display_text += f"Behavior: {result['behavior']} (confidence: {result['confidence']:.2f})\n"
                display_text += f"Metrics:\n"
                display_text += f"  Speed: {result['metrics']['speed']:.1f} km/h\n"
                display_text += f"  Acceleration: {result['metrics']['acceleration']:.2f} m/s²\n"
                display_text += f"  Steering Angle: {result['metrics']['steering_angle']:.1f}°\n"
                self.results_display.setText(display_text)
                
                # 更新图表
                self.update_chart()
    
    def update_chart(self):
        """更新分析结果图表"""
        self.canvas.clear()
        ax = self.canvas.axes
        
        # 绘制行为分类历史
        if len(self.analyzer.analysis_results_history) > 1:
            # 提取行为类型和时间
            behaviors = [r['behavior'] for r in self.analyzer.analysis_results_history]
            confidences = [r['confidence'] * 100 for r in self.analyzer.analysis_results_history]
            timestamps = [r['timestamp'] for r in self.analyzer.analysis_results_history]
            
            # 转换为相对时间
            start_time = timestamps[0]
            times = [t - start_time for t in timestamps]
            
            # 创建行为类型到数值的映射
            behavior_map = {"normal": 0, "aggressive": 1, "fatigued": 2, "distracted": 3}
            behavior_values = [behavior_map[b] for b in behaviors]
            
            # 绘制行为类型
            ax.plot(times, behavior_values, 'o-', color='blue', label='Behavior Type')
            
            # 添加置信度作为散点大小
            scatter = ax.scatter(times, behavior_values, s=confidences, alpha=0.5, 
 c=confidences, cmap='viridis')
            
            # 添加颜色条表示置信度
            cbar = self.canvas.fig.colorbar(scatter, ax=ax)
            cbar.set_label('Confidence (%)')
            
            # 设置Y轴标签
            ax.set_yticks(list(behavior_map.values()))
            ax.set_yticklabels(list(behavior_map.keys()))
            
            ax.set_xlabel('Time (s)')
            ax.set_title('Behavior Analysis History')
            ax.grid(True)
            ax.legend()
            
            self.canvas.draw()
    
    def export_results(self):
        """导出分析结果"""
        if not self.analyzer or len(self.analyzer.analysis_results_history) == 0:
            QMessageBox.warning(self, translations[CoreUIMainWindow.current_lang]['export_failed'], 
translations[CoreUIMainWindow.current_lang]['no_data_to_export'])
            return
            
        file_path, _ = QFileDialog.getSaveFileName(
            self, translations[CoreUIMainWindow.current_lang]['export_data'], 
            f"analysis_results_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json", 
            "JSON Files (*.json)"
        )
        
        if file_path:
            if self.analyzer.export_analysis_results(file_path):
                QMessageBox.information(self, translations[CoreUIMainWindow.current_lang]['export_successful'], 
        f"{translations[CoreUIMainWindow.current_lang]['data_exported_to']}\n{file_path}")
            else:
                QMessageBox.error(self, translations[CoreUIMainWindow.current_lang]['export_failed'], 
  "An error occurred while exporting results.")
  
    def update_translations(self, lang):
        self.title_label.setText(f"<b>{translations[lang]['analysis_visualization']}</b>")
        self.export_btn.setText(translations[lang]['export_data'])

class TopStatusBar(QWidget):
    """顶部状态栏组件"""
    def __init__(self, parent=None):
        super().__init__(parent)
        self.system_status = "Ready"  # Ready, Running, Error
        
        # 设置组件样式 - 优化视觉效果
        self.setStyleSheet("""
            QWidget {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #ffffff, stop:1 #f8f9fa);
                border-bottom: 2px solid #dee2e6;
                border-radius: 0px 0px 8px 8px;
            }
        """)
        
        # 设置固定高度，提供更好的视觉效果
        self.setFixedHeight(70)  # 增加高度以容纳更大的字体
        
        self.init_ui()
        
        # 定时器更新时间
        self.timer = QTimer(self)
        self.timer.timeout.connect(self.update_time)
        self.timer.start(1000)
        
    def init_ui(self):
        layout = QHBoxLayout(self)
        layout.setContentsMargins(20, 12, 20, 12)  # 增加边距以容纳更大的字体
        layout.setSpacing(20)  # 增加组件间距
        
        # 添加左侧填充，让状态元素整体靠右对齐
        layout.addStretch(1)
        
        # 系统标题 - 适应70px高度，使用更大的字体
        self.title_label = QLabel("<b>🚀 Core System Dashboard</b>")
        self.title_label.setFont(QFont("Microsoft YaHei", 18, QFont.Weight.Bold))  # 增大字体
        self.title_label.setStyleSheet("""
            color: #2c3e50; 
            padding: 8px 16px; 
            background-color: #e8f4fd;
            border-radius: 8px;
            border: 2px solid #3498db;
        """)
        layout.addWidget(self.title_label)
        
        # 添加分隔线 - 使用更明显的分隔符
        separator1 = QLabel("●")
        separator1.setStyleSheet("color: #3498db; font-weight: bold; font-size: 16px; margin: 0 8px;")
        layout.addWidget(separator1)
        
        # 系统状态 - 适应70px高度，使用更大的字体
        self.status_label = QLabel("状态:")
        self.status_label.setStyleSheet("""
            color: #7f8c8d; 
            font-size: 16px;  /* 增大字体 */
            font-weight: bold;
            padding: 6px;
        """)
        self.status_value = QLabel(self.system_status)
        self.set_status("Ready")  # 设置初始状态
        
        layout.addWidget(self.status_label)
        layout.addWidget(self.status_value)
        
        # 添加分隔线
        separator2 = QLabel("●")
        separator2.setStyleSheet("color: #3498db; font-weight: bold; font-size: 16px; margin: 0 8px;")
        layout.addWidget(separator2)
        
        # 数据记录状态 - 适应70px高度，使用更大的字体
        self.recording_label = QLabel("记录:")
        self.recording_label.setStyleSheet("""
            color: #7f8c8d; 
            font-size: 16px;  /* 增大字体 */
            font-weight: bold;
            padding: 6px;
        """)
        self.recording_value = QLabel("否")
        self.recording_value.setStyleSheet("""
            color: #95a5a6; 
            font-size: 16px;  /* 增大字体 */
            font-weight: bold;
            padding: 6px;
        """)
        layout.addWidget(self.recording_label)
        layout.addWidget(self.recording_value)
        
        # 添加分隔线
        separator3 = QLabel("●")
        separator3.setStyleSheet("color: #3498db; font-weight: bold; font-size: 16px; margin: 0 8px;")
        layout.addWidget(separator3)
        
        # 时间显示 - 适应70px高度，使用更大的字体
        self.time_label = QLabel()
        self.time_label.setStyleSheet("""
            color: #34495e; 
            font-size: 16px;  /* 增大字体 */
            font-family: 'Consolas', monospace; 
            font-weight: bold;
            padding: 6px;
            background-color: #f8f9fa;
            border-radius: 6px;
            border: 1px solid #dee2e6;
        """)
        layout.addWidget(self.time_label)
        
        # 添加分隔线
        separator4 = QLabel("●")
        separator4.setStyleSheet("color: #3498db; font-weight: bold; font-size: 16px; margin: 0 8px;")
        layout.addWidget(separator4)
        
        # 运行模式 - 适应70px高度，使用更大的字体
        self.mode_label = QLabel("模式:")
        self.mode_label.setStyleSheet("""
            color: #7f8c8d; 
            font-size: 16px;  /* 增大字体 */
            font-weight: bold;
            padding: 6px;
        """)
        self.mode_value = QLabel("标准")
        self.mode_value.setStyleSheet("""
            color: #27ae60; 
            font-size: 16px; 
            font-weight: bold;
            padding: 6px;
            background-color: #d4edda;
            border-radius: 6px;
            border: 1px solid #c3e6cb;
        """)
        layout.addWidget(self.mode_label)
        layout.addWidget(self.mode_value)
        

        

        
    def set_status(self, status):
        """设置系统状态并更新颜色"""
        self.system_status = status
        self.status_value.setText(status)
        
        # 使用更美观的颜色和样式，增大字体并添加背景色
        if status == "Ready" or status == translations['zh']['status_ready']:
            self.status_value.setStyleSheet("""
                color: #27ae60; 
                font-weight: bold; 
                font-size: 16px;  /* 增大字体 */
                padding: 6px 12px;
                background-color: #d4edda;
                border-radius: 6px;
                border: 2px solid #c3e6cb;
            """)
        elif status == "Running" or status == translations['zh']['status_running']:
            self.status_value.setStyleSheet("""
                color: #2980b9; 
                font-weight: bold; 
                font-size: 16px;  /* 增大字体 */
                padding: 6px 12px;
                background-color: #d1ecf1;
                border-radius: 6px;
                border: 2px solid #bee5eb;
            """)
        elif status == "Error" or status == translations['zh']['status_error']:
            self.status_value.setStyleSheet("""
                color: #e74c3c; 
                font-weight: bold; 
                font-size: 16px;  /* 增大字体 */
                padding: 6px 12px;
                background-color: #f8d7da;
                border-radius: 6px;
                border: 2px solid #f5c6cb;
            """)
        else:
            self.status_value.setStyleSheet("""
                color: #34495e; 
                font-weight: bold; 
                font-size: 16px;  /* 增大字体 */
                padding: 6px 12px;
                background-color: #f8f9fa;
                border-radius: 6px;
                border: 2px solid #dee2e6;
            """)
            
    def set_recording_status(self, is_recording):
        """设置记录状态"""
        if is_recording:
            self.recording_value.setText(translations[CoreUIMainWindow.current_lang]['recording_yes'])
            self.recording_value.setStyleSheet("""
                color: #e74c3c; 
                font-weight: bold; 
                font-size: 16px;  /* 增大字体 */
                padding: 6px 12px;
                background-color: #f8d7da;
                border-radius: 6px;
                border: 2px solid #f5c6cb;
            """)
        else:
            self.recording_value.setText(translations[CoreUIMainWindow.current_lang]['recording_no'])
            self.recording_value.setStyleSheet("""
                color: #95a5a6; 
                font-size: 16px;  /* 增大字体 */
                font-weight: bold;
                padding: 6px 12px;
                background-color: #f8f9fa;
                border-radius: 6px;
                border: 1px solid #dee2e6;
            """)
            
    def update_time(self):
        """更新时间显示"""
        try:
            # 使用更紧凑的时间格式
            current_time = QDateTime.currentDateTime().toString("MM-dd HH:mm:ss")
            if hasattr(self, 'time_label'):
                self.time_label.setText(current_time)
        except Exception as e:
            # 这里不能使用self.logger，因为TopStatusBar没有logger
            pass
    
    def update_translations(self, lang):
        # 更新标题
        if lang == 'zh':
            self.title_label.setText("<b>🚀 核心系统仪表板</b>")
        else:
            self.title_label.setText(f"<b>🚀 {translations[lang]['app_title']}</b>")
        
        # 更新标签文本
        if lang == 'zh':
            self.status_label.setText("状态:")
            self.recording_label.setText("记录:")
            self.mode_label.setText("模式:")
        else:
            self.status_label.setText(f"{translations[lang]['state']}: ")
            self.recording_label.setText(f"{translations[lang]['data_recording']}: ")
            self.mode_label.setText("Mode: ")
        
        # 更新值文本
        if lang == 'zh':
            self.mode_value.setText("标准")
        else:
            self.mode_value.setText(translations[lang]['mode_standard'])
        
        # 更新状态文本
        if self.system_status == "Ready" or self.system_status == translations['zh']['status_ready']:
            self.set_status(translations[lang]['status_ready'])
        elif self.system_status == "Running" or self.system_status == translations['zh']['status_running']:
            self.set_status(translations[lang]['status_running'])
        elif self.system_status == "Error" or self.system_status == translations['zh']['status_error']:
            self.set_status(translations[lang]['status_error'])

class BottomStatusBar(QStatusBar):
    """底部状态栏组件"""
    def __init__(self, parent=None):
        super().__init__(parent)
        self.init_ui()
        
    def init_ui(self):
        # 设置状态栏样式
        self.setStyleSheet("""
            QStatusBar {
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 #f8f9fa, stop:1 #e9ecef);
                border-top: 2px solid #dee2e6;
                padding: 8px;
                font-size: 14px;  /* 增大字体 */
                font-weight: bold;
            }
        """)
        
        # 数据统计
        self.data_stats = QLabel("Data points processed: 0")
        self.data_stats.setStyleSheet("""
            color: #495057;
            padding: 5px 10px;
            background-color: #e9ecef;
            border-radius: 6px;
            border: 1px solid #ced4da;
        """)
        self.addWidget(self.data_stats)
        
        # 异常提示
        self.error提示 = QLabel("")
        self.error提示.setStyleSheet("""
            color: #dc3545;
            font-weight: bold;
            padding: 5px 10px;
            background-color: #f8d7da;
            border-radius: 6px;
            border: 1px solid #f5c6cb;
        """)
        self.addPermanentWidget(self.error提示, 1)
        
        # 页面信息
        self.page_info = QLabel("Core UI v2.0.0")
        self.page_info.setStyleSheet("""
            color: #6c757d;
            padding: 5px 10px;
            background-color: #f8f9fa;
            border-radius: 6px;
            border: 1px solid #dee2e6;
        """)
        self.addPermanentWidget(self.page_info)
        
    def update_data_stats(self, count):
        """更新数据统计信息"""
        self.data_stats.setText(f"Data points processed: {count}")
        
    def show_error(self, message):
        """显示错误信息"""
        self.error提示.setText(f"Error: {message}")
        
    def clear_error(self):
        """清除错误信息"""
        self.error提示.setText("")
        
    def show_message(self, message):
        """显示普通信息"""
        self.error提示.setText(message)
        
    def update_translations(self, lang):
        count_text = self.data_stats.text().split(": ")[1]
        self.data_stats.setText(f"Data points processed: {count_text}")  # 可根据需要翻译

class LeftControlPanel(QWidget):
    """左侧控制面板组件"""
    
    # 定义logger
    logger = logging.getLogger(__name__)
    
    # 定义信号
    data_source_changed = Signal(str, dict)
    analysis_toggled = Signal(bool, str)
    load_file_requested = Signal(str)
    record_toggled = Signal(bool)
    export_data_requested = Signal()
    source_added = Signal(int, str, dict)
    source_removed = Signal(int)
    active_source_changed = Signal(int)
    data_sources_selected = Signal(list)  # 新增信号：数据源选择变化
    
    # 高级分析控制信号
    advanced_analysis_started = Signal()  # 高级分析开始
    advanced_analysis_stopped = Signal()  # 高级分析停止
    model_load_requested = Signal()       # 模型加载请求
    model_unload_requested = Signal()     # 模型卸载请求
    
    # 管理模块方法定义
    def open_vehicle_management(self):
        """车辆管理功能（暂时不可用）"""
        QMessageBox.information(self, "车辆管理", "🚗 车辆管理功能\n\n该功能暂时不可用，右侧标签页已移除。\n\n左侧控制面板中的按钮已保留，可用于将来重新启用此功能。")
    
    def open_driver_management(self):
        """司机管理功能（暂时不可用）"""
        QMessageBox.information(self, "司机管理", "👨‍💼 司机管理功能\n\n该功能暂时不可用，右侧标签页已移除。\n\n左侧控制面板中的按钮已保留，可用于将来重新启用此功能。")
    
    def open_fleet_management(self):
        """车队管理功能（暂时不可用）"""
        QMessageBox.information(self, "车队管理", "🚛 车队管理功能\n\n该功能暂时不可用，右侧标签页已移除。\n\n左侧控制面板中的按钮已保留，可用于将来重新启用此功能。")
    
    def open_trip_management(self):
        """行程管理功能（暂时不可用）"""
        QMessageBox.information(self, "行程管理", "🗺️ 行程管理功能\n\n该功能暂时不可用，右侧标签页已移除。\n\n左侧控制面板中的按钮已保留，可用于将来重新启用此功能。")
    
    def update_management_summary(self, vehicle_count=0, driver_count=0, fleet_count=0, trip_count=0):
        """更新管理模块状态摘要"""
        try:
            self.vehicle_count_label.setText(str(vehicle_count))
            self.driver_count_label.setText(str(driver_count))
            self.fleet_count_label.setText(str(fleet_count))
            self.trip_count_label.setText(str(trip_count))
        except Exception as e:
            print(f"更新管理模块状态摘要失败: {e}")
    
    def __init__(self, parent=None):
        super().__init__(parent)
        self.main_layout = QVBoxLayout(self)  # 主布局
        self.init_ui()
        
    def init_ui(self):
        """初始化用户界面 - 重构版本：使用统一数据源管理面板"""
        self.main_layout.setContentsMargins(10, 10, 10, 10)
        self.main_layout.setSpacing(10)
        
        # === 重构：使用统一数据源管理面板替换原有分散模块 ===
        try:
            from modules.ui.unified_data_source_panel import UnifiedDataSourcePanel
            
            # 创建统一数据源管理面板
            self.unified_data_source_panel = UnifiedDataSourcePanel(self)
            
            # 连接信号
            self.unified_data_source_panel.data_source_selected.connect(self._on_unified_data_source_selected)
            self.unified_data_source_panel.data_source_changed.connect(self._on_unified_data_source_changed)
            self.unified_data_source_panel.analysis_toggled.connect(self._on_unified_analysis_toggled)
            self.unified_data_source_panel.record_toggled.connect(self._on_unified_record_toggled)
            self.unified_data_source_panel.export_data_requested.connect(self.export_data_requested)
            
            # 添加到主布局
            self.main_layout.addWidget(self.unified_data_source_panel)
            
            self.logger.info("统一数据源管理面板集成成功")
            
        except ImportError as e:
            self.logger.error(f"导入统一数据源管理面板失败: {e}")
            # 如果导入失败，显示错误信息
            error_label = QLabel("❌ 统一数据源管理面板加载失败")
            error_label.setStyleSheet("color: red; font-weight: bold; padding: 20px;")
            self.main_layout.addWidget(error_label)
        except Exception as e:
            self.logger.error(f"集成统一数据源管理面板失败: {e}")
            # 如果集成失败，显示错误信息
            error_label = QLabel("❌ 统一数据源管理面板集成失败")
            error_label.setStyleSheet("color: red; font-weight: bold; padding: 20px;")
            self.main_layout.addWidget(error_label)
    


        
        # === 管理模块快速访问 ===
