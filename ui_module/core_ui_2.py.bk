    def setup_connections(self):
        """设置组件间的信号连接"""
        # 左侧面板信号
        self.left_panel.data_source_changed.connect(self.on_data_source_changed)
        self.left_panel.analysis_toggled.connect(self.on_analysis_toggled)
        self.left_panel.load_file_requested.connect(self.on_load_file)
        self.left_panel.record_toggled.connect(self.on_record_toggled)
        self.left_panel.export_data_requested.connect(self.on_export_data)
        self.left_panel.theme_combo.currentIndexChanged.connect(
            lambda index: self.set_theme(self.left_panel.theme_combo.currentText()))
        
        # 多源管理信号连接
        self.left_panel.source_added.connect(self.on_source_added)
        self.left_panel.source_removed.connect(self.on_source_removed)
        self.left_panel.active_source_changed.connect(self.on_active_source_changed)
        
        # 数据源选择信号连接
        self.left_panel.data_sources_selected.connect(self.on_data_sources_selected)
        
        # 分析标签页按钮连接
        if hasattr(self.right_tab, 'start_analysis_btn'):
            self.right_tab.start_analysis_btn.clicked.connect(
                lambda: self.left_panel.analysis_toggled.emit(True, "basic"))
        if hasattr(self.right_tab, 'stop_analysis_btn'):
            self.right_tab.stop_analysis_btn.clicked.connect(
                lambda: self.left_panel.analysis_toggled.emit(False, ""))
            

        
    def set_language(self, lang):
        """设置应用语言"""
        CoreUIMainWindow.current_lang = lang
        
        # 更新菜单栏
        self.menuBar().clear()
        self.create_menu_bar()
        
        # 更新所有UI元素的翻译
        self.top_status.update_translations(lang)
        self.bottom_status.update_translations(lang)
        self.left_panel.update_translations(lang)
        self.right_tab.update_translations(lang)
        
        # 更新窗口标题
        self.setWindowTitle(translations[lang]['app_title'])
        
        # 保存语言设置
        self.settings.setValue("system/language", lang)
    
    def on_data_source_changed(self, source_type, params):
        """处理数据源变更"""
        if source_type:
            if self.data_manager.connect(source_type, params):
                self.top_status.set_status(translations[CoreUIMainWindow.current_lang]['status_running'])
                self.right_tab.source_type_label.setText(source_type.capitalize())
                self.right_tab.connection_status_label.setText("Connected")
                # 更新连接状态标签
                if hasattr(self.right_tab.monitoring_tab, 'connection_label'):
                    self.right_tab.monitoring_tab.connection_label.setText(f"{translations[CoreUIMainWindow.current_lang]['connection']} {source_type}")
                
                # 更新数据格式信息
                if source_type == "simulated":
                    self.right_tab.data_format_label.setText("IMU + CNAP (simulated)")
                elif source_type == "file":
                    self.right_tab.data_format_label.setText("Auto-detected from file")
                elif source_type == "serial":
                    self.right_tab.data_format_label.setText("Serial stream (JSON)")
                elif source_type == "mqtt":
                    self.right_tab.data_format_label.setText("MQTT messages (JSON)")
                elif source_type == "tcp":
                    self.right_tab.data_format_label.setText("TCP stream (JSON)")
                elif source_type == "udp":
                    self.right_tab.data_format_label.setText("UDP datagrams (JSON)")
                    
                # 开始更新数据
                self.data_timer.start(1000)  # 每秒更新一次
                self.bottom_status.clear_error()
            else:
                self.top_status.set_status(translations[CoreUIMainWindow.current_lang]['status_error'])
                self.bottom_status.show_error(f"Failed to connect to {source_type}")
        else:
            # 断开连接
            self.data_manager.disconnect()
            self.top_status.set_status(translations[CoreUIMainWindow.current_lang]['status_ready'])
            self.right_tab.connection_status_label.setText("Disconnected")
            # 更新连接状态标签
            if hasattr(self.right_tab.monitoring_tab, 'connection_label'):
                self.right_tab.monitoring_tab.connection_label.setText(f"{translations[CoreUIMainWindow.current_lang]['connection']} Disconnected")
            self.data_timer.stop()
    
    # 多源管理相关方法
    def on_source_added(self, source_id, source_type, params):
        """处理新添加的数据源"""
        # 初始化该数据源的连接
        self.data_sources[source_id] = {
            "manager": DataManager(),  # 为每个源创建独立的数据管理器
            "is_connected": False
        }
        # 尝试连接
        success = self.data_sources[source_id]["manager"].connect(source_type, params)
        self.data_sources[source_id]["is_connected"] = success
        
        # 更新状态
        if success:
            self.bottom_status.show_message(f"Source {source_id} ({source_type}) connected")
        else:
            self.bottom_status.show_error(f"Failed to connect source {source_id}")

    def on_source_removed(self, source_id):
        """处理移除数据源"""
        if source_id in self.data_sources:
            # 断开连接
            self.data_sources[source_id]["manager"].disconnect()
            del self.data_sources[source_id]
            self.bottom_status.show_message(f"Source {source_id} removed")
            
            # 如果移除的是活动源，尝试激活第一个可用源
            if self.active_source_id == source_id:
                if self.data_sources:
                    new_active_id = next(iter(self.data_sources.keys()))
                    self.on_active_source_changed(new_active_id)
                else:
                    self.active_source_id = None
                    self.right_tab.imu_vis_tab.set_data_manager(None)
                    self.right_tab.cnap_vis_tab.set_data_manager(None)
                    self.analyzer.set_data_manager(None)

    def on_active_source_changed(self, source_id):
        """切换激活的数据源（用于显示和分析）"""
        if source_id not in self.data_sources:
            return
        self.active_source_id = source_id
        active_manager = self.data_sources[source_id]["manager"]
        
        # 更新UI显示为当前激活的数据源
        self.right_tab.source_type_label.setText(active_manager.source_type.capitalize())
        self.right_tab.connection_status_label.setText("Connected" if self.data_sources[source_id]["is_connected"] else "Disconnected")
        
        # 重新绑定可视化组件和分析器到当前数据源
        self.right_tab.imu_vis_tab.set_data_manager(active_manager)
        self.right_tab.cnap_vis_tab.set_data_manager(active_manager)
        self.analyzer.set_data_manager(active_manager)
        
        self.bottom_status.show_message(f"Active source changed to {source_id}")
    
    def on_data_sources_selected(self, sources):
        """处理数据源选择变化"""
        try:
            self.logger.info(f"处理数据源选择变化: {sources}")
            
            # 更新数据管理器的选中数据源
            if hasattr(self.data_manager, 'selected_sources'):
                self.data_manager.selected_sources = sources
                self.logger.info("数据管理器已更新选中的数据源")
            
            # 更新标签页可见性
            self._update_tab_visibility(sources)
            
            # 开始配置数据源
            self._configure_data_sources(sources)
            
        except Exception as e:
            self.logger.error(f"处理数据源选择变化失败: {e}")
            QMessageBox.critical(
                self, 
                "数据源配置失败", 
                f"配置数据源时出现错误:\n{str(e)}\n\n请检查系统状态后重试。"
            )
    
    def _update_tab_visibility(self, sources):
        """根据选择的数据源更新标签页可见性"""
        try:
            if hasattr(self, 'right_tab'):
                # 这里可以添加标签页可见性控制逻辑
                self.logger.info("标签页可见性已更新")
        except Exception as e:
            self.logger.warning(f"更新标签页可见性失败: {e}")
    
    def _configure_data_sources(self, sources):
        """配置选中的数据源"""
        try:
            self.logger.info(f"开始配置数据源: {sources}")
            
            # 显示数据源配置对话框
            self._show_data_source_config_dialog(sources)
            
        except Exception as e:
            self.logger.error(f"配置数据源失败: {e}")
    
    def _show_data_source_config_dialog(self, sources):
        """显示数据源配置对话框 - 增强版"""
        try:
            self.logger.info(f"显示数据源配置对话框: {sources}")
            
            # 创建配置确认对话框
            from PySide6.QtWidgets import QDialog, QVBoxLayout, QLabel, QPushButton, QHBoxLayout, QTextEdit, QCheckBox
            
            config_dialog = QDialog(self)
            config_dialog.setWindowTitle("🎯 数据源配置确认")
            config_dialog.setModal(True)
            config_dialog.resize(600, 450)
            
            layout = QVBoxLayout(config_dialog)
            
            # 标题
            title_label = QLabel("🎯 数据源配置确认")
            title_label.setStyleSheet("font-size: 16px; font-weight: bold; color: #0066cc; margin: 10px;")
            layout.addWidget(title_label)
            
            # 说明文字
            description = QLabel(f"您已选择以下数据源:\n{', '.join([s.upper() for s in sources])}\n\n请确认配置:")
            description.setStyleSheet("font-size: 12px; margin: 10px;")
            layout.addWidget(description)
            
            # 配置选项
            config_label = QLabel("""
📊 分析模式: 自动选择最佳分析策略
🔧 参数配置: 根据数据源类型自动优化
📈 实时监控: 启用实时数据分析和可视化
🔄 数据同步: 自动同步多源数据
            """)
            config_label.setStyleSheet("font-size: 11px; margin: 10px; padding: 10px; background-color: #f0f0f0; border-radius: 5px;")
            layout.addWidget(config_label)
            
            # 高级选项
            advanced_options = QTextEdit()
            advanced_options.setMaximumHeight(100)
            advanced_options.setPlainText("""
高级配置选项:
• 数据预处理: 自动过滤异常值
• 实时校准: 动态校准传感器数据
• 缓存管理: 智能数据缓存策略
• 错误恢复: 自动错误检测和恢复
            """)
            advanced_options.setReadOnly(True)
            layout.addWidget(advanced_options)
            
            # 配置确认选项
            confirm_options_layout = QVBoxLayout()
            
            auto_optimize_check = QCheckBox("✅ 自动优化分析参数")
            auto_optimize_check.setChecked(True)
            confirm_options_layout.addWidget(auto_optimize_check)
            
            real_time_check = QCheckBox("✅ 启用实时数据监控")
            real_time_check.setChecked(True)
            confirm_options_layout.addWidget(real_time_check)
            
            error_recovery_check = QCheckBox("✅ 启用自动错误恢复")
            error_recovery_check.setChecked(True)
            confirm_options_layout.addWidget(error_recovery_check)
            
            layout.addLayout(confirm_options_layout)
            
            # 确认按钮
            confirm_btn = QPushButton("✅ 确认配置")
            confirm_btn.clicked.connect(lambda: self._confirm_data_source_config(sources, config_dialog, {
                'auto_optimize': auto_optimize_check.isChecked(),
                'real_time': real_time_check.isChecked(),
                'error_recovery': error_recovery_check.isChecked()
            }))
            confirm_btn.setStyleSheet("""
                QPushButton {
                    background-color: #4CAF50;
                    color: white;
                    border: none;
                    padding: 10px;
                    font-size: 14px;
                    border-radius: 5px;
                }
                QPushButton:hover {
                    background-color: #45a049;
                }
            """)
            
            button_layout = QHBoxLayout()
            button_layout.addStretch()
            button_layout.addWidget(confirm_btn)
            button_layout.addStretch()
            layout.addLayout(button_layout)
            
            # 显示对话框
            config_dialog.exec()
            
        except Exception as e:
            self.logger.error(f"显示数据源配置对话框失败: {e}")
            QMessageBox.critical(self, "错误", f"显示配置对话框失败: {str(e)}")
    
    def _confirm_data_source_config(self, sources, dialog, options=None):
        """确认数据源配置"""
        try:
            self.logger.info(f"确认数据源类型选择: {sources}")
            if options:
                self.logger.info(f"配置选项: {options}")
            
            # 关闭配置对话框
            dialog.accept()
            
            # 应用配置选项
            if options:
                self._apply_configuration_options(options)
            
            # 优化原有的文件浏览功能
            self._optimize_existing_file_browsing(sources)
            
            # 更新UI状态
            self._update_ui_after_source_selection(sources)
            
            # 显示操作建议
            self._show_operation_guidance(sources)
            
        except Exception as e:
            self.logger.error(f"确认数据源配置失败: {e}")
    
    def _apply_configuration_options(self, options):
        """应用配置选项"""
        try:
            self.logger.info(f"应用配置选项: {options}")
            
            # 自动优化分析参数
            if options.get('auto_optimize', False):
                self._enable_auto_optimization()
            
            # 启用实时数据监控
            if options.get('real_time', False):
                self._enable_real_time_monitoring()
            
            # 启用自动错误恢复
            if options.get('error_recovery', False):
                self._enable_error_recovery()
                
        except Exception as e:
            self.logger.error(f"应用配置选项失败: {e}")
    
    def _enable_auto_optimization(self):
        """启用自动优化"""
        try:
            # 防止重复启用
            if hasattr(self, 'auto_optimization_enabled') and self.auto_optimization_enabled:
                self.logger.debug("自动优化已经启用，跳过重复启用")
                return
            
            self.logger.info("启用自动优化分析参数")
            
            # 启用自动参数调整
            self.auto_optimization_enabled = True
            
            # 启动参数优化定时器（确保只创建一次）
            if not hasattr(self, 'optimization_timer') or not self.optimization_timer:
                self.optimization_timer = QTimer()
                self.optimization_timer.timeout.connect(self._auto_optimize_parameters)
                self.logger.debug("创建新的优化定时器")
            else:
                # 如果定时器已存在，先停止它
                if self.optimization_timer.isActive():
                    self.optimization_timer.stop()
                    self.logger.debug("停止现有定时器")
            
            # 启动定时器
            self.optimization_timer.start(30000)  # 每30秒优化一次
            self.logger.debug("启动优化定时器，间隔30秒")
            
            # 初始化优化参数
            if not hasattr(self, 'optimization_history'):
                self.optimization_history = []
            if not hasattr(self, 'current_optimization_level'):
                self.current_optimization_level = 'basic'
            
            # 初始化递归保护标志
            self._optimization_in_progress = False
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("自动优化已启用，系统将自动调整分析参数")
                
        except Exception as e:
            self.logger.error(f"启用自动优化失败: {e}")
            # 出错时重置状态
            self.auto_optimization_enabled = False
            if hasattr(self, 'optimization_timer') and self.optimization_timer:
                self.optimization_timer.stop()
    
    def _disable_auto_optimization(self):
        """禁用自动优化"""
        try:
            if not hasattr(self, 'auto_optimization_enabled') or not self.auto_optimization_enabled:
                return
            
            self.logger.info("禁用自动优化分析参数")
            
            # 禁用自动参数调整
            self.auto_optimization_enabled = False
            
            # 停止定时器
            if hasattr(self, 'optimization_timer') and self.optimization_timer:
                if self.optimization_timer.isActive():
                    self.optimization_timer.stop()
                    self.logger.debug("停止优化定时器")
            
            # 重置递归保护标志
            self._optimization_in_progress = False
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("自动优化已禁用")
                
        except Exception as e:
            self.logger.error(f"禁用自动优化失败: {e}")
    
    def _auto_optimize_parameters(self):
        """自动优化分析参数"""
        try:
            # 防止递归调用
            if not hasattr(self, 'auto_optimization_enabled') or not self.auto_optimization_enabled:
                self.logger.debug("自动优化已禁用，跳过本次调用")
                return
            
            # 添加递归保护
            if hasattr(self, '_optimization_in_progress') and self._optimization_in_progress:
                self.logger.warning("自动优化正在进行中，跳过本次调用")
                return
            
            self._optimization_in_progress = True
            
            self.logger.info("开始自动优化分析参数")
            
            # 获取当前数据质量
            data_quality = self._assess_data_quality()
            
            # 根据数据质量调整参数
            if data_quality == 'excellent':
                self._optimize_for_excellent_quality()
            elif data_quality == 'good':
                self._optimize_for_good_quality()
            elif data_quality == 'fair':
                self._optimize_for_fair_quality()
            elif data_quality == 'poor':
                self._optimize_for_poor_quality()
            else:
                self.logger.warning(f"未知数据质量: {data_quality}，跳过优化")
            
            # 记录优化历史
            if data_quality != 'unknown':
                self._record_optimization_history(data_quality)
            
        except Exception as e:
            self.logger.error(f"自动优化参数失败: {e}")
        finally:
            # 确保递归保护被重置
            self._optimization_in_progress = False
    
    def _assess_data_quality(self):
        """评估数据质量"""
        try:
            # 安全检查数据管理器
            if not hasattr(self, 'data_manager') or not self.data_manager:
                self.logger.debug("数据管理器不存在，返回unknown质量")
                return 'unknown'
            
            # 安全检查数据属性
            if not hasattr(self.data_manager, 'data') or not self.data_manager.data:
                self.logger.debug("数据管理器数据为空，返回unknown质量")
                return 'unknown'
            
            # 安全获取数据统计信息
            data_points = 0
            try:
                imu_data = self.data_manager.data.get('imu', {})
                cnap_data = self.data_manager.data.get('cnap', {})
                
                if isinstance(imu_data, dict) and 'timestamps' in imu_data:
                    imu_points = len(imu_data['timestamps'])
                else:
                    imu_points = 0
                    
                if isinstance(cnap_data, dict) and 'timestamps' in cnap_data:
                    cnap_points = len(cnap_data['timestamps'])
                else:
                    cnap_points = 0
                    
                data_points = imu_points + cnap_points
                
            except (AttributeError, TypeError, KeyError) as e:
                self.logger.debug(f"获取数据点数量时出错: {e}")
                data_points = 0
            
            # 根据数据点数量评估质量
            if data_points > 1000:
                return 'excellent'
            elif data_points > 500:
                return 'good'
            elif data_points > 100:
                return 'fair'
            elif data_points > 0:
                return 'poor'
            else:
                return 'unknown'
                
        except Exception as e:
            self.logger.error(f"评估数据质量失败: {e}")
            return 'unknown'
    
    def _optimize_for_excellent_quality(self):
        """为优秀数据质量优化参数"""
        try:
            self.logger.info("为优秀数据质量优化参数")
            
            # 调整分析窗口大小
                    # 配置标签页已移除，配置管理功能移至菜单
            
            # 调整置信度阈值
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'threshold_edit'):
                self.left_panel.threshold_edit.setText("0.9")  # 提高置信度
            
            # 调整灵敏度
            if hasattr(self, 'left_panel') and hasattr(self.left_panel, 'sensitivity_slider'):
                self.left_panel.sensitivity_slider.setValue(8)  # 提高灵敏度
            
            self.current_optimization_level = 'excellent'
            
        except Exception as e:
            self.logger.error(f"为优秀数据质量优化参数失败: {e}")
    
