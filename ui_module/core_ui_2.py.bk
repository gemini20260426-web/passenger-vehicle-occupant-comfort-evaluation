    def _record_optimization_history(self, data_quality):
        """记录优化历史"""
        try:
            from datetime import datetime
            
            optimization_record = {
                'timestamp': datetime.now().isoformat(),
                'data_quality': data_quality,
                'optimization_level': self.current_optimization_level,
                'window_size': 'unknown',  # 配置标签页已移除
                'confidence_threshold': getattr(self.left_panel, 'threshold_edit', None).text() if hasattr(self.left_panel, 'threshold_edit') else 'unknown',
                'sensitivity': getattr(self.left_panel, 'sensitivity_slider', None).value() if hasattr(self.left_panel, 'sensitivity_slider') else 'unknown'
            }
            
            self.optimization_history.append(optimization_record)
            
            # 限制历史记录长度
            if len(self.optimization_history) > 100:
                self.optimization_history.pop(0)
            
            self.logger.info(f"记录优化历史: {data_quality} -> {self.current_optimization_level}")
            
        except Exception as e:
            self.logger.error(f"记录优化历史失败: {e}")
    
    def _enable_real_time_monitoring(self):
        """启用实时数据监控"""
        try:
            self.logger.info("启用实时数据监控")
            
            # 启用智能缓存管理
            self._enable_smart_caching()
            
            # 优化数据更新频率
            self._optimize_data_update_frequency()
            
            # 启用实时图表更新
            self._enable_real_time_charts()
            
            if hasattr(self, 'bottom_status'):
                self.bottom_status.show_message("实时数据监控已启用，包括智能缓存和性能优化")
                
        except Exception as e:
            self.logger.error(f"启用实时数据监控失败: {e}")
    
    def _enable_smart_caching(self):
        """启用智能缓存管理"""
        try:
            self.logger.info("启用智能缓存管理")
            
            # 设置缓存参数
            self.cache_enabled = True
            self.cache_size = 1000  # 缓存大小
            self.cache_ttl = 300    # 缓存生存时间（秒）
            
            # 初始化缓存
            self.data_cache = {}
            self.cache_timestamps = {}
            
            # 启动缓存清理定时器
            if not hasattr(self, 'cache_cleanup_timer'):
                self.cache_cleanup_timer = QTimer()
                self.cache_cleanup_timer.timeout.connect(self._cleanup_cache)
                self.cache_cleanup_timer.start(60000)  # 每分钟清理一次
            
            self.logger.info("智能缓存管理已启用")
            
        except Exception as e:
            self.logger.error(f"启用智能缓存管理失败: {e}")
    
    def _cleanup_cache(self):
        """清理过期缓存"""
        try:
            if not hasattr(self, 'cache_enabled') or not self.cache_enabled:
                return
            
            current_time = time.time()
            expired_keys = []
            
            # 查找过期的缓存项
            for key, timestamp in self.cache_timestamps.items():
                if current_time - timestamp > self.cache_ttl:
                    expired_keys.append(key)
            
            # 删除过期项
            for key in expired_keys:
                if key in self.data_cache:
                    del self.data_cache[key]
                if key in self.cache_timestamps:
                    del self.cache_timestamps[key]
            
            if expired_keys:
                self.logger.info(f"清理了 {len(expired_keys)} 个过期缓存项")
                
        except Exception as e:
            self.logger.error(f"清理缓存失败: {e}")
    
    def _optimize_data_update_frequency(self):
        """优化数据更新频率"""
        try:
            self.logger.info("优化数据更新频率")
            
            # 根据数据源类型调整更新频率
            if hasattr(self, 'data_manager') and self.data_manager:
                source_type = getattr(self.data_manager, 'source_type', 'simulated')
                
                if source_type == 'simulated':
                    update_interval = 1000  # 1秒
                elif source_type == 'file':
                    update_interval = 2000  # 2秒
                elif source_type in ['serial', 'mqtt', 'tcp', 'udp']:
                    update_interval = 500   # 0.5秒
                else:
                    update_interval = 1000  # 默认1秒
                
                # 调整数据更新定时器
                if hasattr(self, 'data_timer'):
                    self.data_timer.setInterval(update_interval)
                    self.logger.info(f"数据更新频率已调整为 {update_interval}ms")
                    
        except Exception as e:
            self.logger.error(f"优化数据更新频率失败: {e}")
    
    def _enable_real_time_charts(self):
        """启用实时图表更新"""
        try:
            self.logger.info("启用实时图表更新")
            
            # 启用图表动画
            if hasattr(self, 'right_tab'):
                # IMU可视化
