        sync_layout.addRow("融合算法:", self.fusion_algorithm_combo)
        
        sync_group.setLayout(sync_layout)
        layout.addWidget(sync_group)
        
        # 同步控制面板
        control_group = QGroupBox("同步控制")
        control_layout = QHBoxLayout()
        
        self.start_sync_btn = QPushButton("▶️ 开始同步")
        self.pause_sync_btn = QPushButton("⏸️ 暂停同步")
        self.stop_sync_btn = QPushButton("⏹️ 停止同步")
        
        control_layout.addWidget(self.start_sync_btn)
        control_layout.addWidget(self.pause_sync_btn)
        control_layout.addWidget(self.stop_sync_btn)
        
        control_group.setLayout(control_layout)
        layout.addWidget(control_group)
        
        # 实时监控面板
        monitor_group = QGroupBox("实时监控")
        monitor_layout = QGridLayout()
        
        # 频率监控
        self.imu_freq_label = QLabel("IMU: 0 Hz")
        self.cnap_freq_label = QLabel("CNAP: 0 Hz")
        self.fusion_freq_label = QLabel("融合: 0 Hz")
        
        # 性能指标
        self.latency_label = QLabel("延迟: 0 ms")
        self.quality_label = QLabel("质量: 0%")
        
        monitor_layout.addWidget(QLabel("数据频率:"), 0, 0)
        monitor_layout.addWidget(self.imu_freq_label, 0, 1)
        monitor_layout.addWidget(self.cnap_freq_label, 0, 2)
        monitor_layout.addWidget(self.fusion_freq_label, 0, 3)
        
        monitor_layout.addWidget(QLabel("性能指标:"), 1, 0)
        monitor_layout.addWidget(self.latency_label, 1, 1)
        monitor_layout.addWidget(self.quality_label, 1, 2)
        
        monitor_group.setLayout(monitor_layout)
        layout.addWidget(monitor_group)
        
        # 高级配置面板
        config_group = QGroupBox("高级配置")
        config_layout = QHBoxLayout()
        
        self.save_config_btn = QPushButton("💾 保存配置")
        self.reset_config_btn = QPushButton("🔄 重置配置")
        self.import_config_btn = QPushButton("📥 导入配置")
        self.export_config_btn = QPushButton("📤 导出配置")
        
        config_layout.addWidget(self.save_config_btn)
        config_layout.addWidget(self.reset_config_btn)
        config_layout.addWidget(self.import_config_btn)
        config_layout.addWidget(self.export_config_btn)
        
        config_group.setLayout(config_layout)
        layout.addWidget(config_group)
        
        # 连接信号
        self._connect_data_source_signals()
    
    def _init_source_status_list(self):
        """初始化数据源状态列表"""
        try:
            self.source_status_list.clear()
            
            # 添加默认状态项
            default_items = [
                ("📱 IMU", "○ 未连接", "#6c757d"),
                ("💓 CNAP", "○ 未连接", "#6c757d"),
                ("📡 MQTT", "○ 未连接", "#6c757d"),
                ("🔌 串口", "○ 未连接", "#6c757d"),
                ("📁 文件", "○ 未连接", "#6c757d")
            ]
            
            for source_name, status, color in default_items:
                item = QListWidgetItem(f"{source_name} {status}")
                item.setForeground(QColor(color))
                self.source_status_list.addItem(item)
                
        except Exception as e:
            print(f"初始化数据源状态列表失败: {e}")
    
    def _connect_data_source_signals(self):
        """连接数据源相关信号"""
        try:
            # 连接添加数据源按钮
            self.add_imu_btn.clicked.connect(self._add_imu_data_source)
            self.add_cnap_btn.clicked.connect(self._add_cnap_data_source)
            self.add_mqtt_btn.clicked.connect(self._add_mqtt_data_source)
            self.add_serial_btn.clicked.connect(self._add_serial_data_source)
            self.add_file_btn.clicked.connect(self._add_file_data_source)
            
            # 连接刷新状态按钮
            self.refresh_status_btn.clicked.connect(self._refresh_source_status)
            
            # 连接同步控制按钮
            self.start_sync_btn.clicked.connect(self._start_data_sync)
            self.pause_sync_btn.clicked.connect(self._pause_data_sync)
            self.stop_sync_btn.clicked.connect(self._stop_data_sync)
            
            # 连接配置按钮
            self.save_config_btn.clicked.connect(self._save_current_config)
            self.reset_config_btn.clicked.connect(self._reset_config_to_default)
            self.import_config_btn.clicked.connect(self._show_import_config_dialog)
            self.export_config_btn.clicked.connect(self._show_export_config_dialog)
            
            # 连接配置变更信号
            self.sync_mode_combo.currentTextChanged.connect(self._on_sync_mode_changed)
            self.time_window_spin.valueChanged.connect(self._on_time_window_changed)
            self.interpolation_combo.currentTextChanged.connect(self._on_interpolation_changed)
            self.fusion_algorithm_combo.currentTextChanged.connect(self._on_fusion_algorithm_changed)
            
        except Exception as e:
            print(f"连接数据源信号失败: {e}")
    
    def _add_imu_data_source(self):
        """添加IMU数据源"""
        try:
            if self.logger:
                self.logger.info("添加IMU数据源")
            else:
                print("添加IMU数据源")
            
            if self.data_source_manager:
                # 创建IMU数据源配置
                from core.data_processing.unified_data_source_manager import (
                    DataSourceConfig, DataSourceType, TransmissionType, 
                    DataFormat, SamplingRate
                )
                
                imu_config = DataSourceConfig(
                    source_id="imu_sensor_001",
                    name="IMU传感器",
                    source_type=DataSourceType.IMU,
                    transmission_type=TransmissionType.SIMULATED,  # 先使用模拟数据
                    data_format=DataFormat.JSON,
                    sampling_rate=SamplingRate.HIGH,
                    connection_params={
                        "port": "COM3",
                        "baud_rate": 115200,
                        "data_bits": 8,
                        "stop_bits": 1,
                        "parity": "none"
                    },
                    auto_connect=True
                )
                
                # 添加到数据源管理器
                success = self.data_source_manager.add_data_source(imu_config)
                
                if success:
                    # 尝试连接
                    connect_success = self.data_source_manager.connect_data_source("imu_sensor_001")
                    if connect_success:
                        self._update_source_status("IMU", "● 已连接", "#28a745")
                        if self.logger:
                            self.logger.info("IMU数据源添加并连接成功")
                        else:
                            print("IMU数据源添加并连接成功")
                    else:
                        self._update_source_status("IMU", "○ 连接失败", "#dc3545")
                        if self.logger:
                            self.logger.error("IMU数据源连接失败")
                        else:
                            print("IMU数据源连接失败")
                else:
                    self._update_source_status("IMU", "○ 添加失败", "#dc3545")
                    if self.logger:
                        self.logger.error("IMU数据源添加失败")
                    else:
                        print("IMU数据源添加失败")
            else:
                # 如果没有数据源管理器，使用模拟状态
                self._update_source_status("IMU", "● 已连接", "#28a745")
                print("数据源管理器不可用，使用模拟状态")
            
        except Exception as e:
            error_msg = f"添加IMU数据源失败: {e}"
            if self.logger:
