    def _update_source_status(self, source_type, status, color):
        """更新数据源状态"""
        try:
            # 在状态列表中查找对应的数据源
            for i in range(self.source_status_list.count()):
                item = self.source_status_list.item(i)
                item_text = item.text()
                
                if source_type in item_text:
                    # 更新状态
                    if "IMU" in source_type:
                        new_text = f"📱 IMU {status}"
                    elif "CNAP" in source_type:
                        new_text = f"💓 CNAP {status}"
                    elif "MQTT" in source_type:
                        new_text = f"📡 MQTT {status}"
                    elif "串口" in source_type:
                        new_text = f"🔌 串口 {status}"
                    elif "文件" in source_type:
                        new_text = f"📁 文件 {status}"
                    else:
                        new_text = f"🔗 {source_type} {status}"
                    
                    item.setText(new_text)
                    item.setForeground(QColor(color))
                    break
                    
        except Exception as e:
            print(f"更新数据源状态失败: {e}")
    
    def _refresh_source_status(self):
        """刷新数据源状态"""
        try:
            if self.logger:
                self.logger.info("刷新数据源状态")
            else:
                print("刷新数据源状态")
            
            if self.data_source_manager:
                # 从真实的数据源管理器获取状态
                self._update_source_status_from_manager()
            else:
                # 模拟刷新状态
                print("数据源管理器不可用，使用模拟状态")
                self._init_source_status_list()
            
            # 更新性能指标
            self._update_performance_metrics()
            
        except Exception as e:
            error_msg = f"刷新数据源状态失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
    
    def _update_source_status_from_manager(self):
        """从数据源管理器更新状态"""
        try:
            if not self.data_source_manager:
                return
            
            # 清空状态列表
            self.source_status_list.clear()
            
            # 获取所有数据源状态
            for source_id, status_info in self.data_source_manager.source_statuses.items():
                source_name = ""
                status_icon = ""
                status_color = ""
                
                # 根据数据源类型设置名称和图标
                if "imu" in source_id.lower():
                    source_name = "📱 IMU"
                elif "cnap" in source_id.lower():
                    source_name = "💓 CNAP"
                elif "file" in source_id.lower():
                    source_name = "📁 文件"
                elif "mqtt" in source_id.lower():
                    source_name = "📡 MQTT"
                elif "serial" in source_id.lower():
                    source_name = "🔌 串口"
                else:
                    source_name = f"🔗 {source_id}"
                
                # 根据状态设置图标和颜色
                if status_info.status == "CONNECTED":
                    status_icon = "● 已连接"
                    status_color = "#28a745"
                elif status_info.status == "CONNECTING":
                    status_icon = "⏳ 连接中"
                    status_color = "#ffc107"
                elif status_info.status == "ERROR":
                    status_icon = "❌ 错误"
                    status_color = "#dc3545"
                elif status_info.status == "DISCONNECTED":
                    status_icon = "○ 未连接"
                    status_color = "#6c757d"
                else:
                    status_icon = "○ 未知"
                    status_color = "#6c757d"
                
                # 创建列表项
                item = QListWidgetItem(f"{source_name} {status_icon}")
                item.setForeground(QColor(color))
                self.source_status_list.addItem(item)
            
            # 如果没有数据源，显示默认状态
            if self.source_status_list.count() == 0:
                self._init_source_status_list()
            
        except Exception as e:
            error_msg = f"从数据源管理器更新状态失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
            # 回退到默认状态
            self._init_source_status_list()
    
    def _start_data_sync(self):
        """开始数据同步"""
        try:
            if self.logger:
                self.logger.info("开始数据同步")
            else:
                print("开始数据同步")
            
            # 获取同步配置
            sync_mode = self.sync_mode_combo.currentText()
            time_window = self.time_window_spin.value()
            interpolation = self.interpolation_combo.currentText()
            fusion_algorithm = self.fusion_algorithm_combo.currentText()
            
            if self.logger:
                self.logger.info(f"同步配置: 模式={sync_mode}, 时间窗口={time_window}s, 插值={interpolation}, 融合={fusion_algorithm}")
            else:
                print(f"同步配置: 模式={sync_mode}, 时间窗口={time_window}s, 插值={interpolation}, 融合={fusion_algorithm}")
            
            if self.data_source_manager:
                # 启动真实的数据同步
                success = self.data_source_manager.start_sync()
                if success:
                    if self.logger:
                        self.logger.info("数据同步启动成功")
                    else:
                        print("数据同步启动成功")
                    
                    # 启动定时器更新性能指标
                    self._start_performance_monitoring()
                else:
                    if self.logger:
                        self.logger.error("数据同步启动失败")
                    else:
                        print("数据同步启动失败")
            else:
                # 模拟数据同步
                print("数据源管理器不可用，使用模拟同步")
                self._start_performance_monitoring()
            
        except Exception as e:
            error_msg = f"开始数据同步失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
    
    def _stop_data_sync(self):
        """停止数据同步"""
        try:
            if self.logger:
                self.logger.info("停止数据同步")
            else:
                print("停止数据同步")
            
            if self.data_source_manager:
                # 停止真实的数据同步
                success = self.data_source_manager.stop_sync()
                if success:
                    if self.logger:
                        self.logger.info("数据同步停止成功")
                    else:
                        print("数据同步停止成功")
                else:
                    if self.logger:
                        self.logger.error("数据同步停止失败")
                    else:
                        print("数据同步停止失败")
            
            # 停止性能监控
            self._stop_performance_monitoring()
            
        except Exception as e:
            error_msg = f"停止数据同步失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
    
