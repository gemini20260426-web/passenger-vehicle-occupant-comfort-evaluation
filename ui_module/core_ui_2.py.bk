    def _update_performance_metrics(self):
        """更新性能指标"""
        try:
            if self.data_source_manager and self.data_source_manager.sync_running:
                # 从真实的数据源管理器获取性能指标
                self._update_real_performance_metrics()
            else:
                # 模拟更新性能指标
                self._update_simulated_performance_metrics()
            
        except Exception as e:
            error_msg = f"更新性能指标失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
    
    def _update_real_performance_metrics(self):
        """更新真实的性能指标"""
        try:
            if not self.data_source_manager:
                return
            
            # 获取IMU数据源状态
            imu_freq = 0
            cnap_freq = 0
            fusion_freq = 0
            latency = 0
            quality = 0
            
            # 遍历所有数据源获取性能指标
            for source_id, status_info in self.data_source_manager.source_statuses.items():
                if status_info.status == "CONNECTED":
                    if "imu" in source_id.lower():
                        # 从状态信息获取IMU频率
                        imu_freq = getattr(status_info, 'sampling_rate_hz', 100)
                        latency = getattr(status_info, 'latency_ms', 15)
                    elif "cnap" in source_id.lower():
                        # 从状态信息获取CNAP频率
                        cnap_freq = getattr(status_info, 'sampling_rate_hz', 1)
                    elif "fusion" in source_id.lower():
                        # 从状态信息获取融合频率
                        fusion_freq = getattr(status_info, 'sampling_rate_hz', 100)
            
            # 计算数据质量（基于错误率和连接状态）
            total_sources = len(self.data_source_manager.source_statuses)
            connected_sources = sum(1 for s in self.data_source_manager.source_statuses.values() 
   if s.status == "CONNECTED")
            quality = int((connected_sources / total_sources) * 100) if total_sources > 0 else 0
            
            # 更新UI标签
            self.imu_freq_label.setText(f"IMU: {imu_freq} Hz")
            self.cnap_freq_label.setText(f"CNAP: {cnap_freq} Hz")
            self.fusion_freq_label.setText(f"融合: {fusion_freq} Hz")
            self.latency_label.setText(f"延迟: {latency} ms")
            self.quality_label.setText(f"质量: {quality}%")
            
        except Exception as e:
            error_msg = f"更新真实性能指标失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
            # 回退到模拟指标
            self._update_simulated_performance_metrics()
    
    def _update_simulated_performance_metrics(self):
        """更新模拟的性能指标"""
        try:
            import random
            
            # 更新频率标签
            self.imu_freq_label.setText(f"IMU: {random.randint(95, 105)} Hz")
            self.cnap_freq_label.setText(f"CNAP: {random.randint(1, 2)} Hz")
            self.fusion_freq_label.setText(f"融合: {random.randint(95, 105)} Hz")
            
            # 更新延迟和质量标签
            self.latency_label.setText(f"延迟: {random.randint(10, 25)} ms")
            self.quality_label.setText(f"质量: {random.randint(95, 100)}%")
            
        except Exception as e:
            error_msg = f"更新模拟性能指标失败: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(error_msg)
    
    def _start_performance_monitoring(self):
        """开始性能监控"""
        try:
            # 创建定时器更新性能指标
            from PySide6.QtCore import QTimer
            self.performance_timer = QTimer()
            self.performance_timer.timeout.connect(self._update_performance_metrics)
            self.performance_timer.start(1000)  # 每秒更新一次
            
            print("性能监控已启动")
            
        except Exception as e:
            print(f"启动性能监控失败: {e}")
    
    def _stop_performance_monitoring(self):
        """停止性能监控"""
        try:
            if hasattr(self, 'performance_timer'):
                self.performance_timer.stop()
                print("性能监控已停止")
            
        except Exception as e:
            print(f"停止性能监控失败: {e}")
        
